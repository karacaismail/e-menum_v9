{
  "metadata": {
    "document": "E-Menum Reporting Features Part 5",
    "section": "Platform Reports, RBAC Matrix, Plan Limits",
    "version": "3.0.0"
  },
  "FEATURES": {
    "PLATFORM_REPORTS": [
      {
        "feature_key": "report_platform_mrr_dashboard",
        "feature_id": "RPT-PLT-001",
        "name_tr": "MRR/ARR Dashboard",
        "name_en": "MRR/ARR Dashboard",
        "category": "PLATFORM",
        "subcategory": "financial",
        "type": "boolean",
        "default_value": true,
        "description_tr": "Aylık ve yıllık tekrarlayan gelir takibi",
        "description_en": "Monthly and annual recurring revenue tracking",
        "access_level": "super_admin",
        "ai_model": {
          "primary": "claude-sonnet",
          "fallback": "gpt-4o"
        },
        "credit_cost": 0,
        "real_time": true,
        "metrics": [
          {
            "metric": "mrr",
            "name_tr": "Aylık Tekrarlayan Gelir",
            "formula": "sum(active_subscriptions * monthly_price)",
            "format": "currency"
          },
          {
            "metric": "arr",
            "name_tr": "Yıllık Tekrarlayan Gelir",
            "formula": "MRR * 12",
            "format": "currency"
          },
          {
            "metric": "mrr_growth",
            "name_tr": "MRR Büyümesi",
            "format": "percentage"
          },
          {
            "metric": "new_mrr",
            "name_tr": "Yeni MRR",
            "description": "Yeni müşterilerden gelen"
          },
          {
            "metric": "expansion_mrr",
            "name_tr": "Genişleme MRR",
            "description": "Upgrade'lerden gelen"
          },
          {
            "metric": "contraction_mrr",
            "name_tr": "Daralma MRR",
            "description": "Downgrade'lerden kayıp"
          },
          {
            "metric": "churned_mrr",
            "name_tr": "Kayıp MRR",
            "description": "İptallerden kayıp"
          },
          {
            "metric": "net_mrr_change",
            "name_tr": "Net MRR Değişimi",
            "formula": "new + expansion - contraction - churned"
          }
        ],
        "breakdowns": [
          "by_plan",
          "by_region",
          "by_acquisition_channel",
          "by_cohort"
        ],
        "visualizations": [
          "mrr_trend_chart",
          "mrr_waterfall",
          "plan_distribution",
          "growth_components"
        ],
        "priority": "P0",
        "implementation_status": "planned",
        "estimated_effort_days": 10
      },
      {
        "feature_key": "report_platform_churn_analysis",
        "feature_id": "RPT-PLT-002",
        "name_tr": "Churn Analizi",
        "name_en": "Churn Analysis",
        "category": "PLATFORM",
        "subcategory": "retention",
        "type": "boolean",
        "default_value": true,
        "description_tr": "Platform müşteri kaybı analizi ve tahmin",
        "description_en": "Platform customer churn analysis and prediction",
        "access_level": "super_admin",
        "ai_model": {
          "primary": "ml_churn_prediction",
          "secondary": "claude-sonnet"
        },
        "credit_cost": 0,
        "churn_metrics": [
          {
            "metric": "customer_churn_rate",
            "name_tr": "Müşteri Churn Oranı",
            "formula": "churned_customers / total_customers",
            "period": "monthly"
          },
          {
            "metric": "revenue_churn_rate",
            "name_tr": "Gelir Churn Oranı",
            "formula": "churned_mrr / total_mrr",
            "period": "monthly"
          },
          {
            "metric": "net_revenue_retention",
            "name_tr": "Net Gelir Tutma",
            "formula": "(starting_mrr + expansion - contraction - churn) / starting_mrr",
            "target": ">100%"
          },
          {
            "metric": "logo_retention",
            "name_tr": "Logo Tutma",
            "formula": "(starting_customers - churned) / starting_customers"
          }
        ],
        "churn_analysis": {
          "by_plan": true,
          "by_tenure": true,
          "by_usage": true,
          "by_industry": true,
          "by_size": true
        },
        "prediction_features": {
          "at_risk_customers": true,
          "churn_probability_score": true,
          "recommended_interventions": true,
          "revenue_at_risk": true
        },
        "early_warning_signals": [
          "usage_decline",
          "support_tickets_increase",
          "login_frequency_drop",
          "feature_adoption_stall",
          "billing_issues"
        ],
        "priority": "P0",
        "implementation_status": "planned",
        "estimated_effort_days": 15
      },
