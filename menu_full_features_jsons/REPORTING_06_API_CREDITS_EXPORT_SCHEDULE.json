  "EXPORT_FEATURES": {
    "formats": {
      "pdf": {
        "format_id": "EXP-001",
        "name": "PDF Export",
        "mime_type": "application/pdf",
        "features": {
          "ai_summary": true,
          "charts": true,
          "tables": true,
          "custom_branding": true,
          "watermark": "plan-dependent"
        },
        "options": {
          "page_size": ["A4", "Letter", "Legal"],
          "orientation": ["portrait", "landscape"],
          "include_cover": true,
          "include_toc": true,
          "color_mode": ["color", "grayscale"]
        },
        "credits": 2,
        "plan_availability": {
          "free": false,
          "lite": true,
          "pro": true,
          "business": true,
          "enterprise": true
        }
      },
      "excel": {
        "format_id": "EXP-002",
        "name": "Excel Export",
        "mime_type": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "features": {
          "multiple_sheets": true,
          "formulas": true,
          "charts": true,
          "pivot_ready": true,
          "formatting": true
        },
        "options": {
          "include_charts": true,
          "freeze_headers": true,
          "auto_filter": true
        },
        "credits": 0,
        "plan_availability": {
          "free": false,
          "lite": true,
          "pro": true,
          "business": true,
          "enterprise": true
        }
      },
      "csv": {
        "format_id": "EXP-003",
        "name": "CSV Export",
        "mime_type": "text/csv",
        "features": {
          "raw_data": true,
          "large_datasets": true
        },
        "options": {
          "delimiter": [",", ";", "tab"],
          "encoding": ["UTF-8", "UTF-16", "ISO-8859-1"],
          "include_headers": true
        },
        "credits": 0,
        "plan_availability": {
          "free": false,
          "lite": true,
          "pro": true,
          "business": true,
          "enterprise": true
        }
      },
      "json": {
        "format_id": "EXP-004",
        "name": "JSON Export",
        "mime_type": "application/json",
        "features": {
          "api_integration": true,
          "structured_data": true
        },
        "options": {
          "pretty_print": true,
          "include_metadata": true
        },
        "credits": 0,
        "plan_availability": {
          "free": false,
          "lite": false,
          "pro": false,
          "business": true,
          "enterprise": true
        }
      }
    },
    "limits_by_plan": {
      "free": {"exports_per_month": 0},
      "lite": {"exports_per_month": 5, "max_rows": 1000},
      "pro": {"exports_per_month": 30, "max_rows": 10000},
      "business": {"exports_per_month": 100, "max_rows": 100000},
      "enterprise": {"exports_per_month": -1, "max_rows": -1}
    }
  },
