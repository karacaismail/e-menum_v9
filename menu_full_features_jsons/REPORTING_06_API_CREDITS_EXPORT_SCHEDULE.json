{
  "metadata": {
    "document": "E-Menum Reporting Features Part 6",
    "section": "API Endpoints, Credit System, Export, Scheduling, Management",
    "version": "3.0.0"
  },
  "API_ENDPOINTS": {
    "base_url": "https://api.e-menum.net/v2/reports",
    "authentication": {
      "type": "Bearer Token",
      "header": "Authorization: Bearer {token}",
      "token_expiry": "24 hours"
    },
    "rate_limits": {
      "free": {"requests_per_minute": 10, "requests_per_day": 100},
      "lite": {"requests_per_minute": 30, "requests_per_day": 500},
      "pro": {"requests_per_minute": 60, "requests_per_day": 2000},
      "business": {"requests_per_minute": 120, "requests_per_day": 10000},
      "enterprise": {"requests_per_minute": 300, "requests_per_day": -1}
    },
    "endpoints": {
      "natural_language_query": [
        {
          "endpoint": "POST /query",
          "description": "Doğal dil sorgusu gönder",
          "request_body": {
            "query": "string (required) - Doğal dil sorgusu",
            "context": "object (optional) - Ek bağlam",
            "response_format": "string (optional) - text|json|chart",
            "language": "string (optional) - tr|en"
          },
          "response": {
            "success": true,
            "data": {
              "answer": "string - AI yanıtı",
              "data_points": "array - Kullanılan veriler",
              "charts": "array - Grafik verileri",
              "confidence": "number - Güven skoru",
              "credits_used": "number"
            }
          },
          "credits": "1-10 (kompleksiteye göre)"
        },
        {
          "endpoint": "POST /query/stream",
          "description": "Streaming doğal dil sorgusu (SSE)",
          "request_body": {
            "query": "string (required)",
            "stream": true
          },
          "response_type": "Server-Sent Events",
          "events": ["thinking", "data", "chart", "complete", "error"]
        },
        {
          "endpoint": "GET /query/history",
          "description": "Sorgu geçmişi",
          "query_params": {
            "limit": "number (default: 20)",
            "offset": "number (default: 0)",
            "from_date": "ISO date",
            "to_date": "ISO date"
          }
        },
        {
          "endpoint": "GET /query/suggestions",
          "description": "Önerilen sorgular",
          "query_params": {
            "context": "string - dashboard|menu|sales|staff"
          },
          "response": {
            "suggestions": ["Dün kaç sipariş geldi?", "Bu haftanın cirosu ne?", "..."]
          }
        }
      ],
      "preset_reports": [
        {
          "endpoint": "GET /presets",
          "description": "Mevcut preset raporları listele",
          "query_params": {
            "category": "string - periodic|sales|menu|...",
            "include_disabled": "boolean (default: false)"
          },
          "response": {
            "reports": [
              {
                "report_id": "RPT-PER-001",
                "key": "report_daily_summary",
                "name": "Günlük Özet Raporu",
                "category": "periodic",
                "auto_generate": true,
                "credits": 0,
                "enabled": true
              }
            ]
          }
        },
        {
          "endpoint": "POST /presets/{report_id}/run",
          "description": "Preset raporu çalıştır",
          "path_params": {
            "report_id": "string - Rapor ID"
          },
          "request_body": {
            "date_range": {
              "start": "ISO date",
              "end": "ISO date"
            },
            "filters": "object (optional)",
            "output_format": "string - dashboard|pdf|excel|json"
          },
          "response": {
            "report": {
              "generated_at": "ISO datetime",
              "data": "object - Rapor verisi",
              "ai_summary": "string - AI özeti",
              "charts": "array - Grafikler"
            }
          }
        },
        {
          "endpoint": "GET /presets/{report_id}/config",
          "description": "Rapor konfigürasyonunu getir"
        },
        {
          "endpoint": "PUT /presets/{report_id}/config",
          "description": "Rapor konfigürasyonunu güncelle",
          "request_body": {
            "enabled": "boolean",
            "auto_generate": "boolean",
            "delivery_channels": "array",
            "notification_recipients": "array"
          }
        }
      ],
      "custom_reports": [
        {
          "endpoint": "POST /custom/create",
          "description": "Yeni özel rapor oluştur",
          "request_body": {
            "name": "string (required)",
            "description": "string (optional)",
            "metrics": "array (required) - Seçilen metrikler",
            "dimensions": "array (required) - Boyutlar",
            "filters": "object (optional)",
            "visualizations": "array (optional)",
            "schedule": "object (optional)"
          },
          "response": {
            "report_id": "string",
            "created_at": "ISO datetime"
          }
        },
        {
          "endpoint": "GET /custom",
          "description": "Özel raporları listele"
        },
        {
          "endpoint": "GET /custom/{report_id}",
          "description": "Özel rapor detayı"
        },
        {
          "endpoint": "PUT /custom/{report_id}",
          "description": "Özel raporu güncelle"
        },
        {
          "endpoint": "DELETE /custom/{report_id}",
          "description": "Özel raporu sil"
        },
        {
          "endpoint": "POST /custom/{report_id}/run",
          "description": "Özel raporu çalıştır"
        },
        {
          "endpoint": "POST /custom/{report_id}/duplicate",
          "description": "Özel raporu kopyala"
        }
      ],
      "scheduled_reports": [
        {
          "endpoint": "POST /schedules",
          "description": "Yeni zamanlanmış rapor oluştur",
          "request_body": {
            "report_id": "string (required) - Rapor ID (preset veya custom)",
            "frequency": "string (required) - daily|weekly|monthly",
            "day_of_week": "number (optional) - 0-6 for weekly",
            "day_of_month": "number (optional) - 1-28 for monthly",
            "time": "string (required) - HH:mm",
            "timezone": "string (required)",
            "recipients": "array (required) - Email adresleri",
            "format": "string (required) - pdf|excel|email_body",
            "enabled": "boolean (default: true)"
          }
        },
        {
          "endpoint": "GET /schedules",
          "description": "Zamanlanmış raporları listele"
        },
        {
          "endpoint": "GET /schedules/{schedule_id}",
          "description": "Zamanlanmış rapor detayı"
        },
        {
          "endpoint": "PUT /schedules/{schedule_id}",
          "description": "Zamanlanmış raporu güncelle"
        },
        {
          "endpoint": "DELETE /schedules/{schedule_id}",
          "description": "Zamanlanmış raporu sil"
        },
        {
          "endpoint": "POST /schedules/{schedule_id}/run-now",
          "description": "Zamanlanmış raporu hemen çalıştır"
        },
        {
          "endpoint": "GET /schedules/{schedule_id}/history",
          "description": "Çalıştırma geçmişi"
        }
      ],
      "export": [
        {
          "endpoint": "POST /export",
          "description": "Rapor dışa aktar",
          "request_body": {
            "report_type": "string (required) - preset|custom|query",
            "report_id": "string (conditional)",
            "query_result_id": "string (conditional)",
            "format": "string (required) - pdf|excel|csv|json",
            "options": {
              "include_charts": "boolean",
              "include_ai_summary": "boolean",
              "page_size": "string - A4|Letter",
              "orientation": "string - portrait|landscape"
            }
          },
          "response": {
            "export_id": "string",
            "status": "processing|complete|failed",
            "download_url": "string (when complete)",
            "expires_at": "ISO datetime"
          }
        },
        {
          "endpoint": "GET /export/{export_id}",
          "description": "Export durumunu kontrol et"
        },
        {
          "endpoint": "GET /export/{export_id}/download",
          "description": "Export dosyasını indir"
        }
      ],
      "insights": [
        {
          "endpoint": "GET /insights/anomalies",
          "description": "Tespit edilen anomalileri getir",
          "query_params": {
            "severity": "string - info|warning|critical",
            "metric": "string (optional)",
            "from_date": "ISO date",
            "acknowledged": "boolean"
          }
        },
        {
          "endpoint": "POST /insights/anomalies/{id}/acknowledge",
          "description": "Anomaliyi onayla"
        },
        {
          "endpoint": "GET /insights/trends",
          "description": "Tespit edilen trendleri getir"
        },
        {
          "endpoint": "GET /insights/recommendations",
          "description": "AI önerilerini getir",
          "query_params": {
            "category": "string - revenue|cost|customer|operational",
            "priority": "string - high|medium|low"
          }
        },
        {
          "endpoint": "POST /insights/recommendations/{id}/dismiss",
          "description": "Öneriyi kapat"
        },
        {
          "endpoint": "POST /insights/recommendations/{id}/implement",
          "description": "Öneriyi uygula olarak işaretle"
        },
        {
          "endpoint": "POST /insights/whatif",
          "description": "What-If analizi çalıştır",
          "request_body": {
            "scenario_type": "string - pricing|capacity|menu|campaign",
            "parameters": "object - Senaryo parametreleri"
          }
        }
      ],
      "forecasting": [
        {
          "endpoint": "POST /forecast/demand",
          "description": "Talep tahmini oluştur",
          "request_body": {
            "horizon_days": "number (required) - 7|30|90",
            "granularity": "string - hourly|daily|weekly",
            "targets": "array - order_count|revenue|customer_count",
            "include_factors": "array - weather|events|promotions"
          }
        },
        {
          "endpoint": "GET /forecast/{forecast_id}",
          "description": "Tahmin sonuçlarını getir"
        },
        {
          "endpoint": "POST /forecast/revenue",
          "description": "Gelir tahmini oluştur"
        },
        {
          "endpoint": "POST /forecast/inventory",
          "description": "Stok tahmini oluştur"
        }
      ],
      "dashboard": [
        {
          "endpoint": "GET /dashboard/metrics",
          "description": "Dashboard metriklerini getir",
          "query_params": {
            "metrics": "array - revenue|orders|customers|rating",
            "period": "string - today|yesterday|this_week|this_month",
            "compare": "boolean - Karşılaştırma dahil"
          }
        },
        {
          "endpoint": "GET /dashboard/config",
          "description": "Dashboard konfigürasyonunu getir"
        },
        {
          "endpoint": "PUT /dashboard/config",
          "description": "Dashboard konfigürasyonunu güncelle"
        },
        {
          "endpoint": "GET /dashboard/widgets",
          "description": "Mevcut widget'ları getir"
        },
        {
          "endpoint": "POST /dashboard/widgets",
          "description": "Yeni widget ekle"
        }
      ],
      "realtime": [
        {
          "endpoint": "WebSocket wss://api.e-menum.net/v2/reports/live",
          "description": "Gerçek zamanlı veri akışı",
          "channels": [
            "orders",
            "revenue",
            "occupancy",
            "kitchen",
            "alerts"
          ],
          "message_format": {
            "type": "string - data|alert|heartbeat",
            "channel": "string",
            "payload": "object",
            "timestamp": "ISO datetime"
          }
        },
        {
          "endpoint": "GET /live/metrics",
          "description": "Anlık metrikleri getir (polling alternative)"
        }
      ],
      "platform_admin": [
        {
          "endpoint": "GET /platform/mrr",
          "description": "MRR dashboard verisi",
          "access": "super_admin only"
        },
        {
          "endpoint": "GET /platform/churn",
          "description": "Churn analizi",
          "access": "super_admin only"
        },
        {
          "endpoint": "GET /platform/cohort",
          "description": "Cohort analizi",
          "access": "super_admin only"
        },
        {
          "endpoint": "POST /platform/query",
          "description": "Platform seviyesi NL sorgu",
          "access": "super_admin only"
        },
        {
          "endpoint": "GET /platform/ai-usage",
          "description": "AI kullanım raporu",
          "access": "super_admin only"
        },
        {
          "endpoint": "GET /platform/health",
          "description": "Sistem sağlığı",
          "access": "super_admin only"
        }
      ]
    },
    "error_codes": {
      "400": "Bad Request - Geçersiz istek",
      "401": "Unauthorized - Yetkilendirme hatası",
      "403": "Forbidden - Erişim yetkisi yok",
      "404": "Not Found - Kaynak bulunamadı",
      "429": "Too Many Requests - Rate limit aşıldı",
      "500": "Internal Server Error - Sunucu hatası",
      "503": "Service Unavailable - Servis kullanılamıyor"
    },
    "error_response_format": {
      "success": false,
      "error": {
        "code": "string",
        "message": "string",
        "details": "object (optional)"
      }
    }
  },
