          "to_date": "ISO date",
          "group_by": "day|feature|user"
        }
      },
      {
        "endpoint": "POST /credits/purchase",
        "description": "Ek kredi satın al",
        "request_body": {
          "amount": "number - Kredi miktarı",
          "payment_method_id": "string"
        }
      }
