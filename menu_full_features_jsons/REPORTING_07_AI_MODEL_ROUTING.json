  "ROUTING_RULES": {
    "query_classification": {
      "description": "Sorgu kompleksitesine göre model seçimi",
      "rules": [
        {
          "rule_id": "ROUTE-001",
          "name": "Simple Count/Sum Queries",
          "condition": {
            "query_type": ["count", "sum", "average", "top_n", "bottom_n"],
            "complexity": "simple",
            "requires_reasoning": false
          },
          "routing": {
            "primary": "claude-haiku",
            "fallback": "gpt-4o-mini",
            "max_credits": 1
          },
          "examples": [
            "Dün kaç sipariş geldi?",
            "Bu haftanın cirosu ne?",
            "En çok satan 5 ürün?"
          ]
        },
        {
          "rule_id": "ROUTE-002",
          "name": "Comparison Queries",
          "condition": {
            "query_type": ["comparison", "vs", "trend"],
            "complexity": "medium",
            "requires_reasoning": false
          },
          "routing": {
            "primary": "claude-haiku",
            "fallback": "claude-sonnet",
            "max_credits": 2
          },
          "examples": [
            "Bu hafta vs geçen hafta?",
            "Pazartesi mi Cumartesi mi daha iyi?"
          ]
        },
        {
          "rule_id": "ROUTE-003",
          "name": "Why/Root Cause Queries",
          "condition": {
            "query_type": ["why", "root_cause", "explanation"],
            "complexity": "complex",
            "requires_reasoning": true
          },
          "routing": {
            "primary": "claude-sonnet",
            "fallback": "gpt-4o",
            "max_credits": 5
          },
          "examples": [
            "Neden satışlar düştü?",
            "Bu düşüşün sebebi ne?"
          ]
        },
        {
          "rule_id": "ROUTE-004",
          "name": "Recommendation Queries",
          "condition": {
            "query_type": ["recommendation", "what_should", "how_to"],
            "complexity": "complex",
            "requires_reasoning": true
          },
          "routing": {
            "primary": "claude-sonnet",
            "fallback": "gpt-4o",
            "max_credits": 5
          },
          "examples": [
            "Satışları nasıl artırırım?",
            "Ne yapmalıyım?"
          ]
        },
        {
          "rule_id": "ROUTE-005",
          "name": "Multi-step Complex Queries",
          "condition": {
            "query_type": ["multi_step", "strategic", "comprehensive"],
            "complexity": "very_complex",
            "requires_reasoning": true,
            "requires_multiple_data_sources": true
          },
          "routing": {
            "primary": "gpt-4o",
            "fallback": "claude-sonnet",
            "max_credits": 10
          },
          "examples": [
            "En iyi 3 şubenin ortak özellikleri ve diğerlerine nasıl uygulanır?",
            "Kapsamlı çeyrek strateji öner"
          ]
        },
        {
          "rule_id": "ROUTE-006",
          "name": "Forecast Queries",
          "condition": {
            "query_type": ["forecast", "prediction", "projection"],
            "requires_time_series": true
          },
          "routing": {
            "primary": "prophet",
            "secondary": "claude-haiku",
            "fallback": "arima",
            "max_credits": 5
          },
          "examples": [
            "Yarın ne kadar satış beklemeliyim?",
            "Önümüzdeki hafta nasıl olacak?"
          ]
        },
        {
          "rule_id": "ROUTE-007",
          "name": "Summary Queries",
          "condition": {
            "query_type": ["summary", "overview", "highlights"],
            "complexity": "medium"
          },
          "routing": {
            "primary": "claude-haiku",
            "fallback": "gpt-4o-mini",
            "max_credits": 2
          },
          "examples": [
            "Bu haftayı özetle",
            "Öne çıkan noktalar ne?"
          ]
        }
      ]
    },
