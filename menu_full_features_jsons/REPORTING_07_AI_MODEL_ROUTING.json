  "FALLBACK_LOGIC": {
    "triggers": {
      "rate_limit": {
        "description": "API rate limit aşıldığında",
        "action": "switch_to_fallback",
        "retry_after_seconds": 60
      },
      "timeout": {
        "description": "Yanıt süresi aşıldığında",
        "threshold_ms": 30000,
        "action": "switch_to_fallback"
      },
      "error_response": {
        "description": "API hata döndüğünde",
        "error_codes": [500, 502, 503, 504],
        "action": "retry_then_fallback",
        "max_retries": 2
      },
      "quality_check_fail": {
        "description": "Yanıt kalite kontrolünden geçemediğinde",
        "action": "escalate_to_higher_tier"
      },
      "model_unavailable": {
        "description": "Model geçici olarak kullanılamaz",
        "action": "immediate_fallback"
      }
    },
    "fallback_chains": {
      "llm_fast": {
        "description": "Hızlı LLM fallback zinciri",
        "chain": ["claude-haiku", "gpt-4o-mini"],
        "final_fallback": "cached_response"
      },
      "llm_balanced": {
        "description": "Dengeli LLM fallback zinciri",
        "chain": ["claude-sonnet", "gpt-4o", "claude-haiku"],
        "final_fallback": "simplified_response"
      },
      "llm_advanced": {
        "description": "Gelişmiş LLM fallback zinciri",
        "chain": ["gpt-4o", "claude-sonnet"],
        "final_fallback": "notify_user"
      },
      "forecasting": {
        "description": "Tahmin fallback zinciri",
        "chain": ["prophet", "arima", "moving_average"],
        "final_fallback": "historical_average"
      },
      "ml": {
        "description": "ML model fallback zinciri",
        "chain": ["primary_model", "backup_model", "rule_based"],
        "final_fallback": "heuristic"
      }
    },
    "graceful_degradation": {
      "enabled": true,
      "strategies": [
        {
          "condition": "all_llm_unavailable",
          "action": "serve_cached_insights",
          "notification": "inform_user_of_limited_service"
        },
        {
          "condition": "forecasting_unavailable",
          "action": "show_historical_trends",
          "notification": "inform_user_forecasting_limited"
        },
        {
          "condition": "ml_models_unavailable",
          "action": "use_rule_based_alternatives",
          "notification": "inform_user_advanced_features_limited"
        }
      ]
    }
  },
  "COST_OPTIMIZATION": {
    "strategies": {
      "caching": {
        "description": "Tekrarlayan sorgular için önbellekleme",
        "enabled": true,
        "cache_layers": [
          {
            "layer": "query_result_cache",
            "ttl_seconds": 300,
            "max_size_mb": 500,
            "hit_rate_target": 0.3
          },
          {
            "layer": "report_cache",
            "ttl_seconds": 3600,
            "max_size_mb": 1000,
            "hit_rate_target": 0.5
          },
          {
            "layer": "forecast_cache",
            "ttl_seconds": 86400,
            "max_size_mb": 200,
            "hit_rate_target": 0.7
          }
        ],
        "invalidation_triggers": [
          "new_order",
          "data_update",
          "configuration_change"
        ]
      },
      "query_optimization": {
        "description": "Sorgu optimizasyonu",
        "techniques": [
          {
            "technique": "complexity_downgrade",
            "description": "Basit sorguları daha ucuz modele yönlendir",
            "savings_estimate": "30%"
          },
          {
            "technique": "batch_processing",
            "description": "Benzer sorguları grupla ve tek seferde işle",
            "savings_estimate": "20%"
          },
          {
            "technique": "prompt_compression",
            "description": "Prompt'u optimize ederek token sayısını azalt",
            "savings_estimate": "15%"
          },
          {
            "technique": "response_streaming",
            "description": "Streaming ile erken yanıt ver",
            "savings_estimate": "10%"
          }
        ]
      },
      "model_selection_optimization": {
        "description": "Dinamik model seçimi",
        "factors": [
          {
            "factor": "query_complexity",
            "weight": 0.4,
            "description": "Sorgu karmaşıklığına göre model seç"
          },
          {
            "factor": "user_tier",
            "weight": 0.2,
            "description": "Kullanıcı planına göre model kısıtla"
          },
          {
            "factor": "current_load",
            "weight": 0.2,
            "description": "Sistem yüküne göre model seç"
          },
          {
            "factor": "cost_budget",
            "weight": 0.2,
            "description": "Maliyet bütçesine göre model seç"
          }
        ]
      },
      "scheduled_processing": {
        "description": "Zamanlanmış işlemler için off-peak optimizasyonu",
        "enabled": true,
        "off_peak_hours": ["02:00-06:00"],
        "discount_rate": 0.5,
        "applicable_to": ["batch_reports", "forecasting", "ml_training"]
      },
      "credit_pooling": {
        "description": "Enterprise müşteriler için kredi havuzu",
        "enabled": true,
        "plan_requirement": "enterprise",
        "features": [
          "shared_credits_across_branches",
          "flexible_allocation",
          "usage_analytics"
        ]
      }
    },
    "monitoring": {
      "metrics": [
        {
          "metric": "cost_per_query",
          "target": "<$0.05",
          "alert_threshold": "$0.10"
        },
        {
          "metric": "cache_hit_rate",
          "target": ">40%",
          "alert_threshold": "<20%"
        },
        {
          "metric": "model_efficiency_score",
          "target": ">0.8",
          "alert_threshold": "<0.6"
        },
        {
          "metric": "fallback_rate",
          "target": "<5%",
          "alert_threshold": ">15%"
        }
      ],
      "dashboards": [
        "cost_analytics_dashboard",
        "model_performance_dashboard",
        "optimization_recommendations"
      ]
    }
  },
  "QUALITY_ASSURANCE": {
    "response_validation": {
      "enabled": true,
      "checks": [
        {
          "check": "factual_accuracy",
          "description": "Sayısal verilerin doğruluğu",
          "method": "cross_reference_with_data",
          "action_on_fail": "regenerate"
        },
        {
          "check": "relevance",
          "description": "Yanıtın soruyla ilgisi",
          "method": "semantic_similarity",
          "threshold": 0.7,
          "action_on_fail": "escalate"
        },
        {
          "check": "completeness",
          "description": "Yanıtın tamlığı",
          "method": "expected_elements_check",
          "action_on_fail": "supplement"
        },
