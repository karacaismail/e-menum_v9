# =============================================================================
# E-Menum Django - Docker Ignore File
# Excludes files/directories from Docker build context
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Python bytecode
__pycache__
*.py[cod]
*$py.class
*.so

# Virtual environments
venv/
env/
.venv/
.env/

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~
.sublime-*

# Local environment files (IMPORTANT: don't include secrets in build)
.env
.env.local
.env.*.local
*.env

# Keep the example
!.env.example

# Test and coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# Documentation
docs/
*.md
!README.md
LICENSE

# Development files
*.log
*.pot

# Static and media files (will be collected during build)
staticfiles/
media/

# Database files
*.sqlite3
*.db

# Docker files (don't include in context)
docker-compose*.yml
Dockerfile*
.docker/

# CI/CD
.github/
.gitlab-ci.yml
.circleci/
Jenkinsfile

# Build artifacts
dist/
build/
*.egg-info/
*.egg

# Type checking
.mypy_cache/

# macOS
.DS_Store

# Windows
Thumbs.db
Desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Auto-Claude (development)
.auto-claude/
