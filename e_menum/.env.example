# =============================================================================
# E-Menum Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control!
#
# Kullanim:
#   cp .env.example .env
#   nano .env           # degerleri duzenle
# =============================================================================


# =============================================================================
# 1. DJANGO CORE
# =============================================================================

# CRITICAL: Uretim icin benzersiz secret key olustur!
# Komut: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=xT941dKUc0EWxScDtAsP7gfiUvj9gFZA6roCOUWYVVbka41mx6

# Debug modu (uretimde MUTLAKA False!)
DEBUG=False

# Django settings modulu
# Development: config.settings.development
# Production:  config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.production

# Izin verilen hostlar (virgul ile ayir)
ALLOWED_HOSTS=e-menum.com,www.e-menum.com,api.e-menum.com

# CSRF guvenilir originler (uretim icin tam URL)
CSRF_TRUSTED_ORIGINS=https://e-menum.com,https://www.e-menum.com

# CORS izinli originler
CORS_ALLOWED_ORIGINS=https://e-menum.com,https://www.e-menum.com

# Site URL (mutlak URL uretimi icin)
SITE_URL=https://e-menum.com


# =============================================================================
# 2. POSTGRESQL DATABASE
# =============================================================================

# PostgreSQL kullanici adi
POSTGRES_USER=emenum_user

# PostgreSQL sifre (MUTLAKA degistir!)
POSTGRES_PASSWORD=l71UMOpyhPECBBzzgKj2WP5W

# PostgreSQL veritabani adi
POSTGRES_DB=emenum

# PostgreSQL port (varsayilan: 5432)
POSTGRES_PORT=5432

# Tam veritabani URL'i
# docker-compose.prod.yml bunu POSTGRES_USER/PASSWORD/DB'den OTOMATIK olusturur.
# Asagidaki satiri SADECE Docker disinda (manuel kurulum) kullaniyorsan ac:
# DATABASE_URL=postgresql://emenum_user:SIFRE@localhost:5432/emenum

# SSL zorunlu mu? (Docker icinde false, dis baglantida true)
DATABASE_SSL_REQUIRE=false


# =============================================================================
# 3. REDIS
# =============================================================================

# Redis baglanti URL'i (cache icin)
REDIS_URL=redis://redis:6379/0

# Redis port (varsayilan: 6379)
REDIS_PORT=6379


# =============================================================================
# 4. CELERY (Arkaplan Gorevler)
# =============================================================================

# Celery broker (Redis)
CELERY_BROKER_URL=redis://redis:6379/1

# Celery sonuc backend (Redis)
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Worker eslezamanlilik sayisi
CELERY_WORKER_CONCURRENCY=4


# =============================================================================
# 5. WEB SERVER
# =============================================================================

# Web uygulamasi port (varsayilan: 8000)
WEB_PORT=8000

# SSL yonlendirme (Nginx arkasinda false, direkt erisimde true)
SECURE_SSL_REDIRECT=false

# Zaman dilimi
TZ=Europe/Istanbul

# Varsayilan dil kodu
LANGUAGE_CODE=tr


# =============================================================================
# 6. DOCKER ENTRYPOINT AYARLARI
# =============================================================================

# Container basladiginda otomatik migration calistir
DJANGO_MIGRATE=true

# Container basladiginda static dosyalari topla
DJANGO_COLLECTSTATIC=true

# Superuser otomatik olusturma (ilk kurulumda true yap, sonra false)
DJANGO_CREATE_SUPERUSER=true

# Superuser e-posta
DJANGO_SUPERUSER_EMAIL=admin@emenum.com

# Superuser sifre (MUTLAKA degistir!)
DJANGO_SUPERUSER_PASSWORD=BxmtmJih0w0MQyGI


# =============================================================================
# 7. JWT AUTHENTICATION
# =============================================================================

# Access token suresi (dakika, varsayilan: 15)
JWT_ACCESS_TOKEN_LIFETIME=15

# Refresh token suresi (dakika, varsayilan: 10080 = 7 gun)
JWT_REFRESH_TOKEN_LIFETIME=10080


# =============================================================================
# 8. EMAIL
# =============================================================================

# Email backend
# Development: django.core.mail.backends.console.EmailBackend
# Production:  django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP ayarlari
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@e-menum.com


# =============================================================================
# 9. LOGGING & MONITORING
# =============================================================================

# Django log seviyesi (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# Veritabani sorgu log seviyesi
DB_LOG_LEVEL=WARNING

# Sentry DSN (hata takibi - bos birak devre disi birakir)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1


# =============================================================================
# 10. AI SERVICES (Opsiyonel)
# =============================================================================

# OpenAI API key (AI icerik uretimi icin)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4


# =============================================================================
# 11. AWS S3 STORAGE (Opsiyonel - Media dosyalari icin)
# =============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1
