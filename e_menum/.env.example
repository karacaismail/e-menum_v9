# =============================================================================
# E-Menum Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Django Core Settings
# -----------------------------------------------------------------------------

# CRITICAL: Generate a unique secret key for production!
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-change-this-in-production-use-50-char-random-string

# Debug mode (set to False in production!)
DEBUG=True

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# CSRF trusted origins (comma-separated, full URLs for production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emenum

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------

# Redis connection URL (used for caching)
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Celery Configuration
# -----------------------------------------------------------------------------

# Celery broker (Redis)
CELERY_BROKER_URL=redis://localhost:6379/1

# Celery result backend (Redis)
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Worker concurrency (number of parallel workers)
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# Access token lifetime in minutes (default: 15)
JWT_ACCESS_TOKEN_LIFETIME=15

# Refresh token lifetime in minutes (default: 10080 = 7 days)
JWT_REFRESH_TOKEN_LIFETIME=10080

# -----------------------------------------------------------------------------
# Email Configuration
# -----------------------------------------------------------------------------

# Email backend (options: django.core.mail.backends.console.EmailBackend for dev,
# django.core.mail.backends.smtp.EmailBackend for production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP settings (only needed when using SMTP backend)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@e-menum.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Django log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO

# Database query log level
DB_LOG_LEVEL=WARNING

# -----------------------------------------------------------------------------
# Sentry (Production Only)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Sentry environment name
SENTRY_ENVIRONMENT=development

# Sentry traces sample rate (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# -----------------------------------------------------------------------------
# AI Services (Optional)
# -----------------------------------------------------------------------------

# OpenAI API key for AI content generation
OPENAI_API_KEY=

# OpenAI model to use
OPENAI_MODEL=gpt-4

# -----------------------------------------------------------------------------
# AWS S3 Storage (Production)
# -----------------------------------------------------------------------------

# AWS credentials for S3 media storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-central-1

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Default timezone
TZ=Europe/Istanbul

# Default language code
LANGUAGE_CODE=tr

# Site URL (used for generating absolute URLs)
SITE_URL=http://localhost:8000
