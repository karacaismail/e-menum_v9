  "technicalSpecs": {
    "database": {
      "primaryEntities": [
        "menus",
        "categories",
        "menu_items",
        "menu_item_variants",
        "option_groups",
        "options",
        "menu_item_images",
        "menu_versions"
      ],
      "indexes": [
        "menus(organization_id, status)",
        "categories(menu_id, sort_order)",
        "menu_items(category_id, sort_order)",
        "menu_items(menu_id, is_active)",
        "menus(slug) WHERE status = 'published'"
      ],
      "constraints": [
        "menus.slug unique per organization",
        "categories.sort_order unique per menu",
        "menu_items.sku unique per organization (if set)"
      ]
    },
    
    "api": {
      "basePath": "/api/v1",
      "authentication": "JWT Bearer",
      "contentType": "application/json",
      "pagination": {
        "defaultLimit": 20,
        "maxLimit": 100,
        "style": "cursor-based"
      },
      "versioning": "URL path"
    },
    
    "caching": {
      "publicMenu": {
        "strategy": "stale-while-revalidate",
        "cdnTtl": "5 minutes",
        "redisTtl": "1 minute",
        "keyPattern": "menu:{slug}:{locale}:{branchId?}"
      },
      "adminData": {
        "cdnCache": false,
        "redisTtl": "30 seconds (optional)"
      },
      "invalidation": ["publish", "item.update", "stock.change"]
    },
    
    "events": {
      "emitted": [
        "menu.created",
        "menu.updated",
        "menu.published",
        "menu.unpublished",
        "menu.deleted",
        "item.created",
        "item.updated",
        "item.deleted",
        "item.stock_changed",
        "category.created",
        "category.deleted"
      ]
    }
  },

  "testing": {
    "unit": {
      "coverage": "80%",
      "focus": [
        "Price calculation",
        "Stock status logic",
        "Visibility rules",
        "Validation functions",
