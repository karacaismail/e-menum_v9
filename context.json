{
  "$schema": "https://e-menum.net/schemas/context-v1.json",
  "moduleId": "001-menu-module",
  "moduleName": "Menu Module",
  "version": "1.0.0",
  "generatedAt": "2026-01-31T21:00:00Z",
  
  "purpose": {
    "summary": "E-Menum platformunun temel modülü - dijital menü oluşturma ve yönetimi",
    "businessValue": "Restoran/kafelerin QR menülerini oluşturmasını, yönetmesini ve müşterilere sunmasını sağlar",
    "userBenefit": "İşletmeler: Kolay menü yönetimi | Müşteriler: Hızlı, interaktif menü deneyimi"
  },

  "architecture": {
    "layer": "domain",
    "pattern": "modular-monolith",
    "boundaries": {
      "owns": ["menus", "categories", "menu_items", "variants", "options"],
      "consumes": ["organizations", "branches", "users", "media"],
      "exposes": ["menu.published", "item.stock_changed"]
    }
  },

  "keyEntities": {
    "Menu": {
      "description": "Dijital menü container'ı",
      "primaryKey": "id (UUID)",
      "uniqueConstraints": ["slug per organization"],
      "relationships": {
        "belongsTo": "Organization",
        "hasMany": ["Category", "MenuItem", "MenuVersion"]
      },
      "states": ["draft", "published", "archived"],
      "criticalFields": ["slug", "status", "defaultLocale", "currency"]
    },
    
    "Category": {
      "description": "Menü kategorisi (hiyerarşik)",
      "primaryKey": "id (UUID)",
      "relationships": {
        "belongsTo": "Menu",
        "hasMany": "MenuItem",
        "selfReference": "parentId (max 3 levels)"
      },
      "criticalFields": ["menuId", "sortOrder", "isActive", "translations"]
    },
    
    "MenuItem": {
      "description": "Menü ürünü",
      "primaryKey": "id (UUID)",
      "relationships": {
        "belongsTo": ["Menu", "Category"],
        "hasMany": ["Variant", "OptionGroup", "Image"]
      },
      "criticalFields": ["basePrice", "stockStatus", "allergens", "translations"]
    },
    
    "Variant": {
      "description": "Ürün varyantı (boyut, tip)",
      "primaryKey": "id (UUID)",
      "relationships": {
        "belongsTo": "MenuItem"
      },
      "criticalFields": ["price", "attributes", "stockStatus"]
    },
    
    "OptionGroup": {
      "description": "Seçenek grubu (ekstralar)",
      "primaryKey": "id (UUID)",
      "relationships": {
        "belongsTo": "MenuItem",
        "hasMany": "Option"
      },
      "criticalFields": ["type", "isRequired", "minSelections", "maxSelections"]
    }
  },

  "apiEndpoints": {
    "management": {
      "prefix": "/api/v1/menus",
      "authentication": "required",
      "operations": [
        "GET / - List menus",
        "POST / - Create menu",
        "GET /:id - Get menu",
        "PATCH /:id - Update menu",
        "DELETE /:id - Delete menu",
        "POST /:id/publish - Publish",
        "POST /:id/unpublish - Unpublish",
        "POST /:id/duplicate - Clone"
      ]
    },
    "categories": {
      "prefix": "/api/v1/menus/:menuId/categories",
      "operations": ["GET", "POST", "PATCH /:id", "DELETE /:id", "POST /reorder"]
    },
    "items": {
      "prefix": "/api/v1/menus/:menuId/items",
      "operations": ["GET", "POST", "GET /:id", "PATCH /:id", "DELETE /:id", "POST /reorder", "PATCH /bulk", "POST /bulk-stock"]
    },
    "public": {
      "prefix": "/api/v1/public/menus",
      "authentication": "none",
      "operations": ["GET /:slug", "GET /:slug/categories", "GET /:slug/items/:itemId"]
    }
  },

  "businessRules": {
    "validation": [
      "Menu name: 2-100 chars",
      "Category name: 2-50 chars per locale",
      "Item name: 2-100 chars per locale",
      "Price: >= 0, stored in minor units (kuruş)",
      "Max categories per menu: 50",
      "Max items per category: 100",
      "Max variants per item: 10",
      "Max option groups per item: 5",
      "Max options per group: 20",
      "Max images per item: tier-based (2-10)"
    ],
    "stateTransitions": {
      "draft": ["publish → published", "archive → archived"],
      "published": ["unpublish → draft", "edit → draft (new version)"],
      "archived": ["restore → draft"]
    },
    "authorization": {
      "create_menu": ["owner"],
      "edit_menu": ["owner", "manager"],
      "delete_menu": ["owner"],
      "publish_menu": ["owner"],
      "edit_items": ["owner", "manager"],
      "update_stock": ["owner", "manager", "staff"],
      "view_menu": ["owner", "manager", "staff", "viewer"]
    }
  },

  "dataFlow": {
    "createItem": [
      "1. Validate input (Zod schema)",
      "2. Check category exists and belongs to menu",
      "3. Generate SKU if not provided",
      "4. Process translations",
      "5. Create item record",
      "6. Process variants (if any)",
      "7. Process option groups (if any)",
      "8. Invalidate cache",
      "9. Emit item.created event",
      "10. Return created item"
    ],
    "publishMenu": [
      "1. Verify user has owner role",
      "2. Validate menu completeness",
      "3. Create version snapshot",
      "4. Update status to published",
      "5. Set publishedAt timestamp",
      "6. Invalidate public cache",
      "7. Emit menu.published event",
      "8. Return updated menu"
    ],
    "publicMenuFetch": [
      "1. Check CDN cache",
      "2. Check Redis cache",
      "3. Query database (if cache miss)",
      "4. Filter by locale",
      "5. Apply visibility rules",
      "6. Format response",
      "7. Update caches",
      "8. Return menu data"
    ]
  },

  "codePatterns": {
    "serviceStructure": {
      "file": "src/modules/menu/menu.service.ts",
      "pattern": "class-based service with injected repository",
      "example": "class MenuService { constructor(private repo: MenuRepository) {} }"
    },
    "controllerStructure": {
      "file": "src/modules/menu/menu.controller.ts",
      "pattern": "Express router with middleware chain",
      "example": "router.get('/:id', auth, rbac('menu:read'), controller.getById)"
    },
    "validationPattern": {
      "library": "Zod",
      "file": "src/modules/menu/menu.schema.ts",
      "example": "const createMenuSchema = z.object({ name: z.string().min(2).max(100) })"
    },
    "repositoryPattern": {
      "orm": "Prisma",
      "file": "src/modules/menu/menu.repository.ts",
      "example": "class MenuRepository { async findById(id) { return prisma.menu.findUnique() } }"
    }
  },

