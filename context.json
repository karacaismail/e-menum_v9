  "gotchas": [
    {
      "issue": "Price stored in minor units",
      "solution": "Always divide by 100 for display, multiply by 100 for storage",
      "example": "15000 kuruş = 150.00 TL"
    },
    {
      "issue": "Cascade delete",
      "solution": "Deleting category deletes all items. Use soft delete for menus.",
      "warning": "Test delete operations carefully"
    },
    {
      "issue": "Cache invalidation",
      "solution": "Always invalidate cache after mutations",
      "pattern": "Call cacheService.invalidate('menu:{slug}') in service"
    },
    {
      "issue": "Concurrent edits",
      "solution": "Use optimistic locking with version field",
      "pattern": "Include version in update, check for conflict"
    },
    {
      "issue": "Locale fallback",
      "solution": "If translation missing, fall back to defaultLocale",
      "pattern": "translation = item.translations.find(t => t.locale === locale) || item.translations.find(t => t.locale === menu.defaultLocale)"
    }
  ],

