  "patterns": {
    "module_structure": {
      "files": ["module.json", "index.ts", "{name}.module.ts", "{name}.controller.ts", "{name}.service.ts", "{name}.repository.ts", "{name}.schema.ts", "{name}.types.ts", "{name}.routes.ts", "{name}.events.ts"],
      "description": "Each module must have manifest, public exports, and standard file structure"
    },
    "multi_tenancy": {
      "pattern": "organizationId REQUIRED on ALL tenant-scoped queries",
      "middleware": "tenant.middleware.ts sets req.organization from JWT"
    },
    "service_pattern": {
      "pattern": "Extend BaseService, use @injectable decorator, inject PrismaClient and EventService",
      "example": "@injectable() class MenuService extends BaseService<Menu>"
    },
    "controller_pattern": {
      "pattern": "Use @JsonController, @Authorized decorators, @CurrentOrg for tenant context",
      "example": "@JsonController('/api/v1/menus') @Authorized(['menu.view'])"
    },
    "error_handling": {
      "pattern": "Always throw AppException, never raw Error",
      "example": "throw new AppException('MENU_NOT_FOUND', 404)"
    },
    "validation": {
      "pattern": "All input validated with Zod schemas",
      "example": "const schema = z.object({ name: z.string().min(1) })"
    },
    "soft_delete": {
      "pattern": "Never physical delete, always set deletedAt timestamp",
      "filter": "deletedAt: null in all queries"
    },
    "import_alias": {
      "pattern": "Use @/ alias for all internal imports",
      "example": "import { BaseService } from '@/core/base/base.service'"
    }
  },
