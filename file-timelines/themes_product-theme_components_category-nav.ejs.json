      "worktree_state": {
        "content": "<%#\n  Category Navigation Component - Product Theme\n\n  Horizontal scrollable category navigation with sticky positioning.\n\n  Variables:\n  - categories: Array of category objects [{id, name, icon, itemCount}]\n%>\n<nav\n  role=\"navigation\"\n  aria-label=\"<%= typeof t === 'function' ? t('nav.categories') : 'Menu categories' %>\"\n  class=\"sticky top-16 z-20 bg-surface-card border-b border-border-color\"\n>\n  <div class=\"relative\">\n    <!-- Scroll Indicators -->\n    <div\n      class=\"absolute left-0 top-0 bottom-0 w-8 bg-gradient-to-r from-surface-card to-transparent z-10 pointer-events-none opacity-0 transition-opacity\"\n      x-data=\"{ showLeft: false }\"\n      x-init=\"$watch('$el.nextElementSibling.scrollLeft', value => showLeft = value > 20)\"\n      :class=\"{ 'opacity-100': showLeft }\"\n    ></div>\n    <div class=\"absolute right-0 top-0 bottom-0 w-8 bg-gradient-to-l from-surface-card to-transparent z-10 pointer-events-none\"></div>\n\n    <!-- Category Tabs -->\n    <ul\n      class=\"flex overflow-x-auto scrollbar-hide gap-1 px-4 py-2\"\n      role=\"tablist\"\n      aria-label=\"<%= typeof t === 'function' ? t('nav.categoryList') : 'Category list' %>\"\n    >\n      <% if (locals.categories && categories.length > 0) { %>\n        <% categories.forEach(function(category, index) { %>\n          <li role=\"presentation\" class=\"flex-shrink-0\">\n            <button\n              type=\"button\"\n              role=\"tab\"\n              :id=\"'category-tab-<%= category.id %>'\"\n              :aria-selected=\"activeCategory === '<%= category.id %>'\"\n              :aria-controls=\"'category-<%= category.id %>'\"\n              @click=\"scrollToCategory('<%= category.id %>')\"\n              class=\"flex items-center gap-2 px-4 py-2.5 rounded-full text-sm font-medium whitespace-nowrap transition-all min-h-[44px]\"\n              :class=\"activeCategory === '<%= category.id %>'\n                ? 'bg-brand-primary text-white shadow-md'\n                : 'bg-surface-elevated text-text-secondary hover:bg-surface-elevated hover:text-text-primary'\"\n            >\n              <% if (category.icon) { %>\n                <i class=\"ph ph-<%= category.icon %>\" aria-hidden=\"true\"></i>\n              <% } %>\n              <span><%= category.name %></span>\n              <% if (category.itemCount) { %>\n                <span\n                  class=\"text-xs px-1.5 py-0.5 rounded-full\"\n                  :class=\"activeCategory === '<%= category.id %>'\n                    ? 'bg-white/20'\n                    : 'bg-surface-background'\"\n                >\n                  <%= category.itemCount %>\n                </span>\n              <% } %>\n            </button>\n          </li>\n        <% }); %>\n      <% } else { %>\n        <!-- Skeleton loaders when no categories -->\n        <li class=\"flex-shrink-0\">\n          <div class=\"skeleton h-10 w-24 rounded-full\"></div>\n        </li>\n        <li class=\"flex-shrink-0\">\n          <div class=\"skeleton h-10 w-28 rounded-full\"></div>\n        </li>\n        <li class=\"flex-shrink-0\">\n          <div class=\"skeleton h-10 w-20 rounded-full\"></div>\n        </li>\n      <% } %>\n    </ul>\n  </div>\n</nav>\n\n<style>\n  /* Hide scrollbar but keep functionality */\n  .scrollbar-hide {\n    -ms-overflow-style: none;\n    scrollbar-width: none;\n  }\n  .scrollbar-hide::-webkit-scrollbar {\n    display: none;\n  }\n</style>\n",
        "last_modified": "2026-02-01T09:10:53.782153"
