      "worktree_state": {
        "content": "<%#\n  Cart View - Standalone Cart Page\n\n  Full-page cart view for reviewing items before checkout.\n  Typically used on smaller screens or when linked directly.\n\n  Variables:\n  - menu: Current menu object\n  - organization: Organization object\n  - tableNumber: Optional table number from QR scan\n  - lang: Current language code (tr/en)\n%>\n\n<section class=\"min-h-[60vh] px-4 py-6\">\n  <!-- Page Header -->\n  <header class=\"flex items-center gap-4 mb-6\">\n    <a\n      href=\"<%= locals.menu ? '/m/' + menu.slug : '/' %>\"\n      class=\"btn btn-ghost btn-icon\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.back') : 'Back to menu' %>\"\n    >\n      <i class=\"ph ph-arrow-left text-xl\" aria-hidden=\"true\"></i>\n    </a>\n    <div>\n      <h1 class=\"text-2xl font-bold text-text-primary\">\n        <%= typeof t === 'function' ? t('cart.title') : 'Your Order' %>\n      </h1>\n      <p class=\"text-sm text-text-muted\">\n        <span x-text=\"cartItemCount\"></span> <%= typeof t === 'function' ? t('cart.items') : 'items' %>\n        <% if (locals.tableNumber) { %>\n          &middot; <%= typeof t === 'function' ? t('common.table') : 'Table' %> <%= tableNumber %>\n        <% } %>\n      </p>\n    </div>\n  </header>\n\n  <!-- Empty Cart State -->\n  <template x-if=\"cart.length === 0\">\n    <div class=\"text-center py-16\">\n      <div class=\"w-24 h-24 mx-auto mb-6 rounded-full bg-surface-elevated flex items-center justify-center\">\n        <i class=\"ph ph-shopping-cart-simple text-5xl text-text-muted\" aria-hidden=\"true\"></i>\n      </div>\n      <h2 class=\"text-xl font-semibold text-text-primary mb-2\">\n        <%= typeof t === 'function' ? t('cart.empty') : 'Your cart is empty' %>\n      </h2>\n      <p class=\"text-text-muted mb-6 max-w-sm mx-auto\">\n        <%= typeof t === 'function' ? t('cart.emptyDescription') : 'Add some delicious items from the menu to get started' %>\n      </p>\n      <a\n        href=\"<%= locals.menu ? '/m/' + menu.slug : '/' %>\"\n        class=\"btn btn-primary\"\n      >\n        <i class=\"ph ph-fork-knife mr-2\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('cart.browseMenu') : 'Browse Menu' %>\n      </a>\n    </div>\n  </template>\n\n  <!-- Cart Items -->\n  <template x-if=\"cart.length > 0\">\n    <div class=\"space-y-6\">\n      <!-- Items List -->\n      <ul class=\"space-y-4\" role=\"list\" aria-label=\"<%= typeof t === 'function' ? t('cart.itemList') : 'Cart items' %>\">\n        <template x-for=\"(item, index) in cart\" :key=\"index\">\n          <li class=\"card p-4\">\n            <div class=\"flex gap-4\">\n              <!-- Item Image -->\n              <div class=\"w-20 h-20 sm:w-24 sm:h-24 flex-shrink-0 rounded-lg overflow-hidden bg-surface-elevated\">\n                <template x-if=\"item.image\">\n                  <img\n                    :src=\"item.image\"\n                    alt=\"\"\n                    class=\"w-full h-full object-cover\"\n                  >\n                </template>\n                <template x-if=\"!item.image\">\n                  <div class=\"w-full h-full flex items-center justify-center\">\n                    <i class=\"ph ph-bowl-food text-3xl text-text-muted\" aria-hidden=\"true\"></i>\n                  </div>\n                </template>\n              </div>\n\n              <!-- Item Details -->\n              <div class=\"flex-1 min-w-0\">\n                <h3 class=\"font-semibold text-text-primary\" x-text=\"item.name\"></h3>\n\n                <!-- Variants/Modifiers -->\n                <template x-if=\"item.variants.length > 0 || item.modifiers.length > 0\">\n                  <div class=\"mt-1 space-y-0.5\">\n                    <template x-for=\"v in item.variants\" :key=\"v.id\">\n                      <p class=\"text-xs text-text-secondary\">\n                        <span x-text=\"v.name\"></span>\n                        <span x-show=\"v.priceModifier > 0\" class=\"text-text-muted\" x-text=\"' (+' + formatPrice(v.priceModifier) + ')'\"></span>\n                      </p>\n                    </template>\n                    <template x-for=\"m in item.modifiers\" :key=\"m.id\">\n                      <p class=\"text-xs text-text-secondary\">\n                        <span x-text=\"'+ ' + m.name\"></span>\n                        <span class=\"text-text-muted\" x-text=\"' (+' + formatPrice(m.price) + ')'\"></span>\n                      </p>\n                    </template>\n                  </div>\n                </template>\n\n                <!-- Unit Price -->\n                <p class=\"text-sm text-text-muted mt-1\">\n                  <span x-text=\"formatPrice(item.price)\"></span>\n                  <%= typeof t === 'function' ? t('cart.each') : 'each' %>\n                </p>\n              </div>\n\n              <!-- Remove Button -->\n              <button\n                type=\"button\"\n                @click=\"removeFromCart(index)\"\n                class=\"btn btn-ghost btn-icon btn-sm self-start -mr-2 -mt-2 text-text-muted hover:text-red-500\"\n                aria-label=\"<%= typeof t === 'function' ? t('cart.removeItem') : 'Remove item' %>\"\n              >\n                <i class=\"ph ph-x\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n\n            <!-- Quantity & Subtotal -->\n            <div class=\"flex items-center justify-between mt-4 pt-4 border-t border-border-color\">\n              <div class=\"flex items-center gap-3\">\n                <button\n                  type=\"button\"\n                  @click=\"updateQuantity(index, item.quantity - 1)\"\n                  class=\"btn btn-secondary btn-icon btn-sm\"\n                  :aria-label=\"item.quantity === 1 ? '<%= typeof t === 'function' ? t('cart.removeItem') : 'Remove item' %>' : '<%= typeof t === 'function' ? t('cart.decreaseQuantity') : 'Decrease quantity' %>'\"\n                >\n                  <i :class=\"item.quantity === 1 ? 'ph ph-trash' : 'ph ph-minus'\" aria-hidden=\"true\"></i>\n                </button>\n                <span\n                  class=\"w-12 text-center text-lg font-semibold text-text-primary\"\n                  x-text=\"item.quantity\"\n                  aria-label=\"<%= typeof t === 'function' ? t('cart.quantity') : 'Quantity' %>\"\n                ></span>\n                <button\n                  type=\"button\"\n                  @click=\"updateQuantity(index, item.quantity + 1)\"\n                  class=\"btn btn-secondary btn-icon btn-sm\"\n                  :disabled=\"item.quantity >= 99\"\n                  aria-label=\"<%= typeof t === 'function' ? t('cart.increaseQuantity') : 'Increase quantity' %>\"\n                >\n                  <i class=\"ph ph-plus\" aria-hidden=\"true\"></i>\n                </button>\n              </div>\n\n              <span class=\"text-lg font-bold text-brand-primary\" x-text=\"formatPrice(item.price * item.quantity)\"></span>\n            </div>\n          </li>\n        </template>\n      </ul>\n\n      <!-- Special Instructions -->\n      <div class=\"card p-4\">\n        <label for=\"special-instructions\" class=\"block text-sm font-semibold text-text-primary mb-2\">\n          <i class=\"ph ph-note-pencil mr-1\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('cart.specialInstructions') : 'Special Instructions' %>\n        </label>\n        <textarea\n          id=\"special-instructions\"\n          x-model=\"orderNotes\"\n          rows=\"3\"\n          class=\"form-textarea w-full\"\n          placeholder=\"<%= typeof t === 'function' ? t('cart.instructionsPlaceholder') : 'Any allergies or special requests? Let us know...' %>\"\n        ></textarea>\n      </div>\n\n      <!-- Order Summary -->\n      <div class=\"card p-4 bg-surface-elevated\">\n        <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n          <%= typeof t === 'function' ? t('cart.orderSummary') : 'Order Summary' %>\n        </h2>\n\n        <div class=\"space-y-3\">\n          <div class=\"flex items-center justify-between text-sm\">\n            <span class=\"text-text-secondary\">\n              <%= typeof t === 'function' ? t('cart.subtotal') : 'Subtotal' %>\n              (<span x-text=\"cartItemCount\"></span> <%= typeof t === 'function' ? t('cart.items') : 'items' %>)\n            </span>\n            <span class=\"font-medium text-text-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n          </div>\n\n          <!-- Optional: Service charge, tax, etc. would go here -->\n          <!--\n          <div class=\"flex items-center justify-between text-sm\">\n            <span class=\"text-text-secondary\">Service Charge (10%)</span>\n            <span class=\"font-medium text-text-primary\" x-text=\"formatPrice(cartTotal * 0.1)\"></span>\n          </div>\n          -->\n\n          <hr class=\"border-border-color\">\n\n          <div class=\"flex items-center justify-between\">\n            <span class=\"text-lg font-bold text-text-primary\">\n              <%= typeof t === 'function' ? t('cart.total') : 'Total' %>\n            </span>\n            <span class=\"text-2xl font-bold text-brand-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Action Buttons -->\n      <div class=\"space-y-3\">\n        <a\n          href=\"<%= locals.menu ? '/m/' + menu.slug + '/checkout' : '/checkout' %><%= locals.tableNumber ? '?table=' + tableNumber : '' %>\"\n          class=\"btn btn-primary w-full py-4 text-lg\"\n        >\n          <i class=\"ph ph-check-circle mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('cart.proceedToCheckout') : 'Proceed to Checkout' %>\n        </a>\n\n        <div class=\"flex gap-3\">\n          <a\n            href=\"<%= locals.menu ? '/m/' + menu.slug : '/' %>\"\n            class=\"btn btn-secondary flex-1\"\n          >\n            <i class=\"ph ph-plus mr-2\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('cart.addMore') : 'Add More Items' %>\n          </a>\n\n          <button\n            type=\"button\"\n            @click=\"if(confirm('<%= typeof t === 'function' ? t('cart.clearConfirm') : 'Are you sure you want to clear your cart?' %>')) clearCart()\"\n            class=\"btn btn-ghost text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20\"\n          >\n            <i class=\"ph ph-trash mr-2\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('cart.clearCart') : 'Clear' %>\n          </button>\n        </div>\n      </div>\n\n      <!-- Payment Info -->\n      <div class=\"flex items-start gap-3 p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg\">\n        <i class=\"ph ph-info text-xl text-blue-500 flex-shrink-0 mt-0.5\" aria-hidden=\"true\"></i>\n        <div class=\"text-sm text-blue-700 dark:text-blue-300\">\n          <p class=\"font-medium mb-1\">\n            <%= typeof t === 'function' ? t('cart.paymentInfo') : 'Payment Information' %>\n          </p>\n          <p>\n            <%= typeof t === 'function' ? t('cart.paymentNote') : 'Payment will be collected at the counter or by your server after you place your order.' %>\n          </p>\n        </div>\n      </div>\n    </div>\n  </template>\n</section>\n\n<script>\n  // Initialize orderNotes in Alpine context if not already defined\n  document.addEventListener('alpine:init', () => {\n    Alpine.data('cartPage', () => ({\n      orderNotes: localStorage.getItem('orderNotes_<%= locals.menu ? menu.id : 'default' %>') || '',\n\n      init() {\n        this.$watch('orderNotes', (value) => {\n          localStorage.setItem('orderNotes_<%= locals.menu ? menu.id : 'default' %>', value);\n        });\n      }\n    }));\n  });\n</script>\n",
        "last_modified": "2026-02-01T09:10:53.772324"
      },
