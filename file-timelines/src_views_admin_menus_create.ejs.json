      },
      "worktree_state": {
        "content": "<%#\n  Create Menu View\n\n  Variables:\n  - themes: Array of available theme objects\n  - branches: Array of branch objects (for menu assignment)\n  - errors: Validation errors object\n  - formData: Previous form data (for validation errors)\n%>\n\n<div class=\"max-w-4xl mx-auto\">\n  <form\n    action=\"/admin/menus\"\n    method=\"POST\"\n    enctype=\"multipart/form-data\"\n    class=\"space-y-6\"\n    x-data=\"{\n      name: '<%= locals.formData ? formData.name : '' %>',\n      slug: '<%= locals.formData ? formData.slug : '' %>',\n      autoSlug: true,\n      generateSlug() {\n        if (this.autoSlug) {\n          this.slug = this.name\n            .toLowerCase()\n            .replace(/[^a-z0-9\\s-]/g, '')\n            .replace(/\\s+/g, '-')\n            .replace(/-+/g, '-')\n            .trim();\n        }\n      }\n    }\"\n  >\n    <!-- Basic Information -->\n    <div class=\"card p-6\">\n      <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n        <%= typeof t === 'function' ? t('menus.basicInfo') : 'Basic Information' %>\n      </h2>\n\n      <div class=\"space-y-4\">\n        <!-- Menu Name -->\n        <div>\n          <label for=\"name\" class=\"form-label\">\n            <%= typeof t === 'function' ? t('menus.name') : 'Menu Name' %> <span class=\"text-red-500\">*</span>\n          </label>\n          <input\n            type=\"text\"\n            id=\"name\"\n            name=\"name\"\n            x-model=\"name\"\n            @input=\"generateSlug()\"\n            value=\"<%= locals.formData ? formData.name : '' %>\"\n            placeholder=\"<%= typeof t === 'function' ? t('menus.namePlaceholder') : 'e.g., Lunch Menu, Dinner Menu' %>\"\n            class=\"form-input w-full <%= locals.errors && errors.name ? 'border-red-500' : '' %>\"\n            required\n          >\n          <% if (locals.errors && errors.name) { %>\n            <p class=\"form-error\"><%= errors.name %></p>\n          <% } %>\n        </div>\n\n        <!-- Slug -->\n        <div>\n          <label for=\"slug\" class=\"form-label\">\n            <%= typeof t === 'function' ? t('menus.slug') : 'URL Slug' %> <span class=\"text-red-500\">*</span>\n          </label>\n          <div class=\"flex items-center gap-2\">\n            <span class=\"text-sm text-text-muted\">/m/</span>\n            <input\n              type=\"text\"\n              id=\"slug\"\n              name=\"slug\"\n              x-model=\"slug\"\n              @input=\"autoSlug = false\"\n              value=\"<%= locals.formData ? formData.slug : '' %>\"\n              placeholder=\"<%= typeof t === 'function' ? t('menus.slugPlaceholder') : 'menu-url-slug' %>\"\n              class=\"form-input flex-1 <%= locals.errors && errors.slug ? 'border-red-500' : '' %>\"\n              pattern=\"[a-z0-9-]+\"\n              required\n            >\n            <button\n              type=\"button\"\n              @click=\"autoSlug = true; generateSlug()\"\n              class=\"btn btn-ghost btn-sm\"\n              title=\"<%= typeof t === 'function' ? t('menus.autoGenerate') : 'Auto-generate from name' %>\"\n            >\n              <i class=\"ph ph-arrows-clockwise\" aria-hidden=\"true\"></i>\n            </button>\n          </div>\n          <p class=\"form-hint\">\n            <%= typeof t === 'function' ? t('menus.slugHint') : 'This will be the URL path for your menu. Use lowercase letters, numbers, and hyphens only.' %>\n          </p>\n          <% if (locals.errors && errors.slug) { %>\n            <p class=\"form-error\"><%= errors.slug %></p>\n          <% } %>\n        </div>\n\n        <!-- Description -->\n        <div>\n          <label for=\"description\" class=\"form-label\">\n            <%= typeof t === 'function' ? t('menus.description') : 'Description' %>\n          </label>\n          <textarea\n            id=\"description\"\n            name=\"description\"\n            rows=\"3\"\n            placeholder=\"<%= typeof t === 'function' ? t('menus.descriptionPlaceholder') : 'A brief description of this menu...' %>\"\n            class=\"form-textarea w-full\"\n          ><%= locals.formData ? formData.description : '' %></textarea>\n          <p class=\"form-hint\">\n            <%= typeof t === 'function' ? t('menus.descriptionHint') : 'Optional. This description may be shown to customers.' %>\n          </p>\n        </div>\n      </div>\n    </div>\n\n    <!-- Cover Image -->\n    <div class=\"card p-6\">\n      <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n        <%= typeof t === 'function' ? t('menus.coverImage') : 'Cover Image' %>\n      </h2>\n\n      <div\n        x-data=\"{\n          preview: null,\n          handleFile(event) {\n            const file = event.target.files[0];\n            if (file) {\n              this.preview = URL.createObjectURL(file);\n            }\n          }\n        }\"\n        class=\"space-y-4\"\n      >\n        <!-- Upload Area -->\n        <div class=\"relative\">\n          <input\n            type=\"file\"\n            id=\"coverImage\"\n            name=\"coverImage\"\n            accept=\"image/jpeg,image/png,image/webp\"\n            @change=\"handleFile($event)\"\n            class=\"sr-only\"\n          >\n          <label\n            for=\"coverImage\"\n            class=\"flex flex-col items-center justify-center w-full h-48 border-2 border-dashed border-border-color rounded-lg cursor-pointer hover:bg-surface-elevated transition-colors\"\n            :class=\"{ 'border-brand-primary': preview }\"\n          >\n            <template x-if=\"!preview\">\n              <div class=\"text-center\">\n                <i class=\"ph ph-image text-4xl text-text-muted mb-2\" aria-hidden=\"true\"></i>\n                <p class=\"text-sm text-text-muted\">\n                  <%= typeof t === 'function' ? t('menus.clickToUpload') : 'Click to upload or drag and drop' %>\n                </p>\n                <p class=\"text-xs text-text-muted mt-1\">\n                  <%= typeof t === 'function' ? t('menus.imageFormats') : 'PNG, JPG, WebP (max 2MB)' %>\n                </p>\n              </div>\n            </template>\n            <template x-if=\"preview\">\n              <img :src=\"preview\" alt=\"Preview\" class=\"w-full h-full object-cover rounded-lg\">\n            </template>\n          </label>\n        </div>\n\n        <!-- Remove Button -->\n        <template x-if=\"preview\">\n          <button\n            type=\"button\"\n            @click=\"preview = null; document.getElementById('coverImage').value = ''\"\n            class=\"btn btn-ghost btn-sm text-red-600\"\n          >\n            <i class=\"ph ph-trash mr-1\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('common.remove') : 'Remove' %>\n          </button>\n        </template>\n      </div>\n    </div>\n\n    <!-- Theme Selection -->\n    <div class=\"card p-6\">\n      <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n        <%= typeof t === 'function' ? t('menus.theme') : 'Theme' %>\n      </h2>\n\n      <% if (locals.themes && themes.length > 0) { %>\n        <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n          <% themes.forEach(function(theme, index) { %>\n            <label class=\"relative cursor-pointer group\">\n              <input\n                type=\"radio\"\n                name=\"themeId\"\n                value=\"<%= theme.id %>\"\n                class=\"sr-only peer\"\n                <%= index === 0 ? 'checked' : '' %>\n              >\n              <div class=\"border-2 border-border-color rounded-lg overflow-hidden peer-checked:border-brand-primary peer-checked:ring-2 peer-checked:ring-brand-primary/20 transition-all\">\n                <!-- Theme Preview -->\n                <div class=\"aspect-video bg-surface-elevated relative overflow-hidden\">\n                  <% if (theme.preview) { %>\n                    <img src=\"<%= theme.preview %>\" alt=\"<%= theme.name %>\" class=\"w-full h-full object-cover\">\n                  <% } else { %>\n                    <div class=\"w-full h-full flex items-center justify-center\">\n                      <i class=\"ph ph-paint-brush text-3xl text-text-muted\" aria-hidden=\"true\"></i>\n                    </div>\n                  <% } %>\n\n                  <!-- Checkmark -->\n                  <div class=\"absolute top-2 right-2 w-6 h-6 rounded-full bg-brand-primary text-white flex items-center justify-center opacity-0 peer-checked:opacity-100 transition-opacity\">\n                    <i class=\"ph ph-check text-sm\" aria-hidden=\"true\"></i>\n                  </div>\n                </div>\n\n                <!-- Theme Info -->\n                <div class=\"p-3\">\n                  <p class=\"font-medium text-text-primary\"><%= theme.name %></p>\n                  <% if (theme.description) { %>\n                    <p class=\"text-xs text-text-muted mt-1 line-clamp-2\"><%= theme.description %></p>\n                  <% } %>\n                </div>\n              </div>\n            </label>\n          <% }); %>\n        </div>\n      <% } else { %>\n        <p class=\"text-text-muted\">\n          <%= typeof t === 'function' ? t('menus.noThemesAvailable') : 'No themes available. Default theme will be used.' %>\n        </p>\n        <input type=\"hidden\" name=\"themeId\" value=\"\">\n      <% } %>\n    </div>\n\n    <!-- Branch Assignment -->\n    <% if (locals.branches && branches.length > 0) { %>\n      <div class=\"card p-6\">\n        <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n          <%= typeof t === 'function' ? t('menus.branchAssignment') : 'Branch Assignment' %>\n        </h2>\n\n        <p class=\"text-sm text-text-muted mb-4\">\n          <%= typeof t === 'function' ? t('menus.branchAssignmentHint') : 'Select which branches this menu should be available at. Leave empty to make it available at all branches.' %>\n        </p>\n\n        <div class=\"space-y-2\">\n          <% branches.forEach(function(branch) { %>\n            <label class=\"flex items-center gap-3 p-3 rounded-lg hover:bg-surface-elevated cursor-pointer\">\n              <input\n                type=\"checkbox\"\n                name=\"branchIds[]\"\n                value=\"<%= branch.id %>\"\n                class=\"form-checkbox\"\n                <%= locals.formData && formData.branchIds && formData.branchIds.includes(branch.id) ? 'checked' : '' %>\n              >\n              <div>\n                <p class=\"text-sm font-medium text-text-primary\"><%= branch.name %></p>\n                <% if (branch.address) { %>\n                  <p class=\"text-xs text-text-muted\"><%= branch.address %></p>\n                <% } %>\n              </div>\n            </label>\n          <% }); %>\n        </div>\n      </div>\n    <% } %>\n\n    <!-- Settings -->\n    <div class=\"card p-6\">\n      <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n        <%= typeof t === 'function' ? t('menus.settings') : 'Settings' %>\n      </h2>\n\n      <div class=\"space-y-4\">\n        <!-- Currency -->\n        <div>\n          <label for=\"currency\" class=\"form-label\">\n            <%= typeof t === 'function' ? t('menus.currency') : 'Currency' %>\n          </label>\n          <select id=\"currency\" name=\"currency\" class=\"form-select w-full sm:w-48\">\n            <option value=\"TRY\" selected>TRY (\u20ba)</option>\n            <option value=\"USD\">USD ($)</option>\n            <option value=\"EUR\">EUR (\u20ac)</option>\n          </select>\n        </div>\n\n        <!-- Language -->\n        <div>\n          <label for=\"language\" class=\"form-label\">\n            <%= typeof t === 'function' ? t('menus.language') : 'Primary Language' %>\n          </label>\n          <select id=\"language\" name=\"language\" class=\"form-select w-full sm:w-48\">\n            <option value=\"tr\" selected><%= typeof t === 'function' ? t('languages.tr') : 'Turkish' %></option>\n            <option value=\"en\"><%= typeof t === 'function' ? t('languages.en') : 'English' %></option>\n          </select>\n        </div>\n\n        <!-- Ordering Options -->\n        <div class=\"pt-4 border-t border-border-color\">\n          <p class=\"form-label mb-3\">\n            <%= typeof t === 'function' ? t('menus.orderingOptions') : 'Ordering Options' %>\n          </p>\n\n          <div class=\"space-y-3\">\n            <label class=\"flex items-center gap-3 cursor-pointer\">\n              <input\n                type=\"checkbox\"\n                name=\"orderingEnabled\"\n                value=\"true\"\n                class=\"form-checkbox\"\n                checked\n              >\n              <div>\n                <p class=\"text-sm font-medium text-text-primary\">\n                  <%= typeof t === 'function' ? t('menus.enableOrdering') : 'Enable Online Ordering' %>\n                </p>\n                <p class=\"text-xs text-text-muted\">\n                  <%= typeof t === 'function' ? t('menus.enableOrderingHint') : 'Allow customers to place orders through this menu' %>\n                </p>\n              </div>\n            </label>\n\n            <label class=\"flex items-center gap-3 cursor-pointer\">\n              <input\n                type=\"checkbox\"\n                name=\"showPrices\"\n                value=\"true\"\n                class=\"form-checkbox\"\n                checked\n              >\n              <div>\n                <p class=\"text-sm font-medium text-text-primary\">\n                  <%= typeof t === 'function' ? t('menus.showPrices') : 'Show Prices' %>\n                </p>\n                <p class=\"text-xs text-text-muted\">\n                  <%= typeof t === 'function' ? t('menus.showPricesHint') : 'Display product prices on the menu' %>\n                </p>\n              </div>\n            </label>\n\n            <label class=\"flex items-center gap-3 cursor-pointer\">\n              <input\n                type=\"checkbox\"\n                name=\"showAllergens\"\n                value=\"true\"\n                class=\"form-checkbox\"\n                checked\n              >\n              <div>\n                <p class=\"text-sm font-medium text-text-primary\">\n                  <%= typeof t === 'function' ? t('menus.showAllergens') : 'Show Allergen Information' %>\n                </p>\n                <p class=\"text-xs text-text-muted\">\n                  <%= typeof t === 'function' ? t('menus.showAllergensHint') : 'Display allergen warnings on products' %>\n                </p>\n              </div>\n            </label>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- Form Actions -->\n    <div class=\"flex flex-col sm:flex-row gap-3 sm:justify-end\">\n      <a href=\"/admin/menus\" class=\"btn btn-ghost order-2 sm:order-1\">\n        <%= typeof t === 'function' ? t('common.cancel') : 'Cancel' %>\n      </a>\n      <button type=\"submit\" name=\"action\" value=\"draft\" class=\"btn btn-secondary order-1 sm:order-2\">\n        <i class=\"ph ph-floppy-disk mr-2\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('menus.saveAsDraft') : 'Save as Draft' %>\n      </button>\n      <button type=\"submit\" name=\"action\" value=\"publish\" class=\"btn btn-primary order-1 sm:order-3\">\n        <i class=\"ph ph-globe mr-2\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('menus.saveAndPublish') : 'Save & Publish' %>\n      </button>\n    </div>\n  </form>\n</div>\n",
