      },
      "worktree_state": {
        "content": "<%#\n  Header Component\n\n  Variables:\n  - user: Current authenticated user\n  - organization: Current organization\n  - notifications: Array of notifications\n  - breadcrumbs: Array of breadcrumb items [{label, href}]\n%>\n<header\n  role=\"banner\"\n  class=\"sticky top-0 z-30 h-16 bg-surface-card border-b border-border-color flex items-center px-4 md:px-6 gap-4\"\n>\n  <!-- Mobile Menu Toggle -->\n  <button\n    @click=\"toggleSidebar\"\n    type=\"button\"\n    class=\"btn btn-ghost btn-icon lg:hidden\"\n    aria-label=\"<%= typeof t === 'function' ? t('common.toggleMenu') : 'Toggle menu' %>\"\n    :aria-expanded=\"sidebarOpen\"\n  >\n    <i class=\"ph ph-list text-xl\" aria-hidden=\"true\"></i>\n  </button>\n\n  <!-- Desktop Sidebar Collapse Toggle -->\n  <button\n    @click=\"toggleSidebar\"\n    type=\"button\"\n    class=\"btn btn-ghost btn-icon hidden lg:flex\"\n    aria-label=\"<%= typeof t === 'function' ? t('common.toggleSidebar') : 'Toggle sidebar' %>\"\n  >\n    <i x-show=\"!sidebarCollapsed\" class=\"ph ph-sidebar-simple text-xl\" aria-hidden=\"true\"></i>\n    <i x-show=\"sidebarCollapsed\" class=\"ph ph-sidebar text-xl\" aria-hidden=\"true\"></i>\n  </button>\n\n  <!-- Breadcrumbs (Desktop) -->\n  <% if (locals.breadcrumbs && breadcrumbs.length > 0) { %>\n    <nav aria-label=\"<%= typeof t === 'function' ? t('common.breadcrumb') : 'Breadcrumb' %>\" class=\"hidden md:block\">\n      <ol class=\"flex items-center gap-2 text-sm\">\n        <li>\n          <a href=\"/admin\" class=\"text-text-muted hover:text-text-primary transition-colors\">\n            <i class=\"ph ph-house\" aria-hidden=\"true\"></i>\n            <span class=\"sr-only\"><%= typeof t === 'function' ? t('common.home') : 'Home' %></span>\n          </a>\n        </li>\n        <% breadcrumbs.forEach(function(crumb, index) { %>\n          <li class=\"flex items-center gap-2\">\n            <i class=\"ph ph-caret-right text-xs text-text-muted\" aria-hidden=\"true\"></i>\n            <% if (index === breadcrumbs.length - 1) { %>\n              <span class=\"text-text-primary font-medium\" aria-current=\"page\"><%= crumb.label %></span>\n            <% } else { %>\n              <a href=\"<%= crumb.href %>\" class=\"text-text-muted hover:text-text-primary transition-colors\">\n                <%= crumb.label %>\n              </a>\n            <% } %>\n          </li>\n        <% }); %>\n      </ol>\n    </nav>\n  <% } %>\n\n  <!-- Spacer -->\n  <div class=\"flex-1\"></div>\n\n  <!-- Search -->\n  <div x-data=\"{ searchOpen: false, query: '' }\" class=\"relative\">\n    <!-- Search Toggle (Mobile) -->\n    <button\n      @click=\"searchOpen = !searchOpen; $nextTick(() => $refs.searchInput?.focus())\"\n      type=\"button\"\n      class=\"btn btn-ghost btn-icon md:hidden\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.search') : 'Search' %>\"\n    >\n      <i class=\"ph ph-magnifying-glass text-xl\" aria-hidden=\"true\"></i>\n    </button>\n\n    <!-- Search Input (Desktop) -->\n    <div class=\"hidden md:block relative\">\n      <label for=\"header-search\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('common.search') : 'Search' %>\n      </label>\n      <i class=\"ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-text-muted\" aria-hidden=\"true\"></i>\n      <input\n        type=\"search\"\n        id=\"header-search\"\n        x-model=\"query\"\n        placeholder=\"<%= typeof t === 'function' ? t('common.searchPlaceholder') : 'Search... (Ctrl+K)' %>\"\n        class=\"form-input pl-10 pr-4 py-2 w-64 lg:w-80\"\n        @keydown.ctrl.k.window.prevent=\"$el.focus()\"\n        @keydown.meta.k.window.prevent=\"$el.focus()\"\n      >\n    </div>\n\n    <!-- Mobile Search Overlay -->\n    <div\n      x-show=\"searchOpen\"\n      x-transition:enter=\"transition ease-out duration-200\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      x-transition:leave=\"transition ease-in duration-150\"\n      x-transition:leave-start=\"opacity-100\"\n      x-transition:leave-end=\"opacity-0\"\n      class=\"fixed inset-0 bg-surface-background z-50 md:hidden flex flex-col\"\n    >\n      <div class=\"flex items-center gap-3 p-4 border-b border-border-color\">\n        <label for=\"mobile-search\" class=\"sr-only\">\n          <%= typeof t === 'function' ? t('common.search') : 'Search' %>\n        </label>\n        <i class=\"ph ph-magnifying-glass text-text-muted\" aria-hidden=\"true\"></i>\n        <input\n          type=\"search\"\n          id=\"mobile-search\"\n          x-ref=\"searchInput\"\n          x-model=\"query\"\n          placeholder=\"<%= typeof t === 'function' ? t('common.searchPlaceholder') : 'Search...' %>\"\n          class=\"flex-1 bg-transparent border-0 outline-none text-text-primary placeholder:text-text-muted\"\n          @keydown.escape=\"searchOpen = false\"\n        >\n        <button\n          @click=\"searchOpen = false\"\n          type=\"button\"\n          class=\"btn btn-ghost btn-icon\"\n          aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\"\n        >\n          <i class=\"ph ph-x text-xl\" aria-hidden=\"true\"></i>\n        </button>\n      </div>\n      <div class=\"flex-1 p-4 overflow-auto\">\n        <!-- Search results would go here -->\n        <p class=\"text-sm text-text-muted text-center py-8\">\n          <%= typeof t === 'function' ? t('common.typeToSearch') : 'Type to search...' %>\n        </p>\n      </div>\n    </div>\n  </div>\n\n  <!-- Notifications -->\n  <div x-data=\"{ open: false }\" class=\"relative\">\n    <button\n      @click=\"open = !open\"\n      @click.outside=\"open = false\"\n      type=\"button\"\n      class=\"btn btn-ghost btn-icon relative\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.notifications') : 'Notifications' %>\"\n      aria-haspopup=\"true\"\n      :aria-expanded=\"open\"\n    >\n      <i class=\"ph ph-bell text-xl\" aria-hidden=\"true\"></i>\n      <% if (locals.notifications && notifications.length > 0) { %>\n        <span class=\"absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full\" aria-hidden=\"true\"></span>\n        <span class=\"sr-only\">\n          <%= notifications.length %> <%= typeof t === 'function' ? t('common.unreadNotifications') : 'unread notifications' %>\n        </span>\n      <% } %>\n    </button>\n\n    <!-- Notifications Dropdown -->\n    <div\n      x-show=\"open\"\n      x-transition:enter=\"transition ease-out duration-100\"\n      x-transition:enter-start=\"opacity-0 scale-95\"\n      x-transition:enter-end=\"opacity-100 scale-100\"\n      x-transition:leave=\"transition ease-in duration-75\"\n      x-transition:leave-start=\"opacity-100 scale-100\"\n      x-transition:leave-end=\"opacity-0 scale-95\"\n      class=\"absolute right-0 mt-2 w-80 bg-surface-card rounded-lg shadow-lg border border-border-color overflow-hidden z-50\"\n      role=\"menu\"\n    >\n      <div class=\"flex items-center justify-between px-4 py-3 border-b border-border-color\">\n        <h3 class=\"font-semibold text-text-primary\">\n          <%= typeof t === 'function' ? t('common.notifications') : 'Notifications' %>\n        </h3>\n        <% if (locals.notifications && notifications.length > 0) { %>\n          <a href=\"/admin/notifications\" class=\"text-xs text-brand-primary hover:underline\">\n            <%= typeof t === 'function' ? t('common.viewAll') : 'View all' %>\n          </a>\n        <% } %>\n      </div>\n\n      <div class=\"max-h-80 overflow-y-auto\">\n        <% if (!locals.notifications || notifications.length === 0) { %>\n          <div class=\"p-6 text-center\">\n            <i class=\"ph ph-bell-slash text-3xl text-text-muted mb-2\" aria-hidden=\"true\"></i>\n            <p class=\"text-sm text-text-muted\">\n              <%= typeof t === 'function' ? t('common.noNotifications') : 'No notifications' %>\n            </p>\n          </div>\n        <% } else { %>\n          <% notifications.slice(0, 5).forEach(function(notification) { %>\n            <a\n              href=\"<%= notification.href || '#' %>\"\n              class=\"flex items-start gap-3 px-4 py-3 hover:bg-surface-elevated transition-colors\"\n              role=\"menuitem\"\n            >\n              <div class=\"flex-shrink-0 w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center\">\n                <i class=\"ph ph-<%= notification.icon || 'bell' %> text-brand-primary\" aria-hidden=\"true\"></i>\n              </div>\n              <div class=\"flex-1 min-w-0\">\n                <p class=\"text-sm font-medium text-text-primary truncate\">\n                  <%= notification.title %>\n                </p>\n                <p class=\"text-xs text-text-muted truncate\">\n                  <%= notification.message %>\n                </p>\n                <p class=\"text-xs text-text-muted mt-1\">\n                  <%= notification.time %>\n                </p>\n              </div>\n              <% if (!notification.read) { %>\n                <span class=\"flex-shrink-0 w-2 h-2 bg-brand-primary rounded-full\" aria-hidden=\"true\"></span>\n              <% } %>\n            </a>\n          <% }); %>\n        <% } %>\n      </div>\n    </div>\n  </div>\n\n  <!-- Theme Toggle -->\n  <button\n    x-data=\"{ dark: document.documentElement.getAttribute('data-theme') === 'dark' }\"\n    @click=\"dark = !dark; document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light'); localStorage.setItem('theme', dark ? 'dark' : 'light')\"\n    type=\"button\"\n    class=\"btn btn-ghost btn-icon hidden sm:flex\"\n    :aria-label=\"dark ? '<%= typeof t === 'function' ? t('common.lightMode') : 'Switch to light mode' %>' : '<%= typeof t === 'function' ? t('common.darkMode') : 'Switch to dark mode' %>'\"\n  >\n    <template x-if=\"!dark\">\n      <i class=\"ph ph-moon text-xl\" aria-hidden=\"true\"></i>\n    </template>\n    <template x-if=\"dark\">\n      <i class=\"ph ph-sun text-xl\" aria-hidden=\"true\"></i>\n    </template>\n  </button>\n\n  <!-- User Menu -->\n  <div x-data=\"{ open: false }\" class=\"relative\">\n    <button\n      @click=\"open = !open\"\n      @click.outside=\"open = false\"\n      type=\"button\"\n      class=\"flex items-center gap-2 p-1 rounded-lg hover:bg-surface-elevated transition-colors\"\n      aria-haspopup=\"true\"\n      :aria-expanded=\"open\"\n    >\n      <!-- User Avatar -->\n      <div class=\"w-8 h-8 rounded-full bg-brand-primary flex items-center justify-center text-white font-semibold text-sm overflow-hidden\">\n        <% if (locals.user && user.avatar) { %>\n          <img src=\"<%= user.avatar %>\" alt=\"\" class=\"w-full h-full object-cover\">\n        <% } else if (locals.user) { %>\n          <%= user.firstName ? user.firstName.charAt(0).toUpperCase() : 'U' %>\n        <% } else { %>\n          U\n        <% } %>\n      </div>\n      <div class=\"hidden lg:block text-left\">\n        <p class=\"text-sm font-medium text-text-primary leading-tight\">\n          <%= locals.user ? (user.firstName + ' ' + (user.lastName || '')).trim() : 'User' %>\n        </p>\n        <p class=\"text-xs text-text-muted leading-tight\">\n          <%= locals.organization ? organization.name : 'Organization' %>\n        </p>\n      </div>\n      <i class=\"ph ph-caret-down text-xs text-text-muted hidden lg:block\" aria-hidden=\"true\"></i>\n    </button>\n\n    <!-- User Dropdown -->\n    <div\n      x-show=\"open\"\n      x-transition:enter=\"transition ease-out duration-100\"\n      x-transition:enter-start=\"opacity-0 scale-95\"\n      x-transition:enter-end=\"opacity-100 scale-100\"\n      x-transition:leave=\"transition ease-in duration-75\"\n      x-transition:leave-start=\"opacity-100 scale-100\"\n      x-transition:leave-end=\"opacity-0 scale-95\"\n      class=\"absolute right-0 mt-2 w-56 bg-surface-card rounded-lg shadow-lg border border-border-color overflow-hidden z-50\"\n      role=\"menu\"\n    >\n      <!-- User Info (Mobile) -->\n      <div class=\"lg:hidden px-4 py-3 border-b border-border-color\">\n        <p class=\"text-sm font-medium text-text-primary\">\n          <%= locals.user ? (user.firstName + ' ' + (user.lastName || '')).trim() : 'User' %>\n        </p>\n        <p class=\"text-xs text-text-muted truncate\">\n          <%= locals.user ? user.email : 'user@example.com' %>\n        </p>\n      </div>\n\n      <div class=\"py-1\">\n        <a href=\"/admin/profile\" class=\"flex items-center gap-3 px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n          <i class=\"ph ph-user text-text-muted\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('common.profile') : 'Profile' %>\n        </a>\n        <a href=\"/admin/settings\" class=\"flex items-center gap-3 px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n          <i class=\"ph ph-gear text-text-muted\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('common.settings') : 'Settings' %>\n        </a>\n        <a href=\"/admin/subscription\" class=\"flex items-center gap-3 px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n          <i class=\"ph ph-credit-card text-text-muted\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('common.subscription') : 'Subscription' %>\n        </a>\n      </div>\n\n      <div class=\"border-t border-border-color py-1\">\n        <!-- Theme Toggle (Mobile) -->\n        <button\n          x-data=\"{ dark: document.documentElement.getAttribute('data-theme') === 'dark' }\"\n          @click=\"dark = !dark; document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light'); localStorage.setItem('theme', dark ? 'dark' : 'light')\"\n          type=\"button\"\n          class=\"w-full flex items-center gap-3 px-4 py-2 text-sm hover:bg-surface-elevated sm:hidden\"\n          role=\"menuitem\"\n        >\n          <i x-show=\"!dark\" class=\"ph ph-moon text-text-muted\" aria-hidden=\"true\"></i>\n          <i x-show=\"dark\" class=\"ph ph-sun text-text-muted\" aria-hidden=\"true\"></i>\n          <span x-text=\"dark ? '<%= typeof t === 'function' ? t('common.lightMode') : 'Light mode' %>' : '<%= typeof t === 'function' ? t('common.darkMode') : 'Dark mode' %>'\"></span>\n        </button>\n\n        <a href=\"/admin/help\" class=\"flex items-center gap-3 px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n          <i class=\"ph ph-question text-text-muted\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('common.help') : 'Help & Support' %>\n        </a>\n      </div>\n\n      <div class=\"border-t border-border-color py-1\">\n        <form action=\"/api/v1/auth/logout\" method=\"POST\" class=\"block\">\n          <button\n            type=\"submit\"\n            class=\"w-full flex items-center gap-3 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20\"\n            role=\"menuitem\"\n          >\n            <i class=\"ph ph-sign-out\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('common.logout') : 'Logout' %>\n          </button>\n        </form>\n      </div>\n    </div>\n  </div>\n</header>\n",
