      },
      "worktree_state": {
        "content": "<%#\n  Sidebar Component\n\n  Variables:\n  - user: Current authenticated user\n  - organization: Current organization\n  - currentPath: Current URL path for active state\n  - navigation: Navigation configuration (optional override)\n%>\n<%\n  // Default navigation items if not provided\n  const defaultNavigation = [\n    {\n      section: typeof t === 'function' ? t('nav.main') : 'Main',\n      items: [\n        { label: typeof t === 'function' ? t('nav.dashboard') : 'Dashboard', href: '/admin', icon: 'house', permission: 'dashboard.view' },\n        { label: typeof t === 'function' ? t('nav.orders') : 'Orders', href: '/admin/orders', icon: 'receipt', permission: 'order.view', badge: locals.pendingOrders },\n        { label: typeof t === 'function' ? t('nav.menus') : 'Menus', href: '/admin/menus', icon: 'book-open', permission: 'menu.view' },\n        { label: typeof t === 'function' ? t('nav.qrCodes') : 'QR Codes', href: '/admin/qr-codes', icon: 'qr-code', permission: 'qr.view' },\n      ]\n    },\n    {\n      section: typeof t === 'function' ? t('nav.management') : 'Management',\n      items: [\n        { label: typeof t === 'function' ? t('nav.branches') : 'Branches', href: '/admin/branches', icon: 'buildings', permission: 'branch.view' },\n        { label: typeof t === 'function' ? t('nav.users') : 'Users', href: '/admin/users', icon: 'users', permission: 'user.view' },\n        { label: typeof t === 'function' ? t('nav.media') : 'Media Library', href: '/admin/media', icon: 'image-square', permission: 'media.view' },\n      ]\n    },\n    {\n      section: typeof t === 'function' ? t('nav.settings') : 'Settings',\n      items: [\n        { label: typeof t === 'function' ? t('nav.organization') : 'Organization', href: '/admin/organization', icon: 'building-office', permission: 'organization.update' },\n        { label: typeof t === 'function' ? t('nav.subscription') : 'Subscription', href: '/admin/subscription', icon: 'credit-card', permission: 'subscription.view' },\n        { label: typeof t === 'function' ? t('nav.integrations') : 'Integrations', href: '/admin/integrations', icon: 'plugs-connected', permission: 'integration.view' },\n      ]\n    },\n    {\n      section: typeof t === 'function' ? t('nav.system') : 'System',\n      items: [\n        { label: typeof t === 'function' ? t('nav.modules') : 'Modules', href: '/admin/modules', icon: 'puzzle-piece', permission: 'module.manage', adminOnly: true },\n        { label: typeof t === 'function' ? t('nav.analytics') : 'Analytics', href: '/admin/analytics', icon: 'chart-line-up', permission: 'analytics.view' },\n        { label: typeof t === 'function' ? t('nav.reports') : 'Reports', href: '/admin/reports', icon: 'file-chart', permission: 'report.view' },\n      ]\n    }\n  ];\n\n  const nav = locals.navigation || defaultNavigation;\n  const path = locals.currentPath || '';\n\n  // Check if path matches (handles exact and prefix matching)\n  function isActive(href) {\n    if (href === '/admin') return path === '/admin' || path === '/admin/';\n    return path.startsWith(href);\n  }\n%>\n\n<!-- Sidebar -->\n<aside\n  x-show=\"sidebarOpen\"\n  x-transition:enter=\"transition ease-out duration-300 lg:transition-none\"\n  x-transition:enter-start=\"-translate-x-full lg:translate-x-0\"\n  x-transition:enter-end=\"translate-x-0\"\n  x-transition:leave=\"transition ease-in duration-200 lg:transition-none\"\n  x-transition:leave-start=\"translate-x-0\"\n  x-transition:leave-end=\"-translate-x-full lg:translate-x-0\"\n  class=\"fixed inset-y-0 left-0 z-50 flex flex-col bg-surface-card border-r border-border-color transition-all duration-300 lg:z-auto\"\n  :class=\"{\n    'w-64': !sidebarCollapsed,\n    'w-20': sidebarCollapsed,\n    'lg:translate-x-0': true\n  }\"\n  role=\"navigation\"\n  aria-label=\"<%= typeof t === 'function' ? t('nav.mainNavigation') : 'Main navigation' %>\"\n>\n  <!-- Logo -->\n  <div class=\"h-16 flex items-center px-4 border-b border-border-color\">\n    <a href=\"/admin\" class=\"flex items-center gap-3 group\">\n      <div class=\"w-10 h-10 rounded-lg bg-brand-primary flex items-center justify-center flex-shrink-0\">\n        <span class=\"text-white font-bold text-xl\">E</span>\n      </div>\n      <span\n        x-show=\"!sidebarCollapsed\"\n        x-transition:enter=\"transition-opacity duration-200\"\n        x-transition:enter-start=\"opacity-0\"\n        x-transition:enter-end=\"opacity-100\"\n        class=\"text-xl font-bold text-text-primary group-hover:text-brand-primary transition-colors\"\n      >\n        E-Menum\n      </span>\n    </a>\n  </div>\n\n  <!-- Organization Selector (if multiple organizations) -->\n  <% if (locals.organization) { %>\n    <div class=\"p-3 border-b border-border-color\" x-show=\"!sidebarCollapsed\">\n      <div class=\"flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-elevated\">\n        <% if (organization.logo) { %>\n          <img src=\"<%= organization.logo %>\" alt=\"\" class=\"w-8 h-8 rounded object-cover\">\n        <% } else { %>\n          <div class=\"w-8 h-8 rounded bg-brand-primary/10 flex items-center justify-center\">\n            <i class=\"ph ph-storefront text-brand-primary\" aria-hidden=\"true\"></i>\n          </div>\n        <% } %>\n        <div class=\"flex-1 min-w-0\">\n          <p class=\"text-sm font-medium text-text-primary truncate\"><%= organization.name %></p>\n          <p class=\"text-xs text-text-muted truncate capitalize\"><%= organization.tier || 'Free' %></p>\n        </div>\n      </div>\n    </div>\n  <% } %>\n\n  <!-- Navigation -->\n  <nav class=\"flex-1 overflow-y-auto py-4\">\n    <% nav.forEach(function(group, groupIndex) { %>\n      <div class=\"<%= groupIndex > 0 ? 'mt-6' : '' %>\">\n        <!-- Section Header -->\n        <h3\n          x-show=\"!sidebarCollapsed\"\n          class=\"px-4 mb-2 text-xs font-semibold text-text-muted uppercase tracking-wider\"\n        >\n          <%= group.section %>\n        </h3>\n\n        <!-- Divider for collapsed state -->\n        <div x-show=\"sidebarCollapsed\" class=\"<%= groupIndex > 0 ? 'border-t border-border-color mx-3 mb-3' : '' %>\"></div>\n\n        <!-- Nav Items -->\n        <ul class=\"space-y-1 px-3\">\n          <% group.items.forEach(function(item) { %>\n            <li>\n              <a\n                href=\"<%= item.href %>\"\n                class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors group relative\n                  <%= isActive(item.href)\n                    ? 'bg-brand-primary text-white'\n                    : 'text-text-secondary hover:bg-surface-elevated hover:text-text-primary' %>\"\n                <% if (isActive(item.href)) { %>aria-current=\"page\"<% } %>\n              >\n                <!-- Icon -->\n                <i\n                  class=\"ph ph-<%= item.icon %> text-xl flex-shrink-0\n                    <%= isActive(item.href) ? '' : 'group-hover:text-brand-primary' %>\"\n                  aria-hidden=\"true\"\n                ></i>\n\n                <!-- Label -->\n                <span\n                  x-show=\"!sidebarCollapsed\"\n                  x-transition:enter=\"transition-opacity duration-200\"\n                  x-transition:enter-start=\"opacity-0\"\n                  x-transition:enter-end=\"opacity-100\"\n                  class=\"truncate\"\n                >\n                  <%= item.label %>\n                </span>\n\n                <!-- Badge -->\n                <% if (item.badge) { %>\n                  <span\n                    x-show=\"!sidebarCollapsed\"\n                    class=\"ml-auto px-2 py-0.5 text-xs font-medium rounded-full\n                      <%= isActive(item.href)\n                        ? 'bg-white/20 text-white'\n                        : 'bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400' %>\"\n                  >\n                    <%= item.badge %>\n                  </span>\n                <% } %>\n\n                <!-- Tooltip for collapsed state -->\n                <span\n                  x-show=\"sidebarCollapsed\"\n                  class=\"absolute left-full ml-2 px-2 py-1 text-xs font-medium text-white bg-gray-900 dark:bg-gray-700 rounded shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all whitespace-nowrap z-50\"\n                >\n                  <%= item.label %>\n                  <% if (item.badge) { %>\n                    <span class=\"ml-1 px-1.5 py-0.5 bg-red-500 rounded-full\"><%= item.badge %></span>\n                  <% } %>\n                </span>\n              </a>\n            </li>\n          <% }); %>\n        </ul>\n      </div>\n    <% }); %>\n  </nav>\n\n  <!-- Sidebar Footer -->\n  <div class=\"flex-shrink-0 border-t border-border-color p-3\">\n    <!-- Help Link -->\n    <a\n      href=\"/admin/help\"\n      class=\"flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:bg-surface-elevated hover:text-text-primary transition-colors group\"\n    >\n      <i class=\"ph ph-question text-xl group-hover:text-brand-primary\" aria-hidden=\"true\"></i>\n      <span x-show=\"!sidebarCollapsed\">\n        <%= typeof t === 'function' ? t('nav.helpSupport') : 'Help & Support' %>\n      </span>\n    </a>\n\n    <!-- Collapse Toggle (Desktop) -->\n    <button\n      @click=\"sidebarCollapsed = !sidebarCollapsed; localStorage.setItem('sidebarCollapsed', sidebarCollapsed)\"\n      type=\"button\"\n      class=\"hidden lg:flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium text-text-secondary hover:bg-surface-elevated hover:text-text-primary transition-colors group\"\n      :aria-label=\"sidebarCollapsed ? '<%= typeof t === 'function' ? t('nav.expandSidebar') : 'Expand sidebar' %>' : '<%= typeof t === 'function' ? t('nav.collapseSidebar') : 'Collapse sidebar' %>'\"\n    >\n      <i\n        class=\"ph text-xl group-hover:text-brand-primary\"\n        :class=\"sidebarCollapsed ? 'ph-caret-double-right' : 'ph-caret-double-left'\"\n        aria-hidden=\"true\"\n      ></i>\n      <span x-show=\"!sidebarCollapsed\">\n        <%= typeof t === 'function' ? t('nav.collapse') : 'Collapse' %>\n      </span>\n    </button>\n  </div>\n</aside>\n\n<!-- Close button for mobile (outside sidebar for better UX) -->\n<button\n  x-show=\"sidebarOpen && window.innerWidth < 1024\"\n  @click=\"sidebarOpen = false\"\n  type=\"button\"\n  class=\"fixed top-4 right-4 z-50 btn btn-ghost btn-icon bg-surface-card shadow-lg lg:hidden\"\n  aria-label=\"<%= typeof t === 'function' ? t('common.closeSidebar') : 'Close sidebar' %>\"\n>\n  <i class=\"ph ph-x text-xl\" aria-hidden=\"true\"></i>\n</button>\n",
        "last_modified": "2026-02-01T09:10:53.777305"
      },
