      "branch_point": {
        "commit_hash": "e2c14236dedadbadc7b19d123890e3f98e7316c0",
        "content": "",
        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Admin Dashboard View\n\n  Variables:\n  - stats: { ordersToday, revenue, menuCount, pendingOrders, customers }\n  - recentOrders: Array of recent order objects\n  - chartData: Revenue chart data\n  - quickActions: Array of quick action items\n%>\n\n<!-- Stats Cards -->\n<div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-6 md:mb-8\">\n  <!-- Orders Today -->\n  <div class=\"card p-4 md:p-6\">\n    <div class=\"flex items-center justify-between\">\n      <div>\n        <p class=\"text-sm font-medium text-text-muted\">\n          <%= typeof t === 'function' ? t('dashboard.ordersToday') : 'Orders Today' %>\n        </p>\n        <p class=\"mt-2 text-2xl md:text-3xl font-bold text-text-primary\">\n          <%= locals.stats ? stats.ordersToday : 0 %>\n        </p>\n        <% if (locals.stats && stats.ordersTrend) { %>\n          <p class=\"mt-1 text-xs <%= stats.ordersTrend >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>\">\n            <i class=\"ph ph-<%= stats.ordersTrend >= 0 ? 'trend-up' : 'trend-down' %>\" aria-hidden=\"true\"></i>\n            <%= stats.ordersTrend >= 0 ? '+' : '' %><%= stats.ordersTrend %>%\n            <%= typeof t === 'function' ? t('dashboard.vsYesterday') : 'vs yesterday' %>\n          </p>\n        <% } %>\n      </div>\n      <div class=\"w-12 h-12 rounded-lg bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center\">\n        <i class=\"ph ph-shopping-bag text-2xl text-blue-600 dark:text-blue-400\" aria-hidden=\"true\"></i>\n      </div>\n    </div>\n  </div>\n\n  <!-- Today's Revenue -->\n  <div class=\"card p-4 md:p-6\">\n    <div class=\"flex items-center justify-between\">\n      <div>\n        <p class=\"text-sm font-medium text-text-muted\">\n          <%= typeof t === 'function' ? t('dashboard.todaysRevenue') : \"Today's Revenue\" %>\n        </p>\n        <p class=\"mt-2 text-2xl md:text-3xl font-bold text-text-primary\">\n          <%= locals.stats ? stats.revenue.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) : '\u20ba0' %>\n        </p>\n        <% if (locals.stats && stats.revenueTrend) { %>\n          <p class=\"mt-1 text-xs <%= stats.revenueTrend >= 0 ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' %>\">\n            <i class=\"ph ph-<%= stats.revenueTrend >= 0 ? 'trend-up' : 'trend-down' %>\" aria-hidden=\"true\"></i>\n            <%= stats.revenueTrend >= 0 ? '+' : '' %><%= stats.revenueTrend %>%\n            <%= typeof t === 'function' ? t('dashboard.vsYesterday') : 'vs yesterday' %>\n          </p>\n        <% } %>\n      </div>\n      <div class=\"w-12 h-12 rounded-lg bg-green-100 dark:bg-green-900/30 flex items-center justify-center\">\n        <i class=\"ph ph-currency-circle-dollar text-2xl text-green-600 dark:text-green-400\" aria-hidden=\"true\"></i>\n      </div>\n    </div>\n  </div>\n\n  <!-- Active Menus -->\n  <div class=\"card p-4 md:p-6\">\n    <div class=\"flex items-center justify-between\">\n      <div>\n        <p class=\"text-sm font-medium text-text-muted\">\n          <%= typeof t === 'function' ? t('dashboard.activeMenus') : 'Active Menus' %>\n        </p>\n        <p class=\"mt-2 text-2xl md:text-3xl font-bold text-text-primary\">\n          <%= locals.stats ? stats.menuCount : 0 %>\n        </p>\n        <p class=\"mt-1 text-xs text-text-muted\">\n          <%= locals.stats ? stats.productCount : 0 %>\n          <%= typeof t === 'function' ? t('dashboard.products') : 'products' %>\n        </p>\n      </div>\n      <div class=\"w-12 h-12 rounded-lg bg-purple-100 dark:bg-purple-900/30 flex items-center justify-center\">\n        <i class=\"ph ph-book-open text-2xl text-purple-600 dark:text-purple-400\" aria-hidden=\"true\"></i>\n      </div>\n    </div>\n  </div>\n\n  <!-- Pending Orders -->\n  <div class=\"card p-4 md:p-6\">\n    <div class=\"flex items-center justify-between\">\n      <div>\n        <p class=\"text-sm font-medium text-text-muted\">\n          <%= typeof t === 'function' ? t('dashboard.pendingOrders') : 'Pending Orders' %>\n        </p>\n        <p class=\"mt-2 text-2xl md:text-3xl font-bold <%= (locals.stats && stats.pendingOrders > 0) ? 'text-orange-600 dark:text-orange-400' : 'text-text-primary' %>\">\n          <%= locals.stats ? stats.pendingOrders : 0 %>\n        </p>\n        <% if (locals.stats && stats.pendingOrders > 0) { %>\n          <a href=\"/admin/orders?status=pending\" class=\"mt-1 text-xs text-brand-primary hover:underline\">\n            <%= typeof t === 'function' ? t('dashboard.viewPending') : 'View pending' %>\n            <i class=\"ph ph-arrow-right\" aria-hidden=\"true\"></i>\n          </a>\n        <% } else { %>\n          <p class=\"mt-1 text-xs text-green-600 dark:text-green-400\">\n            <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('dashboard.allCaughtUp') : 'All caught up!' %>\n          </p>\n        <% } %>\n      </div>\n      <div class=\"w-12 h-12 rounded-lg bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center\">\n        <i class=\"ph ph-clock text-2xl text-orange-600 dark:text-orange-400\" aria-hidden=\"true\"></i>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- Main Content Grid -->\n<div class=\"grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6\">\n  <!-- Revenue Chart (2 columns) -->\n  <div class=\"lg:col-span-2 card p-4 md:p-6\">\n    <div class=\"flex items-center justify-between mb-4\">\n      <h2 class=\"text-lg font-semibold text-text-primary\">\n        <%= typeof t === 'function' ? t('dashboard.revenueOverview') : 'Revenue Overview' %>\n      </h2>\n      <div x-data=\"{ period: 'week' }\" class=\"flex items-center gap-2\">\n        <button\n          @click=\"period = 'week'\"\n          :class=\"period === 'week' ? 'btn-primary' : 'btn-ghost'\"\n          class=\"btn btn-sm\"\n        >\n          <%= typeof t === 'function' ? t('dashboard.week') : 'Week' %>\n        </button>\n        <button\n          @click=\"period = 'month'\"\n          :class=\"period === 'month' ? 'btn-primary' : 'btn-ghost'\"\n          class=\"btn btn-sm\"\n        >\n          <%= typeof t === 'function' ? t('dashboard.month') : 'Month' %>\n        </button>\n      </div>\n    </div>\n\n    <!-- Chart Container -->\n    <div class=\"h-64 md:h-80 flex items-center justify-center bg-surface-elevated rounded-lg\">\n      <% if (locals.chartData && chartData.length > 0) { %>\n        <canvas id=\"revenueChart\" class=\"w-full h-full\"></canvas>\n      <% } else { %>\n        <div class=\"text-center p-8\">\n          <i class=\"ph ph-chart-line text-4xl text-text-muted mb-2\" aria-hidden=\"true\"></i>\n          <p class=\"text-sm text-text-muted\">\n            <%= typeof t === 'function' ? t('dashboard.noDataYet') : 'No data yet' %>\n          </p>\n          <p class=\"text-xs text-text-muted mt-1\">\n            <%= typeof t === 'function' ? t('dashboard.chartAppears') : 'Chart will appear when orders come in' %>\n          </p>\n        </div>\n      <% } %>\n    </div>\n  </div>\n\n  <!-- Quick Actions -->\n  <div class=\"card p-4 md:p-6\">\n    <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n      <%= typeof t === 'function' ? t('dashboard.quickActions') : 'Quick Actions' %>\n    </h2>\n\n    <div class=\"space-y-3\">\n      <a\n        href=\"/admin/menus/create\"\n        class=\"flex items-center gap-3 p-3 rounded-lg bg-surface-elevated hover:bg-brand-primary hover:text-white group transition-colors\"\n      >\n        <div class=\"w-10 h-10 rounded-lg bg-brand-primary/10 group-hover:bg-white/20 flex items-center justify-center\">\n          <i class=\"ph ph-plus text-xl text-brand-primary group-hover:text-white\" aria-hidden=\"true\"></i>\n        </div>\n        <div>\n          <p class=\"font-medium\"><%= typeof t === 'function' ? t('dashboard.createMenu') : 'Create Menu' %></p>\n          <p class=\"text-xs text-text-muted group-hover:text-white/70\">\n            <%= typeof t === 'function' ? t('dashboard.addNewMenu') : 'Add a new digital menu' %>\n          </p>\n        </div>\n      </a>\n\n      <a\n        href=\"/admin/qr-codes/generate\"\n        class=\"flex items-center gap-3 p-3 rounded-lg bg-surface-elevated hover:bg-brand-primary hover:text-white group transition-colors\"\n      >\n        <div class=\"w-10 h-10 rounded-lg bg-purple-500/10 group-hover:bg-white/20 flex items-center justify-center\">\n          <i class=\"ph ph-qr-code text-xl text-purple-500 group-hover:text-white\" aria-hidden=\"true\"></i>\n        </div>\n        <div>\n          <p class=\"font-medium\"><%= typeof t === 'function' ? t('dashboard.generateQR') : 'Generate QR Code' %></p>\n          <p class=\"text-xs text-text-muted group-hover:text-white/70\">\n            <%= typeof t === 'function' ? t('dashboard.qrForTables') : 'QR codes for tables' %>\n          </p>\n        </div>\n      </a>\n\n      <a\n        href=\"/admin/users/invite\"\n        class=\"flex items-center gap-3 p-3 rounded-lg bg-surface-elevated hover:bg-brand-primary hover:text-white group transition-colors\"\n      >\n        <div class=\"w-10 h-10 rounded-lg bg-green-500/10 group-hover:bg-white/20 flex items-center justify-center\">\n          <i class=\"ph ph-user-plus text-xl text-green-500 group-hover:text-white\" aria-hidden=\"true\"></i>\n        </div>\n        <div>\n          <p class=\"font-medium\"><%= typeof t === 'function' ? t('dashboard.inviteTeam') : 'Invite Team Member' %></p>\n          <p class=\"text-xs text-text-muted group-hover:text-white/70\">\n            <%= typeof t === 'function' ? t('dashboard.addStaff') : 'Add staff to your team' %>\n          </p>\n        </div>\n      </a>\n\n      <a\n        href=\"/admin/reports\"\n        class=\"flex items-center gap-3 p-3 rounded-lg bg-surface-elevated hover:bg-brand-primary hover:text-white group transition-colors\"\n      >\n        <div class=\"w-10 h-10 rounded-lg bg-blue-500/10 group-hover:bg-white/20 flex items-center justify-center\">\n          <i class=\"ph ph-file-chart text-xl text-blue-500 group-hover:text-white\" aria-hidden=\"true\"></i>\n        </div>\n        <div>\n          <p class=\"font-medium\"><%= typeof t === 'function' ? t('dashboard.viewReports') : 'View Reports' %></p>\n          <p class=\"text-xs text-text-muted group-hover:text-white/70\">\n            <%= typeof t === 'function' ? t('dashboard.analyticsInsights') : 'Analytics & insights' %>\n          </p>\n        </div>\n      </a>\n    </div>\n  </div>\n</div>\n\n<!-- Recent Orders Section -->\n<div class=\"mt-6 md:mt-8 card\">\n  <div class=\"flex items-center justify-between p-4 md:p-6 border-b border-border-color\">\n    <h2 class=\"text-lg font-semibold text-text-primary\">\n      <%= typeof t === 'function' ? t('dashboard.recentOrders') : 'Recent Orders' %>\n    </h2>\n    <a href=\"/admin/orders\" class=\"btn btn-ghost btn-sm\">\n      <%= typeof t === 'function' ? t('common.viewAll') : 'View All' %>\n      <i class=\"ph ph-arrow-right ml-1\" aria-hidden=\"true\"></i>\n    </a>\n  </div>\n\n  <% if (!locals.recentOrders || recentOrders.length === 0) { %>\n    <!-- Empty State -->\n    <div class=\"p-8 text-center\">\n      <div class=\"w-16 h-16 mx-auto rounded-full bg-surface-elevated flex items-center justify-center mb-4\">\n        <i class=\"ph ph-receipt text-3xl text-text-muted\" aria-hidden=\"true\"></i>\n      </div>\n      <h3 class=\"text-lg font-medium text-text-primary mb-1\">\n        <%= typeof t === 'function' ? t('dashboard.noOrdersYet') : 'No orders yet' %>\n      </h3>\n      <p class=\"text-sm text-text-muted mb-4\">\n        <%= typeof t === 'function' ? t('dashboard.ordersAppear') : 'Orders will appear here when customers place them' %>\n      </p>\n      <a href=\"/admin/menus\" class=\"btn btn-primary\">\n        <i class=\"ph ph-book-open mr-2\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('dashboard.setupMenu') : 'Setup Your Menu' %>\n      </a>\n    </div>\n  <% } else { %>\n    <!-- Orders Table -->\n    <div class=\"overflow-x-auto\">\n      <table class=\"w-full\">\n        <thead>\n          <tr class=\"bg-surface-elevated\">\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.orderNumber') : 'Order #' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden sm:table-cell\">\n              <%= typeof t === 'function' ? t('orders.customer') : 'Customer' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.status') : 'Status' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden md:table-cell\">\n              <%= typeof t === 'function' ? t('orders.table') : 'Table' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-right text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.total') : 'Total' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-right text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <span class=\"sr-only\"><%= typeof t === 'function' ? t('common.actions') : 'Actions' %></span>\n            </th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-border-color\">\n          <% recentOrders.forEach(function(order) { %>\n            <tr class=\"hover:bg-surface-elevated transition-colors\">\n              <td class=\"px-4 md:px-6 py-4\">\n                <a href=\"/admin/orders/<%= order.id %>\" class=\"font-medium text-brand-primary hover:underline\">\n                  #<%= order.orderNumber %>\n                </a>\n                <p class=\"text-xs text-text-muted sm:hidden mt-1\">\n                  <%= order.customerName || (typeof t === 'function' ? t('orders.guest') : 'Guest') %>\n                </p>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden sm:table-cell\">\n                <p class=\"text-sm text-text-primary\">\n                  <%= order.customerName || (typeof t === 'function' ? t('orders.guest') : 'Guest') %>\n                </p>\n                <% if (order.customerPhone) { %>\n                  <p class=\"text-xs text-text-muted\"><%= order.customerPhone %></p>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4\">\n                <%\n                  const statusColors = {\n                    pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',\n                    confirmed: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',\n                    preparing: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',\n                    ready: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',\n                    delivered: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400',\n                    cancelled: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400'\n                  };\n                  const statusColor = statusColors[order.status] || statusColors.pending;\n                %>\n                <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= statusColor %>\">\n                  <%= typeof t === 'function' ? t('orders.status.' + order.status) : order.status %>\n                </span>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden md:table-cell\">\n                <% if (order.table) { %>\n                  <span class=\"inline-flex items-center gap-1 text-sm text-text-secondary\">\n                    <i class=\"ph ph-armchair\" aria-hidden=\"true\"></i>\n                    <%= order.table.name || order.table.number %>\n                  </span>\n                <% } else { %>\n                  <span class=\"text-sm text-text-muted\">\n                    <%= typeof t === 'function' ? t('orders.takeaway') : 'Takeaway' %>\n                  </span>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 text-right\">\n                <p class=\"text-sm font-medium text-text-primary\">\n                  <%= order.total.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %>\n                </p>\n                <p class=\"text-xs text-text-muted\">\n                  <%= order.itemCount %> <%= typeof t === 'function' ? t('orders.items') : 'items' %>\n                </p>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 text-right\">\n                <a\n                  href=\"/admin/orders/<%= order.id %>\"\n                  class=\"btn btn-ghost btn-sm btn-icon\"\n                  aria-label=\"<%= typeof t === 'function' ? t('common.view') : 'View' %>\"\n                >\n                  <i class=\"ph ph-eye\" aria-hidden=\"true\"></i>\n                </a>\n              </td>\n            </tr>\n          <% }); %>\n        </tbody>\n      </table>\n    </div>\n  <% } %>\n</div>\n\n<% if (locals.chartData && chartData.length > 0) { %>\n<!-- Chart.js Script -->\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js\"></script>\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    const ctx = document.getElementById('revenueChart');\n    if (ctx) {\n      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';\n      new Chart(ctx, {\n        type: 'line',\n        data: {\n          labels: <%- JSON.stringify(chartData.map(d => d.label)) %>,\n          datasets: [{\n            label: '<%= typeof t === 'function' ? t('dashboard.revenue') : 'Revenue' %>',\n            data: <%- JSON.stringify(chartData.map(d => d.value)) %>,\n            borderColor: 'rgb(59, 130, 246)',\n            backgroundColor: 'rgba(59, 130, 246, 0.1)',\n            fill: true,\n            tension: 0.4\n          }]\n        },\n        options: {\n          responsive: true,\n          maintainAspectRatio: false,\n          plugins: {\n            legend: {\n              display: false\n            }\n          },\n          scales: {\n            y: {\n              beginAtZero: true,\n              grid: {\n                color: isDark ? 'rgba(255,255,255,0.1)' : 'rgba(0,0,0,0.1)'\n              },\n              ticks: {\n                color: isDark ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.7)'\n              }\n            },\n            x: {\n              grid: {\n                display: false\n              },\n              ticks: {\n                color: isDark ? 'rgba(255,255,255,0.7)' : 'rgba(0,0,0,0.7)'\n              }\n            }\n          }\n        }\n      });\n    }\n  });\n</script>\n<% } %>\n",
        "last_modified": "2026-02-01T09:10:53.769167"
      },
