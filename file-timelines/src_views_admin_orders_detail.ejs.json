{
  "file_path": "src/views/admin/orders/detail.ejs",
  "main_branch_history": [],
  "task_views": {
    "001-create": {
      "task_id": "001-create",
      "branch_point": {
        "commit_hash": "e2c14236dedadbadc7b19d123890e3f98e7316c0",
        "content": "",
        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Order Detail View\n\n  Variables:\n  - order: The order object with items, customer, etc.\n  - statusHistory: Array of status change records\n%>\n\n<div class=\"max-w-4xl mx-auto\">\n  <!-- Order Header -->\n  <div class=\"card p-6 mb-6\">\n    <div class=\"flex flex-col md:flex-row md:items-center md:justify-between gap-4\">\n      <div>\n        <div class=\"flex items-center gap-3\">\n          <h1 class=\"text-2xl font-bold text-text-primary\">\n            <%= typeof t === 'function' ? t('orders.orderNumber') : 'Order' %> #<%= order.orderNumber %>\n          </h1>\n          <%\n            const statusColors = {\n              pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',\n              confirmed: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',\n              preparing: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',\n              ready: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',\n              delivered: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400',\n              cancelled: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400'\n            };\n            const statusColor = statusColors[order.status] || statusColors.pending;\n          %>\n          <span class=\"inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= statusColor %>\">\n            <%= typeof t === 'function' ? t('orders.status.' + order.status) : order.status %>\n          </span>\n        </div>\n        <p class=\"text-sm text-text-muted mt-1\">\n          <%= typeof t === 'function' ? t('orders.placedOn') : 'Placed on' %>\n          <%= new Date(order.createdAt).toLocaleString(locals.lang || 'tr-TR') %>\n        </p>\n      </div>\n\n      <!-- Quick Actions -->\n      <div class=\"flex flex-wrap gap-2\">\n        <a\n          href=\"/admin/orders/<%= order.id %>/print\"\n          target=\"_blank\"\n          class=\"btn btn-ghost\"\n        >\n          <i class=\"ph ph-printer mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('orders.print') : 'Print' %>\n        </a>\n\n        <% if (order.status === 'pending') { %>\n          <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\" class=\"inline\">\n            <input type=\"hidden\" name=\"status\" value=\"confirmed\">\n            <button type=\"submit\" class=\"btn btn-primary\">\n              <i class=\"ph ph-check mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.confirm') : 'Confirm Order' %>\n            </button>\n          </form>\n        <% } else if (order.status === 'confirmed') { %>\n          <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\" class=\"inline\">\n            <input type=\"hidden\" name=\"status\" value=\"preparing\">\n            <button type=\"submit\" class=\"btn btn-primary\">\n              <i class=\"ph ph-cooking-pot mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.startPreparing') : 'Start Preparing' %>\n            </button>\n          </form>\n        <% } else if (order.status === 'preparing') { %>\n          <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\" class=\"inline\">\n            <input type=\"hidden\" name=\"status\" value=\"ready\">\n            <button type=\"submit\" class=\"btn btn-primary\">\n              <i class=\"ph ph-bell mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.markReady') : 'Mark Ready' %>\n            </button>\n          </form>\n        <% } else if (order.status === 'ready') { %>\n          <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\" class=\"inline\">\n            <input type=\"hidden\" name=\"status\" value=\"delivered\">\n            <button type=\"submit\" class=\"btn btn-primary\">\n              <i class=\"ph ph-check-circle mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.markDelivered') : 'Mark Delivered' %>\n            </button>\n          </form>\n        <% } %>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\n    <!-- Main Content (Order Items) -->\n    <div class=\"lg:col-span-2 space-y-6\">\n      <!-- Order Items -->\n      <div class=\"card\">\n        <div class=\"px-6 py-4 border-b border-border-color\">\n          <h2 class=\"font-semibold text-text-primary\">\n            <%= typeof t === 'function' ? t('orders.orderItems') : 'Order Items' %>\n            <span class=\"text-text-muted font-normal\">(<%= order.items.length %>)</span>\n          </h2>\n        </div>\n\n        <div class=\"divide-y divide-border-color\">\n          <% order.items.forEach(function(item) { %>\n            <div class=\"p-4 md:p-6 flex gap-4\">\n              <!-- Item Image -->\n              <div class=\"w-16 h-16 md:w-20 md:h-20 rounded-lg bg-surface-elevated flex-shrink-0 overflow-hidden\">\n                <% if (item.product && item.product.image) { %>\n                  <img\n                    src=\"<%= item.product.image %>\"\n                    alt=\"<%= item.productName %>\"\n                    class=\"w-full h-full object-cover\"\n                  >\n                <% } else { %>\n                  <div class=\"w-full h-full flex items-center justify-center\">\n                    <i class=\"ph ph-bowl-food text-2xl text-text-muted\" aria-hidden=\"true\"></i>\n                  </div>\n                <% } %>\n              </div>\n\n              <!-- Item Details -->\n              <div class=\"flex-1 min-w-0\">\n                <div class=\"flex items-start justify-between gap-2\">\n                  <div>\n                    <h3 class=\"font-medium text-text-primary\">\n                      <%= item.productName %>\n                    </h3>\n                    <% if (item.variant) { %>\n                      <p class=\"text-sm text-text-muted\">\n                        <%= item.variant.name %>\n                      </p>\n                    <% } %>\n                  </div>\n                  <span class=\"text-sm font-medium text-text-primary whitespace-nowrap\">\n                    <%= item.totalPrice.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %>\n                  </span>\n                </div>\n\n                <!-- Modifiers -->\n                <% if (item.modifiers && item.modifiers.length > 0) { %>\n                  <div class=\"mt-2 flex flex-wrap gap-1\">\n                    <% item.modifiers.forEach(function(modifier) { %>\n                      <span class=\"inline-flex items-center px-2 py-0.5 rounded text-xs bg-surface-elevated text-text-secondary\">\n                        + <%= modifier.name %>\n                        <% if (modifier.price > 0) { %>\n                          (<%= modifier.price.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %>)\n                        <% } %>\n                      </span>\n                    <% }); %>\n                  </div>\n                <% } %>\n\n                <!-- Special Instructions -->\n                <% if (item.notes) { %>\n                  <p class=\"mt-2 text-sm text-yellow-600 dark:text-yellow-400 bg-yellow-50 dark:bg-yellow-900/20 px-2 py-1 rounded\">\n                    <i class=\"ph ph-note mr-1\" aria-hidden=\"true\"></i>\n                    <%= item.notes %>\n                  </p>\n                <% } %>\n\n                <!-- Quantity and Unit Price -->\n                <div class=\"mt-2 flex items-center gap-4 text-sm text-text-muted\">\n                  <span>\n                    <%= typeof t === 'function' ? t('orders.quantity') : 'Qty' %>: <strong><%= item.quantity %></strong>\n                  </span>\n                  <span>\n                    @ <%= item.unitPrice.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %>\n                  </span>\n                </div>\n              </div>\n            </div>\n          <% }); %>\n        </div>\n\n        <!-- Order Totals -->\n        <div class=\"px-6 py-4 bg-surface-elevated border-t border-border-color\">\n          <div class=\"space-y-2\">\n            <div class=\"flex justify-between text-sm\">\n              <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.subtotal') : 'Subtotal' %></span>\n              <span class=\"text-text-primary\"><%= order.subtotal.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %></span>\n            </div>\n            <% if (order.discount > 0) { %>\n              <div class=\"flex justify-between text-sm\">\n                <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.discount') : 'Discount' %></span>\n                <span class=\"text-green-600 dark:text-green-400\">-<%= order.discount.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %></span>\n              </div>\n            <% } %>\n            <% if (order.tax > 0) { %>\n              <div class=\"flex justify-between text-sm\">\n                <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.tax') : 'Tax' %></span>\n                <span class=\"text-text-primary\"><%= order.tax.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %></span>\n              </div>\n            <% } %>\n            <% if (order.serviceFee > 0) { %>\n              <div class=\"flex justify-between text-sm\">\n                <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.serviceFee') : 'Service Fee' %></span>\n                <span class=\"text-text-primary\"><%= order.serviceFee.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %></span>\n              </div>\n            <% } %>\n            <div class=\"flex justify-between text-lg font-semibold pt-2 border-t border-border-color\">\n              <span class=\"text-text-primary\"><%= typeof t === 'function' ? t('orders.total') : 'Total' %></span>\n              <span class=\"text-text-primary\"><%= order.total.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %></span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Order Notes -->\n      <% if (order.notes) { %>\n        <div class=\"card p-6\">\n          <h2 class=\"font-semibold text-text-primary mb-3\">\n            <i class=\"ph ph-note mr-2\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('orders.orderNotes') : 'Order Notes' %>\n          </h2>\n          <p class=\"text-text-secondary bg-yellow-50 dark:bg-yellow-900/20 p-4 rounded-lg\">\n            <%= order.notes %>\n          </p>\n        </div>\n      <% } %>\n\n      <!-- Status History -->\n      <% if (locals.statusHistory && statusHistory.length > 0) { %>\n        <div class=\"card p-6\">\n          <h2 class=\"font-semibold text-text-primary mb-4\">\n            <%= typeof t === 'function' ? t('orders.statusHistory') : 'Status History' %>\n          </h2>\n\n          <div class=\"relative\">\n            <div class=\"absolute left-3 top-0 bottom-0 w-0.5 bg-border-color\"></div>\n\n            <div class=\"space-y-4\">\n              <% statusHistory.forEach(function(entry, index) { %>\n                <div class=\"relative flex gap-4 pl-8\">\n                  <!-- Status Dot -->\n                  <div class=\"absolute left-0 w-6 h-6 rounded-full bg-surface-card border-2 border-brand-primary flex items-center justify-center\">\n                    <div class=\"w-2 h-2 rounded-full bg-brand-primary\"></div>\n                  </div>\n\n                  <div class=\"flex-1 pb-4\">\n                    <p class=\"font-medium text-text-primary\">\n                      <%= typeof t === 'function' ? t('orders.status.' + entry.status) : entry.status %>\n                    </p>\n                    <p class=\"text-sm text-text-muted\">\n                      <%= new Date(entry.createdAt).toLocaleString(locals.lang || 'tr-TR') %>\n                    </p>\n                    <% if (entry.notes) { %>\n                      <p class=\"text-sm text-text-secondary mt-1\"><%= entry.notes %></p>\n                    <% } %>\n                    <% if (entry.user) { %>\n                      <p class=\"text-xs text-text-muted mt-1\">\n                        <%= typeof t === 'function' ? t('orders.by') : 'by' %> <%= entry.user.firstName %> <%= entry.user.lastName %>\n                      </p>\n                    <% } %>\n                  </div>\n                </div>\n              <% }); %>\n            </div>\n          </div>\n        </div>\n      <% } %>\n    </div>\n\n    <!-- Sidebar -->\n    <div class=\"space-y-6\">\n      <!-- Customer Information -->\n      <div class=\"card p-6\">\n        <h2 class=\"font-semibold text-text-primary mb-4\">\n          <i class=\"ph ph-user mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('orders.customer') : 'Customer' %>\n        </h2>\n\n        <div class=\"space-y-3\">\n          <div>\n            <p class=\"text-sm text-text-muted\">\n              <%= typeof t === 'function' ? t('orders.name') : 'Name' %>\n            </p>\n            <p class=\"font-medium text-text-primary\">\n              <%= order.customerName || (typeof t === 'function' ? t('orders.guest') : 'Guest') %>\n            </p>\n          </div>\n\n          <% if (order.customerPhone) { %>\n            <div>\n              <p class=\"text-sm text-text-muted\">\n                <%= typeof t === 'function' ? t('orders.phone') : 'Phone' %>\n              </p>\n              <a href=\"tel:<%= order.customerPhone %>\" class=\"font-medium text-brand-primary hover:underline\">\n                <%= order.customerPhone %>\n              </a>\n            </div>\n          <% } %>\n\n          <% if (order.customerEmail) { %>\n            <div>\n              <p class=\"text-sm text-text-muted\">\n                <%= typeof t === 'function' ? t('orders.email') : 'Email' %>\n              </p>\n              <a href=\"mailto:<%= order.customerEmail %>\" class=\"font-medium text-brand-primary hover:underline truncate block\">\n                <%= order.customerEmail %>\n              </a>\n            </div>\n          <% } %>\n        </div>\n      </div>\n\n      <!-- Order Type -->\n      <div class=\"card p-6\">\n        <h2 class=\"font-semibold text-text-primary mb-4\">\n          <%\n            const typeIcons = {\n              dine_in: 'fork-knife',\n              takeaway: 'bag',\n              delivery: 'moped'\n            };\n            const typeIcon = typeIcons[order.type] || 'receipt';\n          %>\n          <i class=\"ph ph-<%= typeIcon %> mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('orders.orderType') : 'Order Type' %>\n        </h2>\n\n        <p class=\"text-lg font-medium text-text-primary capitalize\">\n          <%= typeof t === 'function' ? t('orders.type.' + order.type) : order.type.replace('_', ' ') %>\n        </p>\n\n        <% if (order.type === 'dine_in' && order.table) { %>\n          <div class=\"mt-3 p-3 bg-surface-elevated rounded-lg\">\n            <p class=\"text-sm text-text-muted\">\n              <%= typeof t === 'function' ? t('orders.table') : 'Table' %>\n            </p>\n            <p class=\"font-medium text-text-primary\">\n              <%= order.table.name || order.table.number %>\n            </p>\n            <% if (order.table.location) { %>\n              <p class=\"text-xs text-text-muted\"><%= order.table.location %></p>\n            <% } %>\n          </div>\n        <% } %>\n\n        <% if (order.type === 'delivery' && order.deliveryAddress) { %>\n          <div class=\"mt-3 p-3 bg-surface-elevated rounded-lg\">\n            <p class=\"text-sm text-text-muted\">\n              <%= typeof t === 'function' ? t('orders.deliveryAddress') : 'Delivery Address' %>\n            </p>\n            <p class=\"font-medium text-text-primary\">\n              <%= order.deliveryAddress %>\n            </p>\n          </div>\n        <% } %>\n\n        <% if (order.type === 'takeaway' && order.pickupTime) { %>\n          <div class=\"mt-3 p-3 bg-surface-elevated rounded-lg\">\n            <p class=\"text-sm text-text-muted\">\n              <%= typeof t === 'function' ? t('orders.pickupTime') : 'Pickup Time' %>\n            </p>\n            <p class=\"font-medium text-text-primary\">\n              <%= new Date(order.pickupTime).toLocaleTimeString(locals.lang || 'tr-TR', { hour: '2-digit', minute: '2-digit' }) %>\n            </p>\n          </div>\n        <% } %>\n      </div>\n\n      <!-- Payment Information -->\n      <div class=\"card p-6\">\n        <h2 class=\"font-semibold text-text-primary mb-4\">\n          <i class=\"ph ph-credit-card mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('orders.payment') : 'Payment' %>\n        </h2>\n\n        <div class=\"space-y-3\">\n          <div class=\"flex justify-between\">\n            <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.method') : 'Method' %></span>\n            <span class=\"font-medium text-text-primary\">\n              <%= typeof t === 'function' ? t('orders.paymentMethod.' + (order.paymentMethod || 'cash')) : (order.paymentMethod || 'Cash') %>\n            </span>\n          </div>\n          <div class=\"flex justify-between\">\n            <span class=\"text-text-muted\"><%= typeof t === 'function' ? t('orders.status') : 'Status' %></span>\n            <%\n              const paymentStatusColors = {\n                pending: 'text-yellow-600 dark:text-yellow-400',\n                paid: 'text-green-600 dark:text-green-400',\n                failed: 'text-red-600 dark:text-red-400',\n                refunded: 'text-blue-600 dark:text-blue-400'\n              };\n              const paymentStatusColor = paymentStatusColors[order.paymentStatus] || paymentStatusColors.pending;\n            %>\n            <span class=\"font-medium <%= paymentStatusColor %>\">\n              <%= typeof t === 'function' ? t('orders.payment.' + (order.paymentStatus || 'pending')) : (order.paymentStatus || 'Pending') %>\n            </span>\n          </div>\n        </div>\n\n        <% if (order.paymentStatus !== 'paid' && !['cancelled', 'delivered'].includes(order.status)) { %>\n          <form action=\"/admin/orders/<%= order.id %>/mark-paid\" method=\"POST\" class=\"mt-4\">\n            <button type=\"submit\" class=\"btn btn-secondary w-full\">\n              <i class=\"ph ph-check-circle mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.markPaid') : 'Mark as Paid' %>\n            </button>\n          </form>\n        <% } %>\n      </div>\n\n      <!-- Cancel Order -->\n      <% if (['pending', 'confirmed'].includes(order.status)) { %>\n        <div class=\"card p-6 border-red-200 dark:border-red-900\">\n          <h2 class=\"font-semibold text-red-600 dark:text-red-400 mb-4\">\n            <i class=\"ph ph-warning mr-2\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('orders.dangerZone') : 'Danger Zone' %>\n          </h2>\n\n          <p class=\"text-sm text-text-muted mb-4\">\n            <%= typeof t === 'function' ? t('orders.cancelWarning') : 'Cancelling an order cannot be undone. The customer will be notified.' %>\n          </p>\n\n          <form\n            action=\"/admin/orders/<%= order.id %>/status\"\n            method=\"POST\"\n            x-data=\"{ reason: '' }\"\n            onsubmit=\"return confirm('<%= typeof t === 'function' ? t('orders.confirmCancel') : 'Are you sure you want to cancel this order?' %>')\"\n          >\n            <input type=\"hidden\" name=\"status\" value=\"cancelled\">\n\n            <div class=\"mb-3\">\n              <label for=\"cancelReason\" class=\"form-label\">\n                <%= typeof t === 'function' ? t('orders.cancelReason') : 'Reason (optional)' %>\n              </label>\n              <textarea\n                id=\"cancelReason\"\n                name=\"reason\"\n                x-model=\"reason\"\n                rows=\"2\"\n                class=\"form-textarea w-full\"\n                placeholder=\"<%= typeof t === 'function' ? t('orders.cancelReasonPlaceholder') : 'Why is this order being cancelled?' %>\"\n              ></textarea>\n            </div>\n\n            <button\n              type=\"submit\"\n              class=\"btn bg-red-600 hover:bg-red-700 text-white w-full\"\n            >\n              <i class=\"ph ph-x-circle mr-2\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('orders.cancelOrder') : 'Cancel Order' %>\n            </button>\n          </form>\n        </div>\n      <% } %>\n    </div>\n  </div>\n</div>\n",
        "last_modified": "2026-02-01T09:10:53.770984"
      },
