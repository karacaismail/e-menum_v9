      "worktree_state": {
        "content": "<%#\n  Footer Component - Product Theme\n\n  Minimal footer for customer-facing menu with branding and essential info.\n\n  Variables:\n  - organization: Organization object\n  - menu: Current menu object\n%>\n<footer\n  role=\"contentinfo\"\n  class=\"flex-shrink-0 border-t border-border-color bg-surface-card mt-auto\"\n>\n  <div class=\"px-4 py-6\">\n    <!-- Restaurant Info -->\n    <div class=\"flex flex-col items-center text-center mb-4\">\n      <% if (locals.organization) { %>\n        <% if (organization.logo) { %>\n          <img\n            src=\"<%= organization.logo %>\"\n            alt=\"<%= organization.name %>\"\n            class=\"h-12 w-auto mb-2\"\n          >\n        <% } %>\n        <h2 class=\"text-lg font-semibold text-text-primary\">\n          <%= organization.name %>\n        </h2>\n        <% if (organization.address) { %>\n          <p class=\"text-sm text-text-muted mt-1\">\n            <i class=\"ph ph-map-pin\" aria-hidden=\"true\"></i>\n            <%= organization.address %>\n          </p>\n        <% } %>\n      <% } %>\n    </div>\n\n    <!-- Contact Actions -->\n    <div class=\"flex flex-wrap items-center justify-center gap-3 mb-6\">\n      <% if (locals.organization && organization.phone) { %>\n        <a\n          href=\"tel:<%= organization.phone %>\"\n          class=\"btn btn-secondary btn-sm\"\n        >\n          <i class=\"ph ph-phone\" aria-hidden=\"true\"></i>\n          <span><%= typeof t === 'function' ? t('common.call') : 'Call' %></span>\n        </a>\n      <% } %>\n      <% if (locals.organization && organization.whatsapp) { %>\n        <a\n          href=\"https://wa.me/<%= organization.whatsapp.replace(/\\D/g, '') %>\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"btn btn-secondary btn-sm\"\n        >\n          <i class=\"ph ph-whatsapp-logo\" aria-hidden=\"true\"></i>\n          <span>WhatsApp</span>\n        </a>\n      <% } %>\n      <% if (locals.organization && organization.googleMapsUrl) { %>\n        <a\n          href=\"<%= organization.googleMapsUrl %>\"\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"btn btn-secondary btn-sm\"\n        >\n          <i class=\"ph ph-map-trifold\" aria-hidden=\"true\"></i>\n          <span><%= typeof t === 'function' ? t('common.directions') : 'Directions' %></span>\n        </a>\n      <% } %>\n    </div>\n\n    <!-- Allergen Information -->\n    <% if (locals.menu && menu.showAllergenNotice !== false) { %>\n      <div class=\"bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-3 mb-4\">\n        <p class=\"text-xs text-amber-700 dark:text-amber-400 text-center\">\n          <i class=\"ph ph-warning\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('menu.allergenNotice') : 'Please inform our staff of any food allergies or dietary requirements before ordering.' %>\n        </p>\n      </div>\n    <% } %>\n\n    <!-- Operating Hours (if available) -->\n    <% if (locals.organization && organization.operatingHours) { %>\n      <div class=\"text-center mb-4\">\n        <p class=\"text-xs text-text-muted\">\n          <i class=\"ph ph-clock\" aria-hidden=\"true\"></i>\n          <span><%= organization.operatingHours %></span>\n        </p>\n      </div>\n    <% } %>\n\n    <!-- Social Links -->\n    <% if (locals.organization && (organization.instagram || organization.facebook || organization.twitter)) { %>\n      <div class=\"flex items-center justify-center gap-4 mb-6\">\n        <% if (organization.instagram) { %>\n          <a\n            href=\"https://instagram.com/<%= organization.instagram %>\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"text-text-muted hover:text-text-primary transition-colors\"\n            aria-label=\"Instagram\"\n          >\n            <i class=\"ph ph-instagram-logo text-2xl\" aria-hidden=\"true\"></i>\n          </a>\n        <% } %>\n        <% if (organization.facebook) { %>\n          <a\n            href=\"https://facebook.com/<%= organization.facebook %>\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"text-text-muted hover:text-text-primary transition-colors\"\n            aria-label=\"Facebook\"\n          >\n            <i class=\"ph ph-facebook-logo text-2xl\" aria-hidden=\"true\"></i>\n          </a>\n        <% } %>\n        <% if (organization.twitter) { %>\n          <a\n            href=\"https://twitter.com/<%= organization.twitter %>\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"text-text-muted hover:text-text-primary transition-colors\"\n            aria-label=\"Twitter\"\n          >\n            <i class=\"ph ph-twitter-logo text-2xl\" aria-hidden=\"true\"></i>\n          </a>\n        <% } %>\n      </div>\n    <% } %>\n\n    <!-- Divider -->\n    <div class=\"border-t border-border-color my-4\"></div>\n\n    <!-- Branding -->\n    <div class=\"flex flex-col items-center gap-2\">\n      <a\n        href=\"https://e-menum.net\"\n        target=\"_blank\"\n        rel=\"noopener noreferrer\"\n        class=\"flex items-center gap-2 text-text-muted hover:text-text-primary transition-colors\"\n      >\n        <span class=\"text-xs\">\n          <%= typeof t === 'function' ? t('common.poweredBy') : 'Powered by' %>\n        </span>\n        <span class=\"font-semibold text-sm text-brand-primary\">E-Menum</span>\n      </a>\n      <p class=\"text-xs text-text-muted\">\n        &copy; <%= new Date().getFullYear() %> <%= locals.organization ? organization.name : 'E-Menum' %>.\n        <%= typeof t === 'function' ? t('common.allRightsReserved') : 'All rights reserved.' %>\n      </p>\n    </div>\n\n    <!-- Accessibility & Legal Links -->\n    <nav\n      aria-label=\"<%= typeof t === 'function' ? t('nav.legal') : 'Legal' %>\"\n      class=\"flex flex-wrap items-center justify-center gap-4 mt-3 text-xs text-text-muted\"\n    >\n      <a\n        href=\"/privacy\"\n        class=\"hover:text-text-primary transition-colors\"\n      >\n        <%= typeof t === 'function' ? t('nav.privacy') : 'Privacy Policy' %>\n      </a>\n      <span aria-hidden=\"true\">&middot;</span>\n      <a\n        href=\"/terms\"\n        class=\"hover:text-text-primary transition-colors\"\n      >\n        <%= typeof t === 'function' ? t('nav.terms') : 'Terms of Service' %>\n      </a>\n      <% if (locals.menu) { %>\n        <span aria-hidden=\"true\">&middot;</span>\n        <a\n          href=\"<%= '/m/' + menu.slug + '/allergens' %>\"\n          class=\"hover:text-text-primary transition-colors\"\n        >\n          <%= typeof t === 'function' ? t('nav.allergenInfo') : 'Allergen Info' %>\n        </a>\n      <% } %>\n    </nav>\n  </div>\n</footer>\n",
        "last_modified": "2026-02-01T09:10:53.782557"
      },
