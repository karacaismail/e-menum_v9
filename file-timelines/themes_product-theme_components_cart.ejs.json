      "worktree_state": {
        "content": "<%#\n  Cart Component - Product Theme\n\n  Slide-up cart drawer with items, quantity controls, and checkout button.\n\n  Variables:\n  - menu: Current menu object\n  - tableNumber: Optional table number\n%>\n<!-- Cart Drawer Overlay -->\n<div\n  x-show=\"cartOpen\"\n  x-transition:enter=\"transition ease-out duration-300\"\n  x-transition:enter-start=\"opacity-0\"\n  x-transition:enter-end=\"opacity-100\"\n  x-transition:leave=\"transition ease-in duration-200\"\n  x-transition:leave-start=\"opacity-100\"\n  x-transition:leave-end=\"opacity-0\"\n  @click=\"cartOpen = false\"\n  class=\"fixed inset-0 z-40 bg-black/50\"\n  aria-hidden=\"true\"\n></div>\n\n<!-- Cart Drawer -->\n<aside\n  x-show=\"cartOpen\"\n  x-transition:enter=\"transition ease-out duration-300 transform\"\n  x-transition:enter-start=\"translate-y-full\"\n  x-transition:enter-end=\"translate-y-0\"\n  x-transition:leave=\"transition ease-in duration-200 transform\"\n  x-transition:leave-start=\"translate-y-0\"\n  x-transition:leave-end=\"translate-y-full\"\n  @keydown.escape.window=\"cartOpen = false\"\n  class=\"fixed bottom-0 inset-x-0 z-50 bg-surface-card rounded-t-2xl shadow-2xl max-h-[85vh] flex flex-col\"\n  role=\"dialog\"\n  aria-modal=\"true\"\n  aria-labelledby=\"cart-title\"\n>\n  <!-- Cart Header -->\n  <div class=\"flex items-center justify-between p-4 border-b border-border-color flex-shrink-0\">\n    <div class=\"flex items-center gap-3\">\n      <div class=\"w-10 h-10 rounded-full bg-brand-primary/10 flex items-center justify-center\">\n        <i class=\"ph ph-shopping-cart text-brand-primary text-xl\" aria-hidden=\"true\"></i>\n      </div>\n      <div>\n        <h2 id=\"cart-title\" class=\"text-lg font-semibold text-text-primary\">\n          <%= typeof t === 'function' ? t('cart.title') : 'Your Order' %>\n        </h2>\n        <p class=\"text-xs text-text-muted\">\n          <span x-text=\"cartItemCount\"></span> <%= typeof t === 'function' ? t('cart.items') : 'items' %>\n          <% if (locals.tableNumber) { %>\n            &middot; <%= typeof t === 'function' ? t('common.table') : 'Table' %> <%= tableNumber %>\n          <% } %>\n        </p>\n      </div>\n    </div>\n    <button\n      type=\"button\"\n      @click=\"cartOpen = false\"\n      class=\"btn btn-ghost btn-icon\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close cart' %>\"\n    >\n      <i class=\"ph ph-x text-xl\" aria-hidden=\"true\"></i>\n    </button>\n  </div>\n\n  <!-- Cart Items -->\n  <div class=\"flex-1 overflow-y-auto p-4\">\n    <!-- Empty Cart State -->\n    <template x-if=\"cart.length === 0\">\n      <div class=\"text-center py-12\">\n        <div class=\"w-20 h-20 mx-auto mb-4 rounded-full bg-surface-elevated flex items-center justify-center\">\n          <i class=\"ph ph-shopping-cart-simple text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n        </div>\n        <h3 class=\"text-lg font-semibold text-text-primary mb-2\">\n          <%= typeof t === 'function' ? t('cart.empty') : 'Your cart is empty' %>\n        </h3>\n        <p class=\"text-sm text-text-muted mb-4\">\n          <%= typeof t === 'function' ? t('cart.emptyDescription') : 'Add some delicious items from the menu' %>\n        </p>\n        <button\n          type=\"button\"\n          @click=\"cartOpen = false\"\n          class=\"btn btn-primary\"\n        >\n          <i class=\"ph ph-fork-knife\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('cart.browseMenu') : 'Browse Menu' %>\n        </button>\n      </div>\n    </template>\n\n    <!-- Cart Items List -->\n    <template x-if=\"cart.length > 0\">\n      <ul class=\"space-y-3\" role=\"list\" aria-label=\"<%= typeof t === 'function' ? t('cart.itemList') : 'Cart items' %>\">\n        <template x-for=\"(item, index) in cart\" :key=\"index\">\n          <li class=\"flex gap-3 p-3 bg-surface-elevated rounded-lg\">\n            <!-- Item Image -->\n            <div class=\"w-16 h-16 flex-shrink-0 rounded-lg overflow-hidden bg-surface-card\">\n              <template x-if=\"item.image\">\n                <img\n                  :src=\"item.image\"\n                  alt=\"\"\n                  class=\"w-full h-full object-cover\"\n                >\n              </template>\n              <template x-if=\"!item.image\">\n                <div class=\"w-full h-full flex items-center justify-center\">\n                  <i class=\"ph ph-bowl-food text-2xl text-text-muted\" aria-hidden=\"true\"></i>\n                </div>\n              </template>\n            </div>\n\n            <!-- Item Info -->\n            <div class=\"flex-1 min-w-0\">\n              <h4 class=\"text-sm font-semibold text-text-primary truncate\" x-text=\"item.name\"></h4>\n\n              <!-- Variants/Modifiers -->\n              <template x-if=\"item.variants.length > 0 || item.modifiers.length > 0\">\n                <p class=\"text-xs text-text-muted mt-0.5 truncate\">\n                  <template x-for=\"(v, i) in item.variants\" :key=\"'v-' + i\">\n                    <span x-text=\"v.name + (i < item.variants.length - 1 || item.modifiers.length > 0 ? ', ' : '')\"></span>\n                  </template>\n                  <template x-for=\"(m, i) in item.modifiers\" :key=\"'m-' + i\">\n                    <span x-text=\"m.name + (i < item.modifiers.length - 1 ? ', ' : '')\"></span>\n                  </template>\n                </p>\n              </template>\n\n              <!-- Price & Quantity Controls -->\n              <div class=\"flex items-center justify-between mt-2\">\n                <span class=\"text-sm font-bold text-brand-primary\" x-text=\"formatPrice(item.price * item.quantity)\"></span>\n\n                <div class=\"flex items-center gap-1\">\n                  <button\n                    type=\"button\"\n                    @click=\"updateQuantity(index, item.quantity - 1)\"\n                    class=\"btn btn-ghost btn-icon btn-sm\"\n                    :aria-label=\"item.quantity === 1 ? '<%= typeof t === 'function' ? t('cart.removeItem') : 'Remove item' %>' : '<%= typeof t === 'function' ? t('cart.decreaseQuantity') : 'Decrease quantity' %>'\"\n                  >\n                    <i :class=\"item.quantity === 1 ? 'ph ph-trash' : 'ph ph-minus'\" class=\"text-sm\" aria-hidden=\"true\"></i>\n                  </button>\n                  <span class=\"w-8 text-center text-sm font-semibold text-text-primary\" x-text=\"item.quantity\"></span>\n                  <button\n                    type=\"button\"\n                    @click=\"updateQuantity(index, item.quantity + 1)\"\n                    class=\"btn btn-ghost btn-icon btn-sm\"\n                    :disabled=\"item.quantity >= 99\"\n                    aria-label=\"<%= typeof t === 'function' ? t('cart.increaseQuantity') : 'Increase quantity' %>\"\n                  >\n                    <i class=\"ph ph-plus text-sm\" aria-hidden=\"true\"></i>\n                  </button>\n                </div>\n              </div>\n            </div>\n          </li>\n        </template>\n      </ul>\n    </template>\n  </div>\n\n  <!-- Cart Footer -->\n  <template x-if=\"cart.length > 0\">\n    <div class=\"flex-shrink-0 border-t border-border-color bg-surface-card p-4 space-y-3\">\n      <!-- Order Summary -->\n      <div class=\"space-y-2\">\n        <div class=\"flex items-center justify-between text-sm\">\n          <span class=\"text-text-secondary\">\n            <%= typeof t === 'function' ? t('cart.subtotal') : 'Subtotal' %>\n          </span>\n          <span class=\"font-medium text-text-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n        </div>\n        <!-- Note: Tax/service charges would be added here -->\n        <div class=\"flex items-center justify-between\">\n          <span class=\"text-base font-semibold text-text-primary\">\n            <%= typeof t === 'function' ? t('cart.total') : 'Total' %>\n          </span>\n          <span class=\"text-xl font-bold text-brand-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n        </div>\n      </div>\n\n      <!-- Action Buttons -->\n      <div class=\"flex gap-3\">\n        <button\n          type=\"button\"\n          @click=\"if(confirm('<%= typeof t === 'function' ? t('cart.clearConfirm') : 'Clear all items?' %>')) clearCart()\"\n          class=\"btn btn-secondary flex-shrink-0\"\n          aria-label=\"<%= typeof t === 'function' ? t('cart.clearCart') : 'Clear cart' %>\"\n        >\n          <i class=\"ph ph-trash\" aria-hidden=\"true\"></i>\n        </button>\n        <a\n          href=\"<%= locals.menu ? '/m/' + menu.slug + '/checkout' : '/checkout' %><%= locals.tableNumber ? '?table=' + tableNumber : '' %>\"\n          class=\"btn btn-primary flex-1 py-3 text-base\"\n          @click=\"cartOpen = false\"\n        >\n          <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n          <span><%= typeof t === 'function' ? t('cart.placeOrder') : 'Place Order' %></span>\n        </a>\n      </div>\n\n      <!-- Additional Notes -->\n      <p class=\"text-xs text-text-muted text-center\">\n        <i class=\"ph ph-info\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('cart.paymentNote') : 'You will pay at the counter or to your server' %>\n      </p>\n    </div>\n  </template>\n</aside>\n\n<!-- Floating Cart Button (when cart is closed and has items) -->\n<div\n  x-show=\"!cartOpen && cartItemCount > 0\"\n  x-transition:enter=\"transition ease-out duration-200 transform\"\n  x-transition:enter-start=\"translate-y-full opacity-0\"\n  x-transition:enter-end=\"translate-y-0 opacity-100\"\n  x-transition:leave=\"transition ease-in duration-150 transform\"\n  x-transition:leave-start=\"translate-y-0 opacity-100\"\n  x-transition:leave-end=\"translate-y-full opacity-0\"\n  class=\"fixed bottom-4 left-4 right-4 z-30 sm:left-auto sm:right-4 sm:max-w-sm\"\n>\n  <button\n    type=\"button\"\n    @click=\"cartOpen = true\"\n    class=\"w-full btn btn-primary py-4 shadow-lg\"\n  >\n    <div class=\"flex items-center justify-between w-full\">\n      <div class=\"flex items-center gap-2\">\n        <div class=\"relative\">\n          <i class=\"ph ph-shopping-cart text-xl\" aria-hidden=\"true\"></i>\n          <span class=\"absolute -top-2 -right-2 w-5 h-5 text-xs font-bold bg-white text-brand-primary rounded-full flex items-center justify-center\" x-text=\"cartItemCount\"></span>\n        </div>\n        <span class=\"font-semibold\"><%= typeof t === 'function' ? t('cart.viewOrder') : 'View Order' %></span>\n      </div>\n      <span class=\"font-bold\" x-text=\"formatPrice(cartTotal)\"></span>\n    </div>\n  </button>\n</div>\n",
        "last_modified": "2026-02-01T09:10:53.781756"
      },
