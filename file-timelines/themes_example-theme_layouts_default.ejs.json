      "worktree_state": {
        "content": "<%#\n  ============================================================================\n  DEFAULT LAYOUT - Example Theme\n  ============================================================================\n\n  This is the main layout template that wraps all page content.\n\n  AVAILABLE VARIABLES (passed from controller):\n  - locals.lang: Current language code (e.g., 'tr', 'en')\n  - locals.theme: Theme preference ('light' or 'dark')\n  - locals.pageTitle: Page title\n  - locals.metaDescription: Meta description\n  - locals.brandColor: Organization's brand color\n  - locals.organizationName: Organization name\n  - locals.menu: Menu object\n  - locals.organization: Organization object\n  - locals.tableNumber: Table number from QR scan\n  - locals.categories: Array of menu categories\n  - locals.flash: Flash messages {error, success, info}\n  - t(): Translation function (i18next)\n\n  IMPORTANT RULES:\n  1. Use CSS variables for ALL colors (no hardcoded colors)\n  2. Use t() function for ALL text (no hardcoded strings)\n  3. Do NOT add business logic here - only layout structure\n  4. Do NOT make API calls from templates\n  5. Data comes via locals - display only\n%>\n<!DOCTYPE html>\n<html lang=\"<%= locals.lang || 'tr' %>\" data-theme=\"<%= locals.theme || 'light' %>\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes\">\n  <meta name=\"description\" content=\"<%= locals.metaDescription || (typeof t === 'function' ? t('meta.defaultDescription') : 'Digital Menu') %>\">\n  <meta name=\"theme-color\" content=\"<%= locals.brandColor || '#6366f1' %>\">\n\n  <!-- Page Title -->\n  <title><%= locals.pageTitle ? `${locals.pageTitle} | ` : '' %><%= locals.organizationName || 'E-Menum' %></title>\n\n  <!-- Favicon -->\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\n\n  <!-- Fonts - Using system fonts for simplicity -->\n  <!-- You can add custom fonts here if needed -->\n\n  <!-- Icons - Phosphor Icons (Primary icon set for E-Menum) -->\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/regular/style.css\">\n\n  <!-- Theme Stylesheet -->\n  <link rel=\"stylesheet\" href=\"/themes/example-theme/styles/main.css\">\n\n  <!--\n    Dynamic Brand Colors\n    Override CSS variables with organization's brand color if provided\n  -->\n  <% if (locals.brandColor) { %>\n    <style>\n      :root {\n        --brand-primary: <%= brandColor %>;\n      }\n    </style>\n  <% } %>\n\n  <!-- Alpine.js for interactivity -->\n  <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n\n  <!--\n    Theme Toggle Script\n    Runs before page render to prevent flash of wrong theme\n  -->\n  <script>\n    (function() {\n      var savedTheme = localStorage.getItem('theme');\n      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;\n      var theme = savedTheme || (prefersDark ? 'dark' : 'light');\n      document.documentElement.setAttribute('data-theme', theme);\n    })();\n  </script>\n</head>\n<body class=\"bg-surface text-text-primary font-sans\">\n  <!--\n    Skip Link - Accessibility Feature\n    Allows keyboard users to skip navigation and jump to main content\n  -->\n  <a href=\"#main-content\" class=\"skip-link\">\n    <%= typeof t === 'function' ? t('common.skipToContent') : 'Skip to main content' %>\n  </a>\n\n  <!--\n    Live Region - Screen Reader Announcements\n    Used to announce dynamic changes (e.g., \"Item added to cart\")\n  -->\n  <div aria-live=\"polite\" aria-atomic=\"true\" class=\"sr-only\" id=\"sr-announcements\"></div>\n\n  <!--\n    Main App Container\n    Uses Alpine.js for reactive state management\n\n    IMPORTANT: Cart logic is handled here at the layout level\n    so it's available to all components\n  -->\n  <div\n    x-data=\"{\n      cart: [],\n      cartOpen: false,\n\n      addToCart(product, quantity) {\n        quantity = quantity || 1;\n        var existing = this.cart.find(function(item) { return item.productId === product.id; });\n\n        if (existing) {\n          existing.quantity += quantity;\n        } else {\n          this.cart.push({\n            productId: product.id,\n            name: product.name,\n            price: product.price,\n            image: product.image,\n            quantity: quantity\n          });\n        }\n\n        this.saveCart();\n        this.announce('<%= typeof t === 'function' ? t('cart.itemAdded') : 'Item added to cart' %>');\n      },\n\n      removeFromCart(index) {\n        this.cart.splice(index, 1);\n        this.saveCart();\n      },\n\n      get cartTotal() {\n        return this.cart.reduce(function(total, item) {\n          return total + (item.price * item.quantity);\n        }, 0);\n      },\n\n      get cartItemCount() {\n        return this.cart.reduce(function(count, item) {\n          return count + item.quantity;\n        }, 0);\n      },\n\n      saveCart() {\n        localStorage.setItem('cart', JSON.stringify(this.cart));\n      },\n\n      loadCart() {\n        var saved = localStorage.getItem('cart');\n        if (saved) {\n          try {\n            this.cart = JSON.parse(saved);\n          } catch (e) {\n            this.cart = [];\n          }\n        }\n      },\n\n      formatPrice(price) {\n        return new Intl.NumberFormat('<%= locals.lang || 'tr' %>-TR', {\n          style: 'currency',\n          currency: 'TRY'\n        }).format(price);\n      },\n\n      announce(message) {\n        var el = document.getElementById('sr-announcements');\n        if (el) {\n          el.textContent = message;\n          setTimeout(function() { el.textContent = ''; }, 1000);\n        }\n      }\n    }\"\n    x-init=\"loadCart()\"\n    @keydown.escape=\"cartOpen = false\"\n    class=\"min-h-screen flex flex-col\"\n  >\n    <!-- Header Component -->\n    <%- include('../components/header', {\n      menu: locals.menu,\n      organization: locals.organization,\n      tableNumber: locals.tableNumber\n    }) %>\n\n    <!--\n      Main Content Area\n      This is where page-specific content will be rendered\n      The <%- body %> variable contains the page content\n    -->\n    <main id=\"main-content\" role=\"main\" class=\"flex-1\">\n      <!-- Flash Messages -->\n      <% if (locals.flash && locals.flash.error) { %>\n        <div role=\"alert\" class=\"alert alert-error\">\n          <i class=\"ph ph-warning-circle\" aria-hidden=\"true\"></i>\n          <span><%= locals.flash.error %></span>\n        </div>\n      <% } %>\n\n      <% if (locals.flash && locals.flash.success) { %>\n        <div role=\"alert\" class=\"alert alert-success\">\n          <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n          <span><%= locals.flash.success %></span>\n        </div>\n      <% } %>\n\n      <!-- Page Content -->\n      <%- body %>\n    </main>\n\n    <!-- Footer Component -->\n    <%- include('../components/footer', {\n      organization: locals.organization,\n      menu: locals.menu\n    }) %>\n\n    <!--\n      Floating Cart Button\n      Shows cart item count and opens cart drawer\n    -->\n    <button\n      x-show=\"cartItemCount > 0\"\n      @click=\"cartOpen = true\"\n      type=\"button\"\n      class=\"cart-fab\"\n      aria-label=\"<%= typeof t === 'function' ? t('cart.viewCart') : 'View cart' %>\"\n    >\n      <i class=\"ph ph-shopping-cart\" aria-hidden=\"true\"></i>\n      <span x-text=\"cartItemCount\" class=\"cart-fab-count\"></span>\n      <span class=\"cart-fab-total\" x-text=\"formatPrice(cartTotal)\"></span>\n    </button>\n  </div>\n</body>\n</html>\n",
        "last_modified": "2026-02-01T09:10:53.780654"
      },
