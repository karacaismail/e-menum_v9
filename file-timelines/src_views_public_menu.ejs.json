      },
      "worktree_state": {
        "content": "<%#\n  Public Menu View - QR Menu Display\n\n  This is the main customer-facing menu page shown when scanning a QR code.\n  Displays categories and products with search, filtering, and add-to-cart functionality.\n\n  Variables:\n  - menu: Menu object {id, name, slug, description, coverImage, status}\n  - categories: Array of category objects [{id, name, description, icon, sortOrder, products[]}]\n  - organization: Organization object {id, name, logo, address, phone}\n  - tableNumber: Optional table number from QR scan\n  - theme: Theme customization object\n  - lang: Current language code (tr/en)\n%>\n\n<!-- Menu Header / Hero Section -->\n<% if (locals.menu && menu.coverImage) { %>\n  <section class=\"relative h-48 sm:h-64 overflow-hidden\">\n    <img\n      src=\"<%= menu.coverImage %>\"\n      alt=\"<%= menu.name %>\"\n      class=\"w-full h-full object-cover\"\n    >\n    <div class=\"absolute inset-0 bg-gradient-to-t from-black/70 to-transparent\"></div>\n    <div class=\"absolute bottom-0 left-0 right-0 p-4 sm:p-6\">\n      <h1 class=\"text-2xl sm:text-3xl font-bold text-white mb-1\">\n        <%= menu.name %>\n      </h1>\n      <% if (menu.description) { %>\n        <p class=\"text-sm sm:text-base text-white/80 line-clamp-2\">\n          <%= menu.description %>\n        </p>\n      <% } %>\n    </div>\n  </section>\n<% } else { %>\n  <section class=\"px-4 py-6 sm:py-8 bg-surface-elevated border-b border-border-color\">\n    <h1 class=\"text-2xl sm:text-3xl font-bold text-text-primary\">\n      <%= locals.menu ? menu.name : (typeof t === 'function' ? t('menu.title') : 'Menu') %>\n    </h1>\n    <% if (locals.menu && menu.description) { %>\n      <p class=\"mt-2 text-text-secondary\">\n        <%= menu.description %>\n      </p>\n    <% } %>\n  </section>\n<% } %>\n\n<!-- Search Results (shown when searching) -->\n<section\n  x-show=\"searchQuery.length > 0\"\n  x-cloak\n  class=\"px-4 py-6\"\n>\n  <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n    <%= typeof t === 'function' ? t('search.results') : 'Search Results' %>\n    <span class=\"text-text-muted font-normal\" x-text=\"'&quot;' + searchQuery + '&quot;'\"></span>\n  </h2>\n\n  <!-- Search results would be filtered client-side with Alpine.js -->\n  <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n    <% if (locals.categories) { %>\n      <% categories.forEach(function(category) { %>\n        <% if (category.products && category.products.length > 0) { %>\n          <% category.products.forEach(function(product) { %>\n            <template x-if=\"'<%= product.name.toLowerCase() %>'.includes(searchQuery.toLowerCase()) || '<%= (product.description || '').toLowerCase() %>'.includes(searchQuery.toLowerCase())\">\n              <div class=\"card overflow-hidden\">\n                <div class=\"flex gap-3 p-3\">\n                  <% if (product.image) { %>\n                    <img\n                      src=\"<%= product.image %>\"\n                      alt=\"\"\n                      class=\"w-20 h-20 rounded-lg object-cover flex-shrink-0\"\n                    >\n                  <% } %>\n                  <div class=\"flex-1 min-w-0\">\n                    <h3 class=\"font-semibold text-text-primary\"><%= product.name %></h3>\n                    <p class=\"text-sm text-text-secondary line-clamp-2 mt-1\"><%= product.description %></p>\n                    <div class=\"flex items-center justify-between mt-2\">\n                      <span class=\"font-bold text-brand-primary\">\n                        <%= product.price ? product.price.toFixed(2) + ' TL' : '' %>\n                      </span>\n                      <button\n                        type=\"button\"\n                        @click=\"addToCart(<%= JSON.stringify(product) %>, 1, [], [])\"\n                        class=\"btn btn-primary btn-sm\"\n                      >\n                        <i class=\"ph ph-plus\" aria-hidden=\"true\"></i>\n                      </button>\n                    </div>\n                  </div>\n                </div>\n              </div>\n            </template>\n          <% }); %>\n        <% } %>\n      <% }); %>\n    <% } %>\n  </div>\n\n  <!-- No Results Message -->\n  <div x-show=\"searchQuery.length > 2\" class=\"text-center py-8\">\n    <p class=\"text-text-muted\">\n      <%= typeof t === 'function' ? t('search.noResults') : 'No items found matching your search' %>\n    </p>\n  </div>\n</section>\n\n<!-- Categories and Products -->\n<section\n  x-show=\"searchQuery.length === 0\"\n  class=\"px-4 py-6 space-y-8\"\n>\n  <% if (!locals.categories || categories.length === 0) { %>\n    <!-- Empty Menu State -->\n    <div class=\"text-center py-12\">\n      <div class=\"w-20 h-20 mx-auto mb-4 rounded-full bg-surface-elevated flex items-center justify-center\">\n        <i class=\"ph ph-book-open text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n      </div>\n      <h2 class=\"text-xl font-semibold text-text-primary mb-2\">\n        <%= typeof t === 'function' ? t('menu.empty') : 'Menu is being prepared' %>\n      </h2>\n      <p class=\"text-text-muted\">\n        <%= typeof t === 'function' ? t('menu.emptyDescription') : 'Check back soon for our delicious offerings' %>\n      </p>\n    </div>\n  <% } else { %>\n    <% categories.forEach(function(category, categoryIndex) { %>\n      <!-- Category Section -->\n      <section\n        id=\"category-<%= category.id %>\"\n        role=\"tabpanel\"\n        :aria-labelledby=\"'category-tab-<%= category.id %>'\"\n        class=\"scroll-mt-32\"\n      >\n        <!-- Category Header -->\n        <header class=\"flex items-center gap-3 mb-4\">\n          <% if (category.icon) { %>\n            <div class=\"w-10 h-10 rounded-lg bg-brand-primary/10 flex items-center justify-center flex-shrink-0\">\n              <i class=\"ph ph-<%= category.icon %> text-xl text-brand-primary\" aria-hidden=\"true\"></i>\n            </div>\n          <% } %>\n          <div>\n            <h2 class=\"text-xl font-bold text-text-primary\">\n              <%= category.name %>\n            </h2>\n            <% if (category.description) { %>\n              <p class=\"text-sm text-text-secondary\">\n                <%= category.description %>\n              </p>\n            <% } %>\n          </div>\n        </header>\n\n        <!-- Products Grid -->\n        <% if (!category.products || category.products.length === 0) { %>\n          <div class=\"text-center py-8 bg-surface-elevated rounded-lg\">\n            <p class=\"text-text-muted\">\n              <%= typeof t === 'function' ? t('category.noProducts') : 'No items in this category yet' %>\n            </p>\n          </div>\n        <% } else { %>\n          <div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">\n            <% category.products.forEach(function(product) { %>\n              <%- include('../../themes/product-theme/components/menu-item', { product: product }) %>\n            <% }); %>\n          </div>\n        <% } %>\n      </section>\n    <% }); %>\n  <% } %>\n</section>\n\n<!-- Restaurant Info Section -->\n<% if (locals.organization) { %>\n  <section class=\"px-4 py-8 bg-surface-elevated border-t border-border-color\">\n    <div class=\"max-w-lg mx-auto text-center\">\n      <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n        <%= typeof t === 'function' ? t('restaurant.contact') : 'Contact Us' %>\n      </h2>\n\n      <div class=\"space-y-3\">\n        <% if (organization.address) { %>\n          <a\n            href=\"https://maps.google.com/?q=<%= encodeURIComponent(organization.address) %>\"\n            target=\"_blank\"\n            rel=\"noopener noreferrer\"\n            class=\"flex items-center justify-center gap-2 text-text-secondary hover:text-brand-primary transition-colors\"\n          >\n            <i class=\"ph ph-map-pin\" aria-hidden=\"true\"></i>\n            <span><%= organization.address %></span>\n          </a>\n        <% } %>\n\n        <% if (organization.phone) { %>\n          <a\n            href=\"tel:<%= organization.phone %>\"\n            class=\"flex items-center justify-center gap-2 text-text-secondary hover:text-brand-primary transition-colors\"\n          >\n            <i class=\"ph ph-phone\" aria-hidden=\"true\"></i>\n            <span><%= organization.phone %></span>\n          </a>\n        <% } %>\n\n        <% if (organization.email) { %>\n          <a\n            href=\"mailto:<%= organization.email %>\"\n            class=\"flex items-center justify-center gap-2 text-text-secondary hover:text-brand-primary transition-colors\"\n          >\n            <i class=\"ph ph-envelope\" aria-hidden=\"true\"></i>\n            <span><%= organization.email %></span>\n          </a>\n        <% } %>\n      </div>\n\n      <!-- Social Links -->\n      <% if (organization.socialLinks && Object.keys(organization.socialLinks).length > 0) { %>\n        <div class=\"flex items-center justify-center gap-4 mt-6\">\n          <% if (organization.socialLinks.instagram) { %>\n            <a\n              href=\"<%= organization.socialLinks.instagram %>\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"btn btn-ghost btn-icon\"\n              aria-label=\"Instagram\"\n            >\n              <i class=\"ph ph-instagram-logo text-xl\" aria-hidden=\"true\"></i>\n            </a>\n          <% } %>\n          <% if (organization.socialLinks.facebook) { %>\n            <a\n              href=\"<%= organization.socialLinks.facebook %>\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"btn btn-ghost btn-icon\"\n              aria-label=\"Facebook\"\n            >\n              <i class=\"ph ph-facebook-logo text-xl\" aria-hidden=\"true\"></i>\n            </a>\n          <% } %>\n          <% if (organization.socialLinks.twitter) { %>\n            <a\n              href=\"<%= organization.socialLinks.twitter %>\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"btn btn-ghost btn-icon\"\n              aria-label=\"Twitter\"\n            >\n              <i class=\"ph ph-twitter-logo text-xl\" aria-hidden=\"true\"></i>\n            </a>\n          <% } %>\n          <% if (organization.socialLinks.whatsapp) { %>\n            <a\n              href=\"https://wa.me/<%= organization.socialLinks.whatsapp.replace(/[^0-9]/g, '') %>\"\n              target=\"_blank\"\n              rel=\"noopener noreferrer\"\n              class=\"btn btn-ghost btn-icon\"\n              aria-label=\"WhatsApp\"\n            >\n              <i class=\"ph ph-whatsapp-logo text-xl\" aria-hidden=\"true\"></i>\n            </a>\n          <% } %>\n        </div>\n      <% } %>\n    </div>\n  </section>\n<% } %>\n\n<!-- Allergen Legend (if products have allergens) -->\n<%\n  const allAllergens = [];\n  if (locals.categories) {\n    categories.forEach(cat => {\n      if (cat.products) {\n        cat.products.forEach(prod => {\n          if (prod.allergens) {\n            prod.allergens.forEach(a => {\n              if (!allAllergens.find(x => x.code === a.code)) {\n                allAllergens.push(a);\n              }\n            });\n          }\n        });\n      }\n    });\n  }\n%>\n<% if (allAllergens.length > 0) { %>\n  <section class=\"px-4 py-6 border-t border-border-color\">\n    <details class=\"group\">\n      <summary class=\"flex items-center justify-between cursor-pointer list-none\">\n        <h2 class=\"text-sm font-semibold text-text-secondary\">\n          <i class=\"ph ph-warning-circle mr-1\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('allergens.title') : 'Allergen Information' %>\n        </h2>\n        <i class=\"ph ph-caret-down text-text-muted group-open:rotate-180 transition-transform\" aria-hidden=\"true\"></i>\n      </summary>\n      <div class=\"mt-3 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2\">\n        <% allAllergens.forEach(function(allergen) { %>\n          <div class=\"flex items-center gap-2 text-xs text-text-secondary\">\n            <span class=\"inline-flex items-center justify-center w-6 h-6 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 font-medium\">\n              <%= allergen.code %>\n            </span>\n            <span><%= allergen.name %></span>\n          </div>\n        <% }); %>\n      </div>\n    </details>\n  </section>\n<% } %>\n",
        "last_modified": "2026-02-01T09:10:53.773296"
      },
