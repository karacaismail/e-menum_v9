      "worktree_state": {
        "content": "<!DOCTYPE html>\n<html lang=\"<%= locals.lang || 'tr' %>\" data-theme=\"<%= locals.theme || 'light' %>\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"<%= locals.metaDescription || 'E-Menum Admin Panel' %>\">\n  <meta name=\"robots\" content=\"noindex, nofollow\">\n\n  <title><%= locals.pageTitle ? `${locals.pageTitle} | ` : '' %>E-Menum Admin</title>\n\n  <!-- Favicon -->\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/images/apple-touch-icon.png\">\n\n  <!-- Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n  <!-- Icons - Phosphor Icons (Primary) -->\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/regular/style.css\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/bold/style.css\">\n\n  <!-- Main Stylesheet -->\n  <link rel=\"stylesheet\" href=\"/themes/admin-theme/styles/main.css\">\n  <% if (locals.extraStyles) { %>\n    <% extraStyles.forEach(function(style) { %>\n      <link rel=\"stylesheet\" href=\"<%= style %>\">\n    <% }); %>\n  <% } %>\n\n  <!-- Alpine.js -->\n  <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n\n  <!-- Theme Toggle Script (runs before page render to prevent flash) -->\n  <script>\n    (function() {\n      const savedTheme = localStorage.getItem('theme');\n      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;\n      const theme = savedTheme || (prefersDark ? 'dark' : 'light');\n      document.documentElement.setAttribute('data-theme', theme);\n    })();\n  </script>\n</head>\n<body class=\"bg-surface-background text-text-primary font-sans antialiased\">\n  <!-- Skip Link for Accessibility -->\n  <a href=\"#main-content\" class=\"skip-link\">\n    <%= typeof t === 'function' ? t('common.skipToContent') : 'Skip to main content' %>\n  </a>\n\n  <!-- Live Region for Screen Reader Announcements -->\n  <div aria-live=\"polite\" aria-atomic=\"true\" class=\"sr-only\" id=\"sr-announcements\"></div>\n\n  <!-- Main Layout Container -->\n  <div\n    x-data=\"{\n      sidebarOpen: window.innerWidth >= 1024,\n      sidebarCollapsed: localStorage.getItem('sidebarCollapsed') === 'true',\n      toggleSidebar() {\n        if (window.innerWidth < 1024) {\n          this.sidebarOpen = !this.sidebarOpen;\n        } else {\n          this.sidebarCollapsed = !this.sidebarCollapsed;\n          localStorage.setItem('sidebarCollapsed', this.sidebarCollapsed);\n        }\n      }\n    }\"\n    @keydown.escape.window=\"if(window.innerWidth < 1024) sidebarOpen = false\"\n    class=\"min-h-screen flex\"\n  >\n    <!-- Sidebar Overlay (Mobile) -->\n    <div\n      x-show=\"sidebarOpen && window.innerWidth < 1024\"\n      x-transition:enter=\"transition-opacity ease-out duration-300\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      x-transition:leave=\"transition-opacity ease-in duration-200\"\n      x-transition:leave-start=\"opacity-100\"\n      x-transition:leave-end=\"opacity-0\"\n      @click=\"sidebarOpen = false\"\n      class=\"fixed inset-0 z-40 bg-black/50 lg:hidden\"\n      aria-hidden=\"true\"\n    ></div>\n\n    <!-- Sidebar -->\n    <%- include('../components/sidebar', {\n      user: locals.user,\n      organization: locals.organization,\n      currentPath: locals.currentPath,\n      navigation: locals.navigation\n    }) %>\n\n    <!-- Main Content Area -->\n    <div\n      class=\"flex-1 flex flex-col min-w-0 transition-all duration-300\"\n      :class=\"{ 'lg:ml-64': !sidebarCollapsed, 'lg:ml-20': sidebarCollapsed }\"\n    >\n      <!-- Header -->\n      <%- include('../components/header', {\n        user: locals.user,\n        organization: locals.organization,\n        notifications: locals.notifications,\n        breadcrumbs: locals.breadcrumbs\n      }) %>\n\n      <!-- Page Content -->\n      <main id=\"main-content\" role=\"main\" class=\"flex-1 p-4 md:p-6 lg:p-8\">\n        <!-- Alerts/Flash Messages -->\n        <% if (locals.flash) { %>\n          <% if (flash.success) { %>\n            <div role=\"alert\" class=\"alert alert-success mb-4\">\n              <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n              <span><%= flash.success %></span>\n              <button type=\"button\" class=\"alert-close\" aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\">\n                <i class=\"ph ph-x\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n          <% } %>\n          <% if (flash.error) { %>\n            <div role=\"alert\" class=\"alert alert-error mb-4\">\n              <i class=\"ph ph-warning-circle\" aria-hidden=\"true\"></i>\n              <span><%= flash.error %></span>\n              <button type=\"button\" class=\"alert-close\" aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\">\n                <i class=\"ph ph-x\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n          <% } %>\n          <% if (flash.warning) { %>\n            <div role=\"alert\" class=\"alert alert-warning mb-4\">\n              <i class=\"ph ph-warning\" aria-hidden=\"true\"></i>\n              <span><%= flash.warning %></span>\n              <button type=\"button\" class=\"alert-close\" aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\">\n                <i class=\"ph ph-x\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n          <% } %>\n          <% if (flash.info) { %>\n            <div role=\"alert\" class=\"alert alert-info mb-4\">\n              <i class=\"ph ph-info\" aria-hidden=\"true\"></i>\n              <span><%= flash.info %></span>\n              <button type=\"button\" class=\"alert-close\" aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\">\n                <i class=\"ph ph-x\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n          <% } %>\n        <% } %>\n\n        <!-- Page Title and Actions -->\n        <% if (locals.pageTitle) { %>\n          <div class=\"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6\">\n            <div>\n              <h1 class=\"text-2xl md:text-3xl font-bold text-text-primary\">\n                <%= pageTitle %>\n              </h1>\n              <% if (locals.pageDescription) { %>\n                <p class=\"mt-1 text-sm text-text-secondary\"><%= pageDescription %></p>\n              <% } %>\n            </div>\n            <% if (locals.pageActions) { %>\n              <div class=\"flex flex-wrap gap-2\">\n                <%- pageActions %>\n              </div>\n            <% } %>\n          </div>\n        <% } %>\n\n        <!-- Main Content (Slot) -->\n        <%- body %>\n      </main>\n\n      <!-- Footer -->\n      <%- include('../components/footer', {\n        version: locals.version,\n        organization: locals.organization\n      }) %>\n    </div>\n  </div>\n\n  <!-- Extra Scripts -->\n  <% if (locals.extraScripts) { %>\n    <% extraScripts.forEach(function(script) { %>\n      <script src=\"<%= script %>\"></script>\n    <% }); %>\n  <% } %>\n\n  <!-- Inline Scripts -->\n  <script>\n    // Alert dismiss functionality\n    document.querySelectorAll('.alert-close').forEach(function(btn) {\n      btn.addEventListener('click', function() {\n        this.closest('.alert').remove();\n      });\n    });\n\n    // Auto-dismiss alerts after 5 seconds (except errors)\n    document.querySelectorAll('.alert:not(.alert-error)').forEach(function(alert) {\n      setTimeout(function() {\n        alert.style.opacity = '0';\n        setTimeout(function() {\n          alert.remove();\n        }, 300);\n      }, 5000);\n    });\n  </script>\n\n  <% if (locals.inlineScript) { %>\n    <script><%= inlineScript %></script>\n  <% } %>\n</body>\n</html>\n",
        "last_modified": "2026-02-01T09:10:53.778036"
      },
