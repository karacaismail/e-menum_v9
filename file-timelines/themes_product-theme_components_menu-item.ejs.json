        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Menu Item Component - Product Theme\n\n  Displays a single product card with image, name, description, price, and add-to-cart functionality.\n\n  Variables:\n  - product: Product object {id, name, description, price, image, allergens[], badges[], variants[], modifiers[], available}\n  - showImage: Boolean to show/hide image (default: true)\n  - compact: Boolean for compact layout (default: false)\n%>\n<%\n  const showImage = locals.showImage !== false;\n  const compact = locals.compact === true;\n  const product = locals.product || {};\n  const isAvailable = product.available !== false;\n%>\n\n<article\n  x-data=\"{\n    product: <%- JSON.stringify(product) %>,\n    quantity: 1,\n    selectedVariants: [],\n    selectedModifiers: [],\n    showModal: false,\n\n    get totalPrice() {\n      let price = this.product.price || 0;\n      this.selectedVariants.forEach(v => price += v.priceModifier || 0);\n      this.selectedModifiers.forEach(m => price += m.price || 0);\n      return price * this.quantity;\n    },\n\n    addProductToCart() {\n      addToCart(this.product, this.quantity, this.selectedVariants, this.selectedModifiers);\n      this.showModal = false;\n      this.quantity = 1;\n      this.selectedVariants = [];\n      this.selectedModifiers = [];\n    },\n\n    hasOptions() {\n      return (this.product.variants && this.product.variants.length > 0) ||\n             (this.product.modifiers && this.product.modifiers.length > 0);\n    }\n  }\"\n  class=\"product-card group <%= compact ? 'product-card-compact' : '' %> <%= !isAvailable ? 'product-card-unavailable' : '' %>\"\n  role=\"article\"\n  aria-labelledby=\"product-name-<%= product.id %>\"\n>\n  <% if (showImage) { %>\n    <!-- Product Image -->\n    <div class=\"product-card-image\">\n      <% if (product.image) { %>\n        <img\n          src=\"<%= product.image %>\"\n          alt=\"\"\n          loading=\"lazy\"\n          class=\"w-full h-full object-cover transition-transform duration-300 group-hover:scale-105\"\n        >\n      <% } else { %>\n        <div class=\"w-full h-full bg-surface-elevated flex items-center justify-center\">\n          <i class=\"ph ph-bowl-food text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n        </div>\n      <% } %>\n\n      <!-- Badges -->\n      <% if (product.badges && product.badges.length > 0) { %>\n        <div class=\"absolute top-2 left-2 flex flex-col gap-1\">\n          <% product.badges.slice(0, 3).forEach(function(badge) { %>\n            <span class=\"badge badge-<%= badge.type || 'primary' %> shadow-sm\">\n              <% if (badge.icon) { %><i class=\"ph ph-<%= badge.icon %>\" aria-hidden=\"true\"></i><% } %>\n              <%= badge.label %>\n            </span>\n          <% }); %>\n        </div>\n      <% } %>\n\n      <!-- Unavailable Overlay -->\n      <% if (!isAvailable) { %>\n        <div class=\"absolute inset-0 bg-black/50 flex items-center justify-center\">\n          <span class=\"badge badge-neutral text-sm\">\n            <%= typeof t === 'function' ? t('product.unavailable') : 'Unavailable' %>\n          </span>\n        </div>\n      <% } %>\n    </div>\n  <% } %>\n\n  <!-- Product Info -->\n  <div class=\"product-card-body\">\n    <div class=\"flex-1 min-w-0\">\n      <!-- Name -->\n      <h3\n        id=\"product-name-<%= product.id %>\"\n        class=\"text-base font-semibold text-text-primary line-clamp-2\"\n      >\n        <%= product.name %>\n      </h3>\n\n      <!-- Description -->\n      <% if (product.description && !compact) { %>\n        <p class=\"mt-1 text-sm text-text-secondary line-clamp-2\">\n          <%= product.description %>\n        </p>\n      <% } %>\n\n      <!-- Allergens -->\n      <% if (product.allergens && product.allergens.length > 0 && !compact) { %>\n        <div class=\"mt-2 flex flex-wrap gap-1\">\n          <% product.allergens.slice(0, 4).forEach(function(allergen) { %>\n            <span\n              class=\"inline-flex items-center gap-1 px-1.5 py-0.5 text-xs rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400\"\n              title=\"<%= allergen.name %>\"\n            >\n              <% if (allergen.icon) { %>\n                <i class=\"ph ph-<%= allergen.icon %>\" aria-hidden=\"true\"></i>\n              <% } %>\n              <span><%= allergen.code || allergen.name %></span>\n            </span>\n          <% }); %>\n          <% if (product.allergens.length > 4) { %>\n            <span class=\"text-xs text-text-muted\">+<%= product.allergens.length - 4 %></span>\n          <% } %>\n        </div>\n      <% } %>\n    </div>\n\n    <!-- Price and Add Button -->\n    <div class=\"flex items-center justify-between gap-3 mt-3\">\n      <div class=\"flex flex-col\">\n        <span class=\"text-lg font-bold text-brand-primary\">\n          <span x-text=\"formatPrice(product.price)\"><%= product.price ? `${product.price.toFixed(2)} TL` : '' %></span>\n        </span>\n        <% if (product.variants && product.variants.length > 0) { %>\n          <span class=\"text-xs text-text-muted\">\n            <%= typeof t === 'function' ? t('product.from') : 'from' %>\n          </span>\n        <% } %>\n      </div>\n\n      <% if (isAvailable) { %>\n        <button\n          type=\"button\"\n          @click=\"hasOptions() ? showModal = true : addProductToCart()\"\n          class=\"btn btn-primary btn-sm flex-shrink-0\"\n          aria-label=\"<%= typeof t === 'function' ? t('cart.addItem', {item: product.name}) : 'Add ' + product.name + ' to cart' %>\"\n        >\n          <i class=\"ph ph-plus\" aria-hidden=\"true\"></i>\n          <span class=\"hidden sm:inline\"><%= typeof t === 'function' ? t('cart.add') : 'Add' %></span>\n        </button>\n      <% } else { %>\n        <span class=\"text-sm text-text-muted italic\">\n          <%= typeof t === 'function' ? t('product.outOfStock') : 'Out of stock' %>\n        </span>\n      <% } %>\n    </div>\n  </div>\n\n  <!-- Product Details Modal (for variants/modifiers) -->\n  <template x-if=\"showModal\">\n    <div\n      x-show=\"showModal\"\n      x-transition:enter=\"transition ease-out duration-200\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      x-transition:leave=\"transition ease-in duration-150\"\n      x-transition:leave-start=\"opacity-100\"\n      x-transition:leave-end=\"opacity-0\"\n      @click.self=\"showModal = false\"\n      @keydown.escape.window=\"showModal = false\"\n      class=\"fixed inset-0 z-50 flex items-end sm:items-center justify-center bg-black/50 p-0 sm:p-4\"\n      role=\"dialog\"\n      aria-modal=\"true\"\n      :aria-labelledby=\"'modal-title-' + product.id\"\n    >\n      <div\n        x-transition:enter=\"transition ease-out duration-200\"\n        x-transition:enter-start=\"opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95\"\n        x-transition:enter-end=\"opacity-100 translate-y-0 sm:scale-100\"\n        x-transition:leave=\"transition ease-in duration-150\"\n        x-transition:leave-start=\"opacity-100 translate-y-0 sm:scale-100\"\n        x-transition:leave-end=\"opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95\"\n        class=\"w-full max-w-lg max-h-[90vh] bg-surface-card rounded-t-2xl sm:rounded-2xl overflow-hidden flex flex-col\"\n      >\n        <!-- Modal Header -->\n        <div class=\"flex items-start gap-4 p-4 border-b border-border-color\">\n          <% if (product.image) { %>\n            <img\n              :src=\"product.image\"\n              alt=\"\"\n              class=\"w-20 h-20 rounded-lg object-cover flex-shrink-0\"\n            >\n          <% } %>\n          <div class=\"flex-1 min-w-0\">\n            <h2 :id=\"'modal-title-' + product.id\" class=\"text-lg font-semibold text-text-primary\" x-text=\"product.name\"></h2>\n            <p class=\"mt-1 text-sm text-text-secondary line-clamp-2\" x-text=\"product.description\"></p>\n          </div>\n          <button\n            type=\"button\"\n            @click=\"showModal = false\"\n            class=\"btn btn-ghost btn-icon -mt-1 -mr-1\"\n            aria-label=\"<%= typeof t === 'function' ? t('common.close') : 'Close' %>\"\n          >\n            <i class=\"ph ph-x text-xl\" aria-hidden=\"true\"></i>\n          </button>\n        </div>\n\n        <!-- Modal Body -->\n        <div class=\"flex-1 overflow-y-auto p-4 space-y-4\">\n          <!-- Variants -->\n          <template x-if=\"product.variants && product.variants.length > 0\">\n            <fieldset>\n              <legend class=\"text-sm font-semibold text-text-primary mb-2\">\n                <%= typeof t === 'function' ? t('product.chooseOption') : 'Choose an option' %>\n              </legend>\n              <div class=\"space-y-2\">\n                <template x-for=\"variant in product.variants\" :key=\"variant.id\">\n                  <label class=\"flex items-center gap-3 p-3 border border-border-color rounded-lg cursor-pointer hover:bg-surface-elevated transition-colors\">\n                    <input\n                      type=\"radio\"\n                      :name=\"'variant-' + product.id\"\n                      :value=\"JSON.stringify(variant)\"\n                      @change=\"selectedVariants = [variant]\"\n                      class=\"form-radio\"\n                    >\n                    <span class=\"flex-1 text-sm font-medium text-text-primary\" x-text=\"variant.name\"></span>\n                    <span class=\"text-sm text-text-secondary\" x-text=\"variant.priceModifier > 0 ? '+' + formatPrice(variant.priceModifier) : ''\"></span>\n                  </label>\n                </template>\n              </div>\n            </fieldset>\n          </template>\n\n          <!-- Modifiers -->\n          <template x-if=\"product.modifiers && product.modifiers.length > 0\">\n            <fieldset>\n              <legend class=\"text-sm font-semibold text-text-primary mb-2\">\n                <%= typeof t === 'function' ? t('product.extras') : 'Extras' %>\n              </legend>\n              <div class=\"space-y-2\">\n                <template x-for=\"modifier in product.modifiers\" :key=\"modifier.id\">\n                  <label class=\"flex items-center gap-3 p-3 border border-border-color rounded-lg cursor-pointer hover:bg-surface-elevated transition-colors\">\n                    <input\n                      type=\"checkbox\"\n                      :value=\"JSON.stringify(modifier)\"\n                      @change=\"$event.target.checked ? selectedModifiers.push(modifier) : selectedModifiers = selectedModifiers.filter(m => m.id !== modifier.id)\"\n                      class=\"form-checkbox\"\n                    >\n                    <span class=\"flex-1 text-sm font-medium text-text-primary\" x-text=\"modifier.name\"></span>\n                    <span class=\"text-sm text-text-secondary\" x-text=\"'+' + formatPrice(modifier.price)\"></span>\n                  </label>\n                </template>\n              </div>\n            </fieldset>\n          </template>\n\n          <!-- Quantity Selector -->\n          <div class=\"flex items-center gap-4\">\n            <span class=\"text-sm font-semibold text-text-primary\">\n              <%= typeof t === 'function' ? t('product.quantity') : 'Quantity' %>\n            </span>\n            <div class=\"flex items-center gap-2 ml-auto\">\n              <button\n                type=\"button\"\n                @click=\"quantity = Math.max(1, quantity - 1)\"\n                class=\"btn btn-secondary btn-icon btn-sm\"\n                :disabled=\"quantity <= 1\"\n                aria-label=\"<%= typeof t === 'function' ? t('common.decrease') : 'Decrease' %>\"\n              >\n                <i class=\"ph ph-minus\" aria-hidden=\"true\"></i>\n              </button>\n              <span class=\"w-10 text-center font-semibold text-text-primary\" x-text=\"quantity\"></span>\n              <button\n                type=\"button\"\n                @click=\"quantity = Math.min(99, quantity + 1)\"\n                class=\"btn btn-secondary btn-icon btn-sm\"\n                :disabled=\"quantity >= 99\"\n                aria-label=\"<%= typeof t === 'function' ? t('common.increase') : 'Increase' %>\"\n              >\n                <i class=\"ph ph-plus\" aria-hidden=\"true\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <!-- Modal Footer -->\n        <div class=\"p-4 border-t border-border-color bg-surface-elevated\">\n          <button\n            type=\"button\"\n            @click=\"addProductToCart()\"\n            class=\"btn btn-primary w-full py-3 text-base\"\n          >\n            <i class=\"ph ph-shopping-cart\" aria-hidden=\"true\"></i>\n            <span><%= typeof t === 'function' ? t('cart.addToCart') : 'Add to Cart' %></span>\n            <span class=\"ml-auto font-bold\" x-text=\"formatPrice(totalPrice)\"></span>\n          </button>\n        </div>\n      </div>\n    </div>\n  </template>\n</article>\n",
        "last_modified": "2026-02-01T09:10:53.783314"
      },
