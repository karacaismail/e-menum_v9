      "branch_point": {
        "commit_hash": "e2c14236dedadbadc7b19d123890e3f98e7316c0",
        "content": "",
        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Menus List View\n\n  Variables:\n  - menus: Array of menu objects\n  - pagination: { page, perPage, total, totalPages }\n  - filters: { search, status }\n%>\n\n<!-- Filters and Search -->\n<div class=\"card p-4 mb-6\">\n  <form action=\"/admin/menus\" method=\"GET\" class=\"flex flex-col sm:flex-row gap-4\">\n    <!-- Search -->\n    <div class=\"flex-1 relative\">\n      <label for=\"search\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('common.search') : 'Search' %>\n      </label>\n      <i class=\"ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-text-muted\" aria-hidden=\"true\"></i>\n      <input\n        type=\"search\"\n        id=\"search\"\n        name=\"search\"\n        value=\"<%= locals.filters ? filters.search : '' %>\"\n        placeholder=\"<%= typeof t === 'function' ? t('menus.searchPlaceholder') : 'Search menus...' %>\"\n        class=\"form-input pl-10 w-full\"\n      >\n    </div>\n\n    <!-- Status Filter -->\n    <div class=\"sm:w-48\">\n      <label for=\"status\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('common.status') : 'Status' %>\n      </label>\n      <select id=\"status\" name=\"status\" class=\"form-select w-full\">\n        <option value=\"\"><%= typeof t === 'function' ? t('menus.allStatuses') : 'All Statuses' %></option>\n        <option value=\"draft\" <%= locals.filters && filters.status === 'draft' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('menus.status.draft') : 'Draft' %>\n        </option>\n        <option value=\"published\" <%= locals.filters && filters.status === 'published' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('menus.status.published') : 'Published' %>\n        </option>\n        <option value=\"archived\" <%= locals.filters && filters.status === 'archived' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('menus.status.archived') : 'Archived' %>\n        </option>\n      </select>\n    </div>\n\n    <!-- Filter Button -->\n    <button type=\"submit\" class=\"btn btn-secondary\">\n      <i class=\"ph ph-funnel mr-2\" aria-hidden=\"true\"></i>\n      <%= typeof t === 'function' ? t('common.filter') : 'Filter' %>\n    </button>\n  </form>\n</div>\n\n<% if (!locals.menus || menus.length === 0) { %>\n  <!-- Empty State -->\n  <div class=\"card p-8 text-center\">\n    <div class=\"w-20 h-20 mx-auto rounded-full bg-surface-elevated flex items-center justify-center mb-4\">\n      <i class=\"ph ph-book-open text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n    </div>\n    <h3 class=\"text-xl font-semibold text-text-primary mb-2\">\n      <%= typeof t === 'function' ? t('menus.noMenusYet') : 'No menus yet' %>\n    </h3>\n    <p class=\"text-text-muted mb-6 max-w-md mx-auto\">\n      <%= typeof t === 'function' ? t('menus.createFirstMenu') : 'Create your first digital menu to start receiving orders from customers.' %>\n    </p>\n    <a href=\"/admin/menus/create\" class=\"btn btn-primary\">\n      <i class=\"ph ph-plus mr-2\" aria-hidden=\"true\"></i>\n      <%= typeof t === 'function' ? t('menus.createMenu') : 'Create Menu' %>\n    </a>\n  </div>\n<% } else { %>\n  <!-- Menus Grid -->\n  <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6\">\n    <% menus.forEach(function(menu) { %>\n      <div class=\"card overflow-hidden group\">\n        <!-- Menu Cover Image -->\n        <div class=\"aspect-video bg-surface-elevated relative overflow-hidden\">\n          <% if (menu.coverImage) { %>\n            <img\n              src=\"<%= menu.coverImage %>\"\n              alt=\"<%= menu.name %>\"\n              class=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-300\"\n            >\n          <% } else { %>\n            <div class=\"w-full h-full flex items-center justify-center\">\n              <i class=\"ph ph-image text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n            </div>\n          <% } %>\n\n          <!-- Status Badge -->\n          <%\n            const statusStyles = {\n              draft: 'bg-gray-900/80 text-gray-100',\n              published: 'bg-green-600/90 text-white',\n              archived: 'bg-yellow-600/90 text-white'\n            };\n            const statusStyle = statusStyles[menu.status] || statusStyles.draft;\n          %>\n          <span class=\"absolute top-3 right-3 px-2.5 py-1 rounded-full text-xs font-medium <%= statusStyle %>\">\n            <%= typeof t === 'function' ? t('menus.status.' + menu.status) : menu.status %>\n          </span>\n\n          <!-- Quick Actions Overlay -->\n          <div class=\"absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-2\">\n            <a\n              href=\"/admin/menus/<%= menu.id %>/edit\"\n              class=\"btn btn-sm bg-white text-gray-900 hover:bg-gray-100\"\n            >\n              <i class=\"ph ph-pencil mr-1\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('common.edit') : 'Edit' %>\n            </a>\n            <a\n              href=\"/m/<%= menu.slug %>\"\n              target=\"_blank\"\n              class=\"btn btn-sm bg-white text-gray-900 hover:bg-gray-100\"\n            >\n              <i class=\"ph ph-eye mr-1\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('common.preview') : 'Preview' %>\n            </a>\n          </div>\n        </div>\n\n        <!-- Menu Info -->\n        <div class=\"p-4\">\n          <div class=\"flex items-start justify-between gap-2\">\n            <div>\n              <h3 class=\"font-semibold text-text-primary truncate\">\n                <a href=\"/admin/menus/<%= menu.id %>\" class=\"hover:text-brand-primary\">\n                  <%= menu.name %>\n                </a>\n              </h3>\n              <p class=\"text-sm text-text-muted mt-1\">\n                <%= menu.categoryCount %> <%= typeof t === 'function' ? t('menus.categories') : 'categories' %> &middot;\n                <%= menu.productCount %> <%= typeof t === 'function' ? t('menus.products') : 'products' %>\n              </p>\n            </div>\n\n            <!-- Menu Dropdown -->\n            <div x-data=\"{ open: false }\" class=\"relative\">\n              <button\n                @click=\"open = !open\"\n                @click.outside=\"open = false\"\n                type=\"button\"\n                class=\"btn btn-ghost btn-sm btn-icon\"\n                aria-label=\"<%= typeof t === 'function' ? t('common.moreActions') : 'More actions' %>\"\n              >\n                <i class=\"ph ph-dots-three-vertical\" aria-hidden=\"true\"></i>\n              </button>\n\n              <div\n                x-show=\"open\"\n                x-transition:enter=\"transition ease-out duration-100\"\n                x-transition:enter-start=\"opacity-0 scale-95\"\n                x-transition:enter-end=\"opacity-100 scale-100\"\n                x-transition:leave=\"transition ease-in duration-75\"\n                x-transition:leave-start=\"opacity-100 scale-100\"\n                x-transition:leave-end=\"opacity-0 scale-95\"\n                class=\"absolute right-0 mt-1 w-48 bg-surface-card rounded-lg shadow-lg border border-border-color overflow-hidden z-10\"\n              >\n                <a\n                  href=\"/admin/menus/<%= menu.id %>/edit\"\n                  class=\"flex items-center gap-2 px-4 py-2 text-sm hover:bg-surface-elevated\"\n                >\n                  <i class=\"ph ph-pencil text-text-muted\" aria-hidden=\"true\"></i>\n                  <%= typeof t === 'function' ? t('common.edit') : 'Edit' %>\n                </a>\n                <a\n                  href=\"/admin/menus/<%= menu.id %>/duplicate\"\n                  class=\"flex items-center gap-2 px-4 py-2 text-sm hover:bg-surface-elevated\"\n                >\n                  <i class=\"ph ph-copy text-text-muted\" aria-hidden=\"true\"></i>\n                  <%= typeof t === 'function' ? t('common.duplicate') : 'Duplicate' %>\n                </a>\n                <a\n                  href=\"/admin/qr-codes/generate?menuId=<%= menu.id %>\"\n                  class=\"flex items-center gap-2 px-4 py-2 text-sm hover:bg-surface-elevated\"\n                >\n                  <i class=\"ph ph-qr-code text-text-muted\" aria-hidden=\"true\"></i>\n                  <%= typeof t === 'function' ? t('menus.generateQR') : 'Generate QR' %>\n                </a>\n                <hr class=\"border-border-color\">\n                <% if (menu.status === 'draft') { %>\n                  <form action=\"/admin/menus/<%= menu.id %>/publish\" method=\"POST\">\n                    <button\n                      type=\"submit\"\n                      class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20\"\n                    >\n                      <i class=\"ph ph-globe\" aria-hidden=\"true\"></i>\n                      <%= typeof t === 'function' ? t('menus.publish') : 'Publish' %>\n                    </button>\n                  </form>\n                <% } else if (menu.status === 'published') { %>\n                  <form action=\"/admin/menus/<%= menu.id %>/unpublish\" method=\"POST\">\n                    <button\n                      type=\"submit\"\n                      class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-yellow-600 dark:text-yellow-400 hover:bg-yellow-50 dark:hover:bg-yellow-900/20\"\n                    >\n                      <i class=\"ph ph-eye-slash\" aria-hidden=\"true\"></i>\n                      <%= typeof t === 'function' ? t('menus.unpublish') : 'Unpublish' %>\n                    </button>\n                  </form>\n                <% } %>\n                <hr class=\"border-border-color\">\n                <form\n                  action=\"/admin/menus/<%= menu.id %>/delete\"\n                  method=\"POST\"\n                  onsubmit=\"return confirm('<%= typeof t === 'function' ? t('menus.confirmDelete') : 'Are you sure you want to delete this menu?' %>')\"\n                >\n                  <button\n                    type=\"submit\"\n                    class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20\"\n                  >\n                    <i class=\"ph ph-trash\" aria-hidden=\"true\"></i>\n                    <%= typeof t === 'function' ? t('common.delete') : 'Delete' %>\n                  </button>\n                </form>\n              </div>\n            </div>\n          </div>\n\n          <!-- Menu Stats -->\n          <div class=\"flex items-center gap-4 mt-4 pt-4 border-t border-border-color text-xs text-text-muted\">\n            <span class=\"flex items-center gap-1\">\n              <i class=\"ph ph-eye\" aria-hidden=\"true\"></i>\n              <%= menu.viewCount || 0 %> <%= typeof t === 'function' ? t('menus.views') : 'views' %>\n            </span>\n            <span class=\"flex items-center gap-1\">\n              <i class=\"ph ph-shopping-cart\" aria-hidden=\"true\"></i>\n              <%= menu.orderCount || 0 %> <%= typeof t === 'function' ? t('menus.orders') : 'orders' %>\n            </span>\n            <% if (menu.lastUpdated) { %>\n              <span class=\"ml-auto\">\n                <%= typeof t === 'function' ? t('common.updated') : 'Updated' %>\n                <%= new Date(menu.lastUpdated).toLocaleDateString(locals.lang || 'tr-TR') %>\n              </span>\n            <% } %>\n          </div>\n        </div>\n      </div>\n    <% }); %>\n  </div>\n\n  <!-- Pagination -->\n  <% if (locals.pagination && pagination.totalPages > 1) { %>\n    <nav class=\"mt-6 flex items-center justify-between\" aria-label=\"<%= typeof t === 'function' ? t('common.pagination') : 'Pagination' %>\">\n      <p class=\"text-sm text-text-muted\">\n        <%= typeof t === 'function' ? t('common.showing') : 'Showing' %>\n        <span class=\"font-medium\"><%= (pagination.page - 1) * pagination.perPage + 1 %></span>\n        <%= typeof t === 'function' ? t('common.to') : 'to' %>\n        <span class=\"font-medium\"><%= Math.min(pagination.page * pagination.perPage, pagination.total) %></span>\n        <%= typeof t === 'function' ? t('common.of') : 'of' %>\n        <span class=\"font-medium\"><%= pagination.total %></span>\n        <%= typeof t === 'function' ? t('common.results') : 'results' %>\n      </p>\n\n      <div class=\"flex items-center gap-2\">\n        <% if (pagination.page > 1) { %>\n          <a\n            href=\"?page=<%= pagination.page - 1 %><%= locals.filters && filters.search ? '&search=' + filters.search : '' %><%= locals.filters && filters.status ? '&status=' + filters.status : '' %>\"\n            class=\"btn btn-ghost btn-sm\"\n          >\n            <i class=\"ph ph-caret-left mr-1\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('common.previous') : 'Previous' %>\n          </a>\n        <% } %>\n\n        <% for (let i = 1; i <= pagination.totalPages; i++) { %>\n          <% if (i === pagination.page) { %>\n            <span class=\"btn btn-primary btn-sm\" aria-current=\"page\"><%= i %></span>\n          <% } else if (i === 1 || i === pagination.totalPages || (i >= pagination.page - 1 && i <= pagination.page + 1)) { %>\n            <a\n              href=\"?page=<%= i %><%= locals.filters && filters.search ? '&search=' + filters.search : '' %><%= locals.filters && filters.status ? '&status=' + filters.status : '' %>\"\n              class=\"btn btn-ghost btn-sm\"\n            >\n              <%= i %>\n            </a>\n          <% } else if (i === pagination.page - 2 || i === pagination.page + 2) { %>\n            <span class=\"text-text-muted\">...</span>\n          <% } %>\n        <% } %>\n\n        <% if (pagination.page < pagination.totalPages) { %>\n          <a\n            href=\"?page=<%= pagination.page + 1 %><%= locals.filters && filters.search ? '&search=' + filters.search : '' %><%= locals.filters && filters.status ? '&status=' + filters.status : '' %>\"\n            class=\"btn btn-ghost btn-sm\"\n          >\n            <%= typeof t === 'function' ? t('common.next') : 'Next' %>\n            <i class=\"ph ph-caret-right ml-1\" aria-hidden=\"true\"></i>\n          </a>\n        <% } %>\n      </div>\n    </nav>\n  <% } %>\n<% } %>\n",
