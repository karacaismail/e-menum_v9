      "worktree_state": {
        "content": "<!DOCTYPE html>\n<html lang=\"<%= locals.lang || 'tr' %>\" data-theme=\"<%= locals.theme || 'light' %>\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"<%= locals.metaDescription || 'E-Menum - Enterprise QR Menu Platform' %>\">\n  <meta name=\"robots\" content=\"noindex, nofollow\">\n\n  <title><%= locals.pageTitle ? `${locals.pageTitle} | ` : '' %>E-Menum</title>\n\n  <!-- Favicon -->\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/images/apple-touch-icon.png\">\n\n  <!-- Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n  <!-- Icons - Phosphor Icons -->\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/regular/style.css\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/bold/style.css\">\n\n  <!-- Main Stylesheet -->\n  <link rel=\"stylesheet\" href=\"/themes/admin-theme/styles/main.css\">\n  <% if (locals.extraStyles) { %>\n    <% extraStyles.forEach(function(style) { %>\n      <link rel=\"stylesheet\" href=\"<%= style %>\">\n    <% }); %>\n  <% } %>\n\n  <!-- Alpine.js -->\n  <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n\n  <!-- Theme Toggle Script -->\n  <script>\n    (function() {\n      const savedTheme = localStorage.getItem('theme');\n      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;\n      const theme = savedTheme || (prefersDark ? 'dark' : 'light');\n      document.documentElement.setAttribute('data-theme', theme);\n    })();\n  </script>\n</head>\n<body class=\"bg-surface-background text-text-primary font-sans antialiased\">\n  <!-- Skip Link -->\n  <a href=\"#main-content\" class=\"skip-link\">\n    <%= typeof t === 'function' ? t('common.skipToContent') : 'Skip to main content' %>\n  </a>\n\n  <!-- Live Region for Announcements -->\n  <div aria-live=\"polite\" aria-atomic=\"true\" class=\"sr-only\" id=\"sr-announcements\"></div>\n\n  <!-- Auth Layout Container -->\n  <div class=\"min-h-screen flex flex-col\">\n    <!-- Header -->\n    <header class=\"flex-shrink-0 py-4 px-4 md:px-6\">\n      <div class=\"max-w-7xl mx-auto flex items-center justify-between\">\n        <!-- Logo -->\n        <a href=\"/\" class=\"flex items-center gap-2 group\" aria-label=\"<%= typeof t === 'function' ? t('common.goHome') : 'Go to home page' %>\">\n          <div class=\"w-10 h-10 rounded-lg bg-brand-primary flex items-center justify-center\">\n            <span class=\"text-white font-bold text-xl\">E</span>\n          </div>\n          <span class=\"text-xl font-bold text-text-primary group-hover:text-brand-primary transition-colors\">\n            E-Menum\n          </span>\n        </a>\n\n        <!-- Theme Toggle and Language -->\n        <div class=\"flex items-center gap-3\">\n          <!-- Language Switcher -->\n          <% if (locals.languages) { %>\n            <div x-data=\"{ open: false }\" class=\"relative\">\n              <button\n                @click=\"open = !open\"\n                @click.outside=\"open = false\"\n                type=\"button\"\n                class=\"btn btn-ghost btn-sm\"\n                aria-expanded=\"false\"\n                aria-haspopup=\"true\"\n                :aria-expanded=\"open\"\n              >\n                <i class=\"ph ph-globe\" aria-hidden=\"true\"></i>\n                <span class=\"hidden sm:inline\"><%= locals.currentLang === 'tr' ? 'TR' : 'EN' %></span>\n                <i class=\"ph ph-caret-down text-xs\" aria-hidden=\"true\"></i>\n              </button>\n              <div\n                x-show=\"open\"\n                x-transition:enter=\"transition ease-out duration-100\"\n                x-transition:enter-start=\"opacity-0 scale-95\"\n                x-transition:enter-end=\"opacity-100 scale-100\"\n                x-transition:leave=\"transition ease-in duration-75\"\n                x-transition:leave-start=\"opacity-100 scale-100\"\n                x-transition:leave-end=\"opacity-0 scale-95\"\n                class=\"absolute right-0 mt-2 w-32 bg-surface-card rounded-lg shadow-lg border border-border-color overflow-hidden z-50\"\n                role=\"menu\"\n              >\n                <a href=\"?lang=tr\" class=\"block px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n                  <span class=\"fi fi-tr mr-2\"></span> T\u00fcrk\u00e7e\n                </a>\n                <a href=\"?lang=en\" class=\"block px-4 py-2 text-sm hover:bg-surface-elevated\" role=\"menuitem\">\n                  <span class=\"fi fi-gb mr-2\"></span> English\n                </a>\n              </div>\n            </div>\n          <% } %>\n\n          <!-- Theme Toggle -->\n          <button\n            x-data=\"{ dark: document.documentElement.getAttribute('data-theme') === 'dark' }\"\n            @click=\"dark = !dark; document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light'); localStorage.setItem('theme', dark ? 'dark' : 'light')\"\n            type=\"button\"\n            class=\"btn btn-ghost btn-icon\"\n            :aria-label=\"dark ? '<%= typeof t === 'function' ? t('common.lightMode') : 'Switch to light mode' %>' : '<%= typeof t === 'function' ? t('common.darkMode') : 'Switch to dark mode' %>'\"\n          >\n            <i x-show=\"!dark\" class=\"ph ph-moon\" aria-hidden=\"true\"></i>\n            <i x-show=\"dark\" class=\"ph ph-sun\" aria-hidden=\"true\"></i>\n          </button>\n        </div>\n      </div>\n    </header>\n\n    <!-- Main Content -->\n    <main id=\"main-content\" role=\"main\" class=\"flex-1 flex items-center justify-center p-4 md:p-6\">\n      <div class=\"w-full max-w-md\">\n        <!-- Flash Messages -->\n        <% if (locals.flash) { %>\n          <% if (flash.success) { %>\n            <div role=\"alert\" class=\"alert alert-success mb-6\">\n              <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n              <span><%= flash.success %></span>\n            </div>\n          <% } %>\n          <% if (flash.error) { %>\n            <div role=\"alert\" class=\"alert alert-error mb-6\">\n              <i class=\"ph ph-warning-circle\" aria-hidden=\"true\"></i>\n              <span><%= flash.error %></span>\n            </div>\n          <% } %>\n          <% if (flash.warning) { %>\n            <div role=\"alert\" class=\"alert alert-warning mb-6\">\n              <i class=\"ph ph-warning\" aria-hidden=\"true\"></i>\n              <span><%= flash.warning %></span>\n            </div>\n          <% } %>\n          <% if (flash.info) { %>\n            <div role=\"alert\" class=\"alert alert-info mb-6\">\n              <i class=\"ph ph-info\" aria-hidden=\"true\"></i>\n              <span><%= flash.info %></span>\n            </div>\n          <% } %>\n        <% } %>\n\n        <!-- Auth Card -->\n        <div class=\"card\">\n          <div class=\"card-body p-6 md:p-8\">\n            <!-- Page Header -->\n            <% if (locals.pageTitle) { %>\n              <div class=\"text-center mb-6\">\n                <h1 class=\"text-2xl font-bold text-text-primary\">\n                  <%= pageTitle %>\n                </h1>\n                <% if (locals.pageDescription) { %>\n                  <p class=\"mt-2 text-sm text-text-secondary\">\n                    <%= pageDescription %>\n                  </p>\n                <% } %>\n              </div>\n            <% } %>\n\n            <!-- Content Slot -->\n            <%- body %>\n          </div>\n        </div>\n\n        <!-- Additional Links -->\n        <% if (locals.authLinks) { %>\n          <div class=\"mt-6 text-center text-sm text-text-secondary\">\n            <%- authLinks %>\n          </div>\n        <% } %>\n      </div>\n    </main>\n\n    <!-- Footer -->\n    <footer class=\"flex-shrink-0 py-4 px-4 text-center\">\n      <p class=\"text-sm text-text-muted\">\n        &copy; <%= new Date().getFullYear() %> E-Menum.\n        <%= typeof t === 'function' ? t('common.allRightsReserved') : 'All rights reserved.' %>\n      </p>\n      <div class=\"mt-2 flex items-center justify-center gap-4 text-xs text-text-muted\">\n        <a href=\"/privacy\" class=\"hover:text-text-primary transition-colors\">\n          <%= typeof t === 'function' ? t('common.privacyPolicy') : 'Privacy Policy' %>\n        </a>\n        <span aria-hidden=\"true\">&middot;</span>\n        <a href=\"/terms\" class=\"hover:text-text-primary transition-colors\">\n          <%= typeof t === 'function' ? t('common.termsOfService') : 'Terms of Service' %>\n        </a>\n        <span aria-hidden=\"true\">&middot;</span>\n        <a href=\"/contact\" class=\"hover:text-text-primary transition-colors\">\n          <%= typeof t === 'function' ? t('common.contact') : 'Contact' %>\n        </a>\n      </div>\n    </footer>\n  </div>\n\n  <!-- Extra Scripts -->\n  <% if (locals.extraScripts) { %>\n    <% extraScripts.forEach(function(script) { %>\n      <script src=\"<%= script %>\"></script>\n    <% }); %>\n  <% } %>\n\n  <% if (locals.inlineScript) { %>\n    <script><%= inlineScript %></script>\n  <% } %>\n</body>\n</html>\n",
        "last_modified": "2026-02-01T09:10:53.777682"
      },
