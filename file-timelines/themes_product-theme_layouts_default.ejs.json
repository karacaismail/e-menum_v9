      "worktree_state": {
        "content": "<!DOCTYPE html>\n<html lang=\"<%= locals.lang || 'tr' %>\" data-theme=\"<%= locals.theme || 'light' %>\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes\">\n  <meta name=\"description\" content=\"<%= locals.metaDescription || (locals.menu ? menu.name + ' - Digital Menu' : 'E-Menum Digital Menu') %>\">\n  <meta name=\"theme-color\" content=\"<%= locals.brandColor || '#2563eb' %>\">\n\n  <!-- Open Graph -->\n  <meta property=\"og:title\" content=\"<%= locals.pageTitle || (locals.menu ? menu.name : 'Digital Menu') %>\">\n  <meta property=\"og:description\" content=\"<%= locals.metaDescription || 'Browse our digital menu and place your order' %>\">\n  <meta property=\"og:type\" content=\"website\">\n  <% if (locals.menu && menu.coverImage) { %>\n    <meta property=\"og:image\" content=\"<%= menu.coverImage %>\">\n  <% } %>\n\n  <title><%= locals.pageTitle ? `${locals.pageTitle} | ` : '' %><%= locals.organizationName || 'E-Menum' %></title>\n\n  <!-- Favicon -->\n  <link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\">\n  <link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/images/apple-touch-icon.png\">\n\n  <!-- PWA Manifest -->\n  <link rel=\"manifest\" href=\"/manifest.json\">\n\n  <!-- Fonts -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n  <!-- Icons - Phosphor Icons (Primary) -->\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/regular/style.css\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/bold/style.css\">\n  <link rel=\"stylesheet\" href=\"https://unpkg.com/@phosphor-icons/web@2.0.3/src/fill/style.css\">\n\n  <!-- Main Stylesheet -->\n  <link rel=\"stylesheet\" href=\"/themes/product-theme/styles/main.css\">\n\n  <!-- Brand Colors (Dynamic) -->\n  <% if (locals.brandColor) { %>\n    <style>\n      :root {\n        --brand-primary: <%= brandColor %>;\n      }\n    </style>\n  <% } %>\n\n  <!-- Extra Styles -->\n  <% if (locals.extraStyles) { %>\n    <% extraStyles.forEach(function(style) { %>\n      <link rel=\"stylesheet\" href=\"<%= style %>\">\n    <% }); %>\n  <% } %>\n\n  <!-- Alpine.js -->\n  <script defer src=\"https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js\"></script>\n\n  <!-- Theme Toggle Script (runs before page render to prevent flash) -->\n  <script>\n    (function() {\n      const savedTheme = localStorage.getItem('theme');\n      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;\n      const theme = savedTheme || (prefersDark ? 'dark' : 'light');\n      document.documentElement.setAttribute('data-theme', theme);\n    })();\n  </script>\n</head>\n<body class=\"bg-surface-background text-text-primary font-sans antialiased\">\n  <!-- Skip Link for Accessibility -->\n  <a href=\"#main-content\" class=\"skip-link\">\n    <%= typeof t === 'function' ? t('common.skipToContent') : 'Skip to main content' %>\n  </a>\n\n  <!-- Live Region for Screen Reader Announcements -->\n  <div aria-live=\"polite\" aria-atomic=\"true\" class=\"sr-only\" id=\"sr-announcements\"></div>\n\n  <!-- Main App Container -->\n  <div\n    x-data=\"{\n      cart: [],\n      cartOpen: false,\n      searchOpen: false,\n      searchQuery: '',\n      activeCategory: '<%= locals.categories && categories.length > 0 ? categories[0].id : '' %>',\n\n      // Cart Methods\n      addToCart(product, quantity = 1, variants = [], modifiers = []) {\n        const existingIndex = this.cart.findIndex(item =>\n          item.productId === product.id &&\n          JSON.stringify(item.variants) === JSON.stringify(variants) &&\n          JSON.stringify(item.modifiers) === JSON.stringify(modifiers)\n        );\n\n        if (existingIndex > -1) {\n          this.cart[existingIndex].quantity += quantity;\n        } else {\n          this.cart.push({\n            productId: product.id,\n            name: product.name,\n            price: product.price,\n            image: product.image,\n            quantity: quantity,\n            variants: variants,\n            modifiers: modifiers\n          });\n        }\n\n        this.saveCart();\n        this.announceToScreenReader('<%= typeof t === 'function' ? t('cart.itemAdded') : 'Item added to cart' %>');\n      },\n\n      removeFromCart(index) {\n        this.cart.splice(index, 1);\n        this.saveCart();\n        this.announceToScreenReader('<%= typeof t === 'function' ? t('cart.itemRemoved') : 'Item removed from cart' %>');\n      },\n\n      updateQuantity(index, quantity) {\n        if (quantity <= 0) {\n          this.removeFromCart(index);\n        } else {\n          this.cart[index].quantity = quantity;\n          this.saveCart();\n        }\n      },\n\n      get cartTotal() {\n        return this.cart.reduce((total, item) => {\n          let itemPrice = item.price * item.quantity;\n          // Add variant prices\n          item.variants.forEach(v => itemPrice += (v.priceModifier || 0) * item.quantity);\n          // Add modifier prices\n          item.modifiers.forEach(m => itemPrice += (m.price || 0) * item.quantity);\n          return total + itemPrice;\n        }, 0);\n      },\n\n      get cartItemCount() {\n        return this.cart.reduce((count, item) => count + item.quantity, 0);\n      },\n\n      saveCart() {\n        localStorage.setItem('cart_<%= locals.menu ? menu.id : 'default' %>', JSON.stringify(this.cart));\n      },\n\n      loadCart() {\n        const saved = localStorage.getItem('cart_<%= locals.menu ? menu.id : 'default' %>');\n        if (saved) {\n          try {\n            this.cart = JSON.parse(saved);\n          } catch (e) {\n            this.cart = [];\n          }\n        }\n      },\n\n      clearCart() {\n        this.cart = [];\n        this.saveCart();\n      },\n\n      formatPrice(price) {\n        return new Intl.NumberFormat('<%= locals.lang || 'tr' %>-TR', {\n          style: 'currency',\n          currency: 'TRY',\n          minimumFractionDigits: 2\n        }).format(price);\n      },\n\n      scrollToCategory(categoryId) {\n        const element = document.getElementById('category-' + categoryId);\n        if (element) {\n          const headerOffset = 120;\n          const elementPosition = element.getBoundingClientRect().top;\n          const offsetPosition = elementPosition + window.pageYOffset - headerOffset;\n\n          window.scrollTo({\n            top: offsetPosition,\n            behavior: 'smooth'\n          });\n        }\n        this.activeCategory = categoryId;\n      },\n\n      announceToScreenReader(message) {\n        const announcer = document.getElementById('sr-announcements');\n        if (announcer) {\n          announcer.textContent = message;\n          setTimeout(() => announcer.textContent = '', 1000);\n        }\n      }\n    }\"\n    x-init=\"loadCart()\"\n    @keydown.escape=\"cartOpen = false; searchOpen = false\"\n    class=\"min-h-screen flex flex-col\"\n  >\n    <!-- Header -->\n    <%- include('../components/header', {\n      menu: locals.menu,\n      organization: locals.organization,\n      tableNumber: locals.tableNumber\n    }) %>\n\n    <!-- Category Navigation -->\n    <% if (locals.categories && categories.length > 0) { %>\n      <%- include('../components/category-nav', {\n        categories: categories\n      }) %>\n    <% } %>\n\n    <!-- Main Content -->\n    <main id=\"main-content\" role=\"main\" class=\"flex-1 pb-24\">\n      <!-- Flash Messages -->\n      <% if (locals.flash && flash.error) { %>\n        <div role=\"alert\" class=\"mx-4 mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg\">\n          <div class=\"flex items-center gap-2 text-red-600 dark:text-red-400\">\n            <i class=\"ph ph-warning-circle\" aria-hidden=\"true\"></i>\n            <span><%= flash.error %></span>\n          </div>\n        </div>\n      <% } %>\n\n      <!-- Page Content -->\n      <%- body %>\n    </main>\n\n    <!-- Cart Component -->\n    <%- include('../components/cart', {\n      menu: locals.menu,\n      tableNumber: locals.tableNumber\n    }) %>\n\n    <!-- Footer -->\n    <%- include('../components/footer', {\n      organization: locals.organization,\n      menu: locals.menu\n    }) %>\n  </div>\n\n  <!-- Extra Scripts -->\n  <% if (locals.extraScripts) { %>\n    <% extraScripts.forEach(function(script) { %>\n      <script src=\"<%= script %>\"></script>\n    <% }); %>\n  <% } %>\n\n  <!-- Inline Scripts -->\n  <% if (locals.inlineScript) { %>\n    <script><%= inlineScript %></script>\n  <% } %>\n\n  <!-- Service Worker Registration -->\n  <script>\n    if ('serviceWorker' in navigator) {\n      window.addEventListener('load', function() {\n        navigator.serviceWorker.register('/sw.js').catch(function(err) {\n          // Service worker registration failed silently\n        });\n      });\n    }\n  </script>\n</body>\n</html>\n",
        "last_modified": "2026-02-01T09:10:53.783833"
      },
