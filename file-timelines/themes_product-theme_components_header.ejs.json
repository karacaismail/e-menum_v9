      "worktree_state": {
        "content": "<%#\n  Header Component - Product Theme\n\n  Variables:\n  - menu: Current menu object\n  - organization: Organization object\n  - tableNumber: Optional table number from QR scan\n%>\n<header\n  role=\"banner\"\n  class=\"sticky top-0 z-30 bg-surface-card border-b border-border-color\"\n>\n  <div class=\"flex items-center h-16 px-4 gap-3\">\n    <!-- Logo / Restaurant Name -->\n    <a\n      href=\"<%= locals.menu ? '/m/' + menu.slug : '/' %>\"\n      class=\"flex items-center gap-2 min-w-0 flex-shrink-0\"\n      aria-label=\"<%= locals.organization ? organization.name : 'Home' %>\"\n    >\n      <% if (locals.organization && organization.logo) { %>\n        <img\n          src=\"<%= organization.logo %>\"\n          alt=\"\"\n          class=\"h-10 w-10 rounded-lg object-contain\"\n        >\n      <% } else { %>\n        <div class=\"h-10 w-10 rounded-lg bg-brand-primary flex items-center justify-center text-white font-bold text-lg\">\n          <%= locals.organization ? organization.name.charAt(0).toUpperCase() : 'M' %>\n        </div>\n      <% } %>\n      <div class=\"min-w-0 hidden sm:block\">\n        <h1 class=\"text-base font-semibold text-text-primary truncate\">\n          <%= locals.organization ? organization.name : 'Menu' %>\n        </h1>\n        <% if (locals.menu && menu.name) { %>\n          <p class=\"text-xs text-text-muted truncate\">\n            <%= menu.name %>\n          </p>\n        <% } %>\n      </div>\n    </a>\n\n    <!-- Table Badge (if scanned from QR) -->\n    <% if (locals.tableNumber) { %>\n      <span class=\"badge badge-primary flex-shrink-0\">\n        <i class=\"ph ph-table\" aria-hidden=\"true\"></i>\n        <span><%= typeof t === 'function' ? t('common.table') : 'Table' %> <%= tableNumber %></span>\n      </span>\n    <% } %>\n\n    <!-- Spacer -->\n    <div class=\"flex-1\"></div>\n\n    <!-- Search Toggle -->\n    <button\n      @click=\"searchOpen = !searchOpen; $nextTick(() => $refs.searchInput?.focus())\"\n      type=\"button\"\n      class=\"btn btn-ghost btn-icon\"\n      :aria-expanded=\"searchOpen\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.search') : 'Search menu' %>\"\n    >\n      <i x-show=\"!searchOpen\" class=\"ph ph-magnifying-glass text-xl\" aria-hidden=\"true\"></i>\n      <i x-show=\"searchOpen\" class=\"ph ph-x text-xl\" aria-hidden=\"true\"></i>\n    </button>\n\n    <!-- Theme Toggle -->\n    <button\n      x-data=\"{ dark: document.documentElement.getAttribute('data-theme') === 'dark' }\"\n      @click=\"dark = !dark; document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light'); localStorage.setItem('theme', dark ? 'dark' : 'light')\"\n      type=\"button\"\n      class=\"btn btn-ghost btn-icon\"\n      :aria-label=\"dark ? '<%= typeof t === 'function' ? t('common.lightMode') : 'Switch to light mode' %>' : '<%= typeof t === 'function' ? t('common.darkMode') : 'Switch to dark mode' %>'\"\n    >\n      <template x-if=\"!dark\">\n        <i class=\"ph ph-moon text-xl\" aria-hidden=\"true\"></i>\n      </template>\n      <template x-if=\"dark\">\n        <i class=\"ph ph-sun text-xl\" aria-hidden=\"true\"></i>\n      </template>\n    </button>\n\n    <!-- Cart Button -->\n    <button\n      @click=\"cartOpen = true\"\n      type=\"button\"\n      class=\"btn btn-primary btn-icon relative\"\n      aria-label=\"<%= typeof t === 'function' ? t('cart.viewCart') : 'View cart' %>\"\n      :aria-label=\"cartItemCount > 0 ? `<%= typeof t === 'function' ? t('cart.viewCart') : 'View cart' %> (${cartItemCount} <%= typeof t === 'function' ? t('cart.items') : 'items' %>)` : `<%= typeof t === 'function' ? t('cart.viewCart') : 'View cart' %>`\"\n    >\n      <i class=\"ph ph-shopping-cart text-xl\" aria-hidden=\"true\"></i>\n      <span\n        x-show=\"cartItemCount > 0\"\n        x-text=\"cartItemCount\"\n        class=\"absolute -top-1 -right-1 w-5 h-5 text-xs font-bold bg-red-500 text-white rounded-full flex items-center justify-center\"\n      ></span>\n    </button>\n  </div>\n\n  <!-- Search Overlay -->\n  <div\n    x-show=\"searchOpen\"\n    x-transition:enter=\"transition ease-out duration-200\"\n    x-transition:enter-start=\"opacity-0 -translate-y-2\"\n    x-transition:enter-end=\"opacity-100 translate-y-0\"\n    x-transition:leave=\"transition ease-in duration-150\"\n    x-transition:leave-start=\"opacity-100 translate-y-0\"\n    x-transition:leave-end=\"opacity-0 -translate-y-2\"\n    class=\"absolute top-full left-0 right-0 bg-surface-card border-b border-border-color shadow-lg p-4\"\n  >\n    <div class=\"relative max-w-2xl mx-auto\">\n      <label for=\"menu-search\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('common.searchMenu') : 'Search menu' %>\n      </label>\n      <i class=\"ph ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-text-muted\" aria-hidden=\"true\"></i>\n      <input\n        type=\"search\"\n        id=\"menu-search\"\n        x-ref=\"searchInput\"\n        x-model=\"searchQuery\"\n        placeholder=\"<%= typeof t === 'function' ? t('common.searchPlaceholder') : 'Search for dishes, drinks...' %>\"\n        class=\"form-input w-full pl-12 pr-4 py-3 text-base\"\n        autocomplete=\"off\"\n        @keydown.escape=\"searchOpen = false\"\n      >\n    </div>\n\n    <!-- Quick Filters -->\n    <div class=\"flex flex-wrap items-center gap-2 mt-3 max-w-2xl mx-auto\">\n      <span class=\"text-xs text-text-muted\">\n        <%= typeof t === 'function' ? t('common.popularSearches') : 'Popular:' %>\n      </span>\n      <button type=\"button\" class=\"badge badge-neutral cursor-pointer hover:bg-surface-elevated\" @click=\"searchQuery = 'vegetarian'\">\n        <i class=\"ph ph-leaf text-green-500\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('filters.vegetarian') : 'Vegetarian' %>\n      </button>\n      <button type=\"button\" class=\"badge badge-neutral cursor-pointer hover:bg-surface-elevated\" @click=\"searchQuery = 'spicy'\">\n        <i class=\"ph ph-fire text-red-500\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('filters.spicy') : 'Spicy' %>\n      </button>\n      <button type=\"button\" class=\"badge badge-neutral cursor-pointer hover:bg-surface-elevated\" @click=\"searchQuery = 'popular'\">\n        <i class=\"ph ph-star text-yellow-500\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('filters.popular') : 'Popular' %>\n      </button>\n    </div>\n  </div>\n</header>\n",
        "last_modified": "2026-02-01T09:10:53.782945"
      },
