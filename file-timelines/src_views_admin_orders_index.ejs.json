{
  "file_path": "src/views/admin/orders/index.ejs",
  "main_branch_history": [],
  "task_views": {
    "001-create": {
      "task_id": "001-create",
      "branch_point": {
        "commit_hash": "e2c14236dedadbadc7b19d123890e3f98e7316c0",
        "content": "",
        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Orders List View\n\n  Variables:\n  - orders: Array of order objects\n  - pagination: { page, perPage, total, totalPages }\n  - filters: { search, status, dateFrom, dateTo, type }\n  - stats: { pending, preparing, ready, completed, total }\n%>\n\n<!-- Status Quick Filters -->\n<div class=\"flex flex-wrap gap-2 mb-6\">\n  <%\n    const statusFilters = [\n      { value: '', label: typeof t === 'function' ? t('orders.all') : 'All', icon: 'list', count: locals.stats ? stats.total : 0 },\n      { value: 'pending', label: typeof t === 'function' ? t('orders.status.pending') : 'Pending', icon: 'clock', count: locals.stats ? stats.pending : 0, color: 'yellow' },\n      { value: 'confirmed', label: typeof t === 'function' ? t('orders.status.confirmed') : 'Confirmed', icon: 'check', count: locals.stats ? stats.confirmed : 0, color: 'blue' },\n      { value: 'preparing', label: typeof t === 'function' ? t('orders.status.preparing') : 'Preparing', icon: 'cooking-pot', count: locals.stats ? stats.preparing : 0, color: 'purple' },\n      { value: 'ready', label: typeof t === 'function' ? t('orders.status.ready') : 'Ready', icon: 'bell', count: locals.stats ? stats.ready : 0, color: 'green' },\n      { value: 'delivered', label: typeof t === 'function' ? t('orders.status.delivered') : 'Delivered', icon: 'check-circle', count: locals.stats ? stats.delivered : 0, color: 'gray' }\n    ];\n    const currentStatus = (locals.filters && filters.status) || '';\n  %>\n  <% statusFilters.forEach(function(sf) { %>\n    <a\n      href=\"/admin/orders<%= sf.value ? '?status=' + sf.value : '' %>\"\n      class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium transition-colors\n        <%= currentStatus === sf.value\n          ? (sf.color ? 'bg-' + sf.color + '-100 dark:bg-' + sf.color + '-900/30 text-' + sf.color + '-700 dark:text-' + sf.color + '-400' : 'bg-brand-primary text-white')\n          : 'bg-surface-card hover:bg-surface-elevated text-text-secondary' %>\"\n    >\n      <i class=\"ph ph-<%= sf.icon %>\" aria-hidden=\"true\"></i>\n      <%= sf.label %>\n      <% if (sf.count > 0) { %>\n        <span class=\"px-1.5 py-0.5 text-xs rounded-full\n          <%= currentStatus === sf.value ? 'bg-white/20' : 'bg-surface-elevated' %>\">\n          <%= sf.count %>\n        </span>\n      <% } %>\n    </a>\n  <% }); %>\n</div>\n\n<!-- Filters and Search -->\n<div class=\"card p-4 mb-6\">\n  <form action=\"/admin/orders\" method=\"GET\" class=\"flex flex-col lg:flex-row gap-4\">\n    <!-- Search -->\n    <div class=\"flex-1 relative\">\n      <label for=\"search\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('common.search') : 'Search' %>\n      </label>\n      <i class=\"ph ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-text-muted\" aria-hidden=\"true\"></i>\n      <input\n        type=\"search\"\n        id=\"search\"\n        name=\"search\"\n        value=\"<%= locals.filters ? filters.search : '' %>\"\n        placeholder=\"<%= typeof t === 'function' ? t('orders.searchPlaceholder') : 'Search by order #, customer name...' %>\"\n        class=\"form-input pl-10 w-full\"\n      >\n    </div>\n\n    <!-- Date Range -->\n    <div class=\"flex gap-2\">\n      <div>\n        <label for=\"dateFrom\" class=\"sr-only\">\n          <%= typeof t === 'function' ? t('common.from') : 'From' %>\n        </label>\n        <input\n          type=\"date\"\n          id=\"dateFrom\"\n          name=\"dateFrom\"\n          value=\"<%= locals.filters ? filters.dateFrom : '' %>\"\n          class=\"form-input\"\n        >\n      </div>\n      <div>\n        <label for=\"dateTo\" class=\"sr-only\">\n          <%= typeof t === 'function' ? t('common.to') : 'To' %>\n        </label>\n        <input\n          type=\"date\"\n          id=\"dateTo\"\n          name=\"dateTo\"\n          value=\"<%= locals.filters ? filters.dateTo : '' %>\"\n          class=\"form-input\"\n        >\n      </div>\n    </div>\n\n    <!-- Order Type -->\n    <div class=\"w-full lg:w-40\">\n      <label for=\"type\" class=\"sr-only\">\n        <%= typeof t === 'function' ? t('orders.type') : 'Type' %>\n      </label>\n      <select id=\"type\" name=\"type\" class=\"form-select w-full\">\n        <option value=\"\"><%= typeof t === 'function' ? t('orders.allTypes') : 'All Types' %></option>\n        <option value=\"dine_in\" <%= locals.filters && filters.type === 'dine_in' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('orders.type.dine_in') : 'Dine In' %>\n        </option>\n        <option value=\"takeaway\" <%= locals.filters && filters.type === 'takeaway' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('orders.type.takeaway') : 'Takeaway' %>\n        </option>\n        <option value=\"delivery\" <%= locals.filters && filters.type === 'delivery' ? 'selected' : '' %>>\n          <%= typeof t === 'function' ? t('orders.type.delivery') : 'Delivery' %>\n        </option>\n      </select>\n    </div>\n\n    <!-- Hidden status field to preserve filter -->\n    <% if (currentStatus) { %>\n      <input type=\"hidden\" name=\"status\" value=\"<%= currentStatus %>\">\n    <% } %>\n\n    <!-- Filter Button -->\n    <button type=\"submit\" class=\"btn btn-secondary\">\n      <i class=\"ph ph-funnel mr-2\" aria-hidden=\"true\"></i>\n      <%= typeof t === 'function' ? t('common.filter') : 'Filter' %>\n    </button>\n  </form>\n</div>\n\n<% if (!locals.orders || orders.length === 0) { %>\n  <!-- Empty State -->\n  <div class=\"card p-8 text-center\">\n    <div class=\"w-20 h-20 mx-auto rounded-full bg-surface-elevated flex items-center justify-center mb-4\">\n      <i class=\"ph ph-receipt text-4xl text-text-muted\" aria-hidden=\"true\"></i>\n    </div>\n    <h3 class=\"text-xl font-semibold text-text-primary mb-2\">\n      <%= typeof t === 'function' ? t('orders.noOrdersFound') : 'No orders found' %>\n    </h3>\n    <p class=\"text-text-muted mb-6 max-w-md mx-auto\">\n      <% if (currentStatus || (locals.filters && (filters.search || filters.dateFrom))) { %>\n        <%= typeof t === 'function' ? t('orders.tryDifferentFilters') : 'Try adjusting your filters to find orders.' %>\n      <% } else { %>\n        <%= typeof t === 'function' ? t('orders.waitingForOrders') : 'Orders will appear here when customers place them through your menu.' %>\n      <% } %>\n    </p>\n    <% if (currentStatus || (locals.filters && (filters.search || filters.dateFrom))) { %>\n      <a href=\"/admin/orders\" class=\"btn btn-secondary\">\n        <i class=\"ph ph-x-circle mr-2\" aria-hidden=\"true\"></i>\n        <%= typeof t === 'function' ? t('common.clearFilters') : 'Clear Filters' %>\n      </a>\n    <% } %>\n  </div>\n<% } else { %>\n  <!-- Orders Table -->\n  <div class=\"card overflow-hidden\">\n    <div class=\"overflow-x-auto\">\n      <table class=\"w-full\">\n        <thead>\n          <tr class=\"bg-surface-elevated\">\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.orderNumber') : 'Order #' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden sm:table-cell\">\n              <%= typeof t === 'function' ? t('orders.customer') : 'Customer' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.status') : 'Status' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden md:table-cell\">\n              <%= typeof t === 'function' ? t('orders.type') : 'Type' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden lg:table-cell\">\n              <%= typeof t === 'function' ? t('orders.items') : 'Items' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-right text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <%= typeof t === 'function' ? t('orders.total') : 'Total' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-left text-xs font-semibold text-text-muted uppercase tracking-wider hidden xl:table-cell\">\n              <%= typeof t === 'function' ? t('orders.time') : 'Time' %>\n            </th>\n            <th class=\"px-4 md:px-6 py-3 text-right text-xs font-semibold text-text-muted uppercase tracking-wider\">\n              <span class=\"sr-only\"><%= typeof t === 'function' ? t('common.actions') : 'Actions' %></span>\n            </th>\n          </tr>\n        </thead>\n        <tbody class=\"divide-y divide-border-color\">\n          <% orders.forEach(function(order) { %>\n            <tr\n              class=\"hover:bg-surface-elevated transition-colors <%= order.status === 'pending' ? 'bg-yellow-50/50 dark:bg-yellow-900/10' : '' %>\"\n              x-data=\"{ actionsOpen: false }\"\n            >\n              <td class=\"px-4 md:px-6 py-4\">\n                <a href=\"/admin/orders/<%= order.id %>\" class=\"font-medium text-brand-primary hover:underline\">\n                  #<%= order.orderNumber %>\n                </a>\n                <p class=\"text-xs text-text-muted sm:hidden mt-1\">\n                  <%= order.customerName || (typeof t === 'function' ? t('orders.guest') : 'Guest') %>\n                </p>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden sm:table-cell\">\n                <p class=\"text-sm text-text-primary font-medium\">\n                  <%= order.customerName || (typeof t === 'function' ? t('orders.guest') : 'Guest') %>\n                </p>\n                <% if (order.customerPhone) { %>\n                  <p class=\"text-xs text-text-muted\">\n                    <i class=\"ph ph-phone\" aria-hidden=\"true\"></i>\n                    <%= order.customerPhone %>\n                  </p>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4\">\n                <%\n                  const statusColors = {\n                    pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400',\n                    confirmed: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400',\n                    preparing: 'bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400',\n                    ready: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400',\n                    delivered: 'bg-gray-100 text-gray-800 dark:bg-gray-900/30 dark:text-gray-400',\n                    cancelled: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400'\n                  };\n                  const statusColor = statusColors[order.status] || statusColors.pending;\n                %>\n                <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= statusColor %>\">\n                  <%= typeof t === 'function' ? t('orders.status.' + order.status) : order.status %>\n                </span>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden md:table-cell\">\n                <%\n                  const typeIcons = {\n                    dine_in: 'fork-knife',\n                    takeaway: 'bag',\n                    delivery: 'moped'\n                  };\n                  const typeIcon = typeIcons[order.type] || 'receipt';\n                %>\n                <span class=\"inline-flex items-center gap-1 text-sm text-text-secondary\">\n                  <i class=\"ph ph-<%= typeIcon %>\" aria-hidden=\"true\"></i>\n                  <%= typeof t === 'function' ? t('orders.type.' + order.type) : order.type %>\n                </span>\n                <% if (order.type === 'dine_in' && order.table) { %>\n                  <p class=\"text-xs text-text-muted\">\n                    <%= typeof t === 'function' ? t('orders.table') : 'Table' %>: <%= order.table.name || order.table.number %>\n                  </p>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden lg:table-cell\">\n                <p class=\"text-sm text-text-primary\">\n                  <%= order.itemCount %> <%= typeof t === 'function' ? t('orders.items') : 'items' %>\n                </p>\n                <% if (order.items && order.items.length > 0) { %>\n                  <p class=\"text-xs text-text-muted truncate max-w-xs\">\n                    <%= order.items.slice(0, 2).map(i => i.productName).join(', ') %><%= order.items.length > 2 ? '...' : '' %>\n                  </p>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 text-right\">\n                <p class=\"text-sm font-medium text-text-primary\">\n                  <%= order.total.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' }) %>\n                </p>\n                <% if (order.paymentStatus) { %>\n                  <span class=\"text-xs <%= order.paymentStatus === 'paid' ? 'text-green-600 dark:text-green-400' : 'text-yellow-600 dark:text-yellow-400' %>\">\n                    <%= typeof t === 'function' ? t('orders.payment.' + order.paymentStatus) : order.paymentStatus %>\n                  </span>\n                <% } %>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 hidden xl:table-cell\">\n                <p class=\"text-sm text-text-primary\">\n                  <%= new Date(order.createdAt).toLocaleTimeString(locals.lang || 'tr-TR', { hour: '2-digit', minute: '2-digit' }) %>\n                </p>\n                <p class=\"text-xs text-text-muted\">\n                  <%= new Date(order.createdAt).toLocaleDateString(locals.lang || 'tr-TR') %>\n                </p>\n              </td>\n              <td class=\"px-4 md:px-6 py-4 text-right\">\n                <div class=\"relative\">\n                  <button\n                    @click=\"actionsOpen = !actionsOpen\"\n                    @click.outside=\"actionsOpen = false\"\n                    type=\"button\"\n                    class=\"btn btn-ghost btn-sm btn-icon\"\n                    aria-label=\"<%= typeof t === 'function' ? t('common.actions') : 'Actions' %>\"\n                  >\n                    <i class=\"ph ph-dots-three-vertical\" aria-hidden=\"true\"></i>\n                  </button>\n\n                  <div\n                    x-show=\"actionsOpen\"\n                    x-transition:enter=\"transition ease-out duration-100\"\n                    x-transition:enter-start=\"opacity-0 scale-95\"\n                    x-transition:enter-end=\"opacity-100 scale-100\"\n                    x-transition:leave=\"transition ease-in duration-75\"\n                    x-transition:leave-start=\"opacity-100 scale-100\"\n                    x-transition:leave-end=\"opacity-0 scale-95\"\n                    class=\"absolute right-0 mt-1 w-48 bg-surface-card rounded-lg shadow-lg border border-border-color overflow-hidden z-10\"\n                  >\n                    <a\n                      href=\"/admin/orders/<%= order.id %>\"\n                      class=\"flex items-center gap-2 px-4 py-2 text-sm hover:bg-surface-elevated\"\n                    >\n                      <i class=\"ph ph-eye text-text-muted\" aria-hidden=\"true\"></i>\n                      <%= typeof t === 'function' ? t('common.viewDetails') : 'View Details' %>\n                    </a>\n\n                    <% if (order.status === 'pending') { %>\n                      <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\">\n                        <input type=\"hidden\" name=\"status\" value=\"confirmed\">\n                        <button\n                          type=\"submit\"\n                          class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-blue-600 dark:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/20\"\n                        >\n                          <i class=\"ph ph-check\" aria-hidden=\"true\"></i>\n                          <%= typeof t === 'function' ? t('orders.confirm') : 'Confirm' %>\n                        </button>\n                      </form>\n                    <% } else if (order.status === 'confirmed') { %>\n                      <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\">\n                        <input type=\"hidden\" name=\"status\" value=\"preparing\">\n                        <button\n                          type=\"submit\"\n                          class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-900/20\"\n                        >\n                          <i class=\"ph ph-cooking-pot\" aria-hidden=\"true\"></i>\n                          <%= typeof t === 'function' ? t('orders.startPreparing') : 'Start Preparing' %>\n                        </button>\n                      </form>\n                    <% } else if (order.status === 'preparing') { %>\n                      <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\">\n                        <input type=\"hidden\" name=\"status\" value=\"ready\">\n                        <button\n                          type=\"submit\"\n                          class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-green-600 dark:text-green-400 hover:bg-green-50 dark:hover:bg-green-900/20\"\n                        >\n                          <i class=\"ph ph-bell\" aria-hidden=\"true\"></i>\n                          <%= typeof t === 'function' ? t('orders.markReady') : 'Mark Ready' %>\n                        </button>\n                      </form>\n                    <% } else if (order.status === 'ready') { %>\n                      <form action=\"/admin/orders/<%= order.id %>/status\" method=\"POST\">\n                        <input type=\"hidden\" name=\"status\" value=\"delivered\">\n                        <button\n                          type=\"submit\"\n                          class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-900/20\"\n                        >\n                          <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n                          <%= typeof t === 'function' ? t('orders.markDelivered') : 'Mark Delivered' %>\n                        </button>\n                      </form>\n                    <% } %>\n\n                    <% if (['pending', 'confirmed'].includes(order.status)) { %>\n                      <hr class=\"border-border-color\">\n                      <form\n                        action=\"/admin/orders/<%= order.id %>/status\"\n                        method=\"POST\"\n                        onsubmit=\"return confirm('<%= typeof t === 'function' ? t('orders.confirmCancel') : 'Are you sure you want to cancel this order?' %>')\"\n                      >\n                        <input type=\"hidden\" name=\"status\" value=\"cancelled\">\n                        <button\n                          type=\"submit\"\n                          class=\"w-full flex items-center gap-2 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20\"\n                        >\n                          <i class=\"ph ph-x-circle\" aria-hidden=\"true\"></i>\n                          <%= typeof t === 'function' ? t('orders.cancel') : 'Cancel Order' %>\n                        </button>\n                      </form>\n                    <% } %>\n\n                    <hr class=\"border-border-color\">\n                    <a\n                      href=\"/admin/orders/<%= order.id %>/print\"\n                      target=\"_blank\"\n                      class=\"flex items-center gap-2 px-4 py-2 text-sm hover:bg-surface-elevated\"\n                    >\n                      <i class=\"ph ph-printer text-text-muted\" aria-hidden=\"true\"></i>\n                      <%= typeof t === 'function' ? t('orders.print') : 'Print Order' %>\n                    </a>\n                  </div>\n                </div>\n              </td>\n            </tr>\n          <% }); %>\n        </tbody>\n      </table>\n    </div>\n\n    <!-- Pagination -->\n    <% if (locals.pagination && pagination.totalPages > 1) { %>\n      <div class=\"px-4 md:px-6 py-4 border-t border-border-color flex items-center justify-between\">\n        <p class=\"text-sm text-text-muted\">\n          <%= typeof t === 'function' ? t('common.showing') : 'Showing' %>\n          <span class=\"font-medium\"><%= (pagination.page - 1) * pagination.perPage + 1 %></span>\n          <%= typeof t === 'function' ? t('common.to') : 'to' %>\n          <span class=\"font-medium\"><%= Math.min(pagination.page * pagination.perPage, pagination.total) %></span>\n          <%= typeof t === 'function' ? t('common.of') : 'of' %>\n          <span class=\"font-medium\"><%= pagination.total %></span>\n        </p>\n\n        <div class=\"flex items-center gap-2\">\n          <% if (pagination.page > 1) { %>\n            <a\n              href=\"?page=<%= pagination.page - 1 %><%= currentStatus ? '&status=' + currentStatus : '' %><%= locals.filters && filters.search ? '&search=' + filters.search : '' %>\"\n              class=\"btn btn-ghost btn-sm\"\n            >\n              <i class=\"ph ph-caret-left mr-1\" aria-hidden=\"true\"></i>\n              <%= typeof t === 'function' ? t('common.previous') : 'Previous' %>\n            </a>\n          <% } %>\n\n          <% if (pagination.page < pagination.totalPages) { %>\n            <a\n              href=\"?page=<%= pagination.page + 1 %><%= currentStatus ? '&status=' + currentStatus : '' %><%= locals.filters && filters.search ? '&search=' + filters.search : '' %>\"\n              class=\"btn btn-ghost btn-sm\"\n            >\n              <%= typeof t === 'function' ? t('common.next') : 'Next' %>\n              <i class=\"ph ph-caret-right ml-1\" aria-hidden=\"true\"></i>\n            </a>\n          <% } %>\n        </div>\n      </div>\n    <% } %>\n  </div>\n<% } %>\n\n<!-- Auto-refresh for pending orders -->\n<% if (currentStatus === 'pending' || !currentStatus) { %>\n<script>\n  // Auto-refresh every 30 seconds for order updates\n  setTimeout(function() {\n    window.location.reload();\n  }, 30000);\n</script>\n<% } %>\n",
