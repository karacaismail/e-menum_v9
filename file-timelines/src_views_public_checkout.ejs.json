{
  "file_path": "src/views/public/checkout.ejs",
  "main_branch_history": [],
  "task_views": {
    "001-create": {
      "task_id": "001-create",
      "branch_point": {
        "commit_hash": "e2c14236dedadbadc7b19d123890e3f98e7316c0",
        "content": "",
        "timestamp": "2026-02-01T08:03:23.990755"
      },
      "worktree_state": {
        "content": "<%#\n  Checkout View - Order Placement Page\n\n  Form for collecting customer information and placing the order.\n  Displays order summary and handles form submission.\n\n  Variables:\n  - menu: Current menu object\n  - organization: Organization object\n  - tableNumber: Optional table number from QR scan\n  - lang: Current language code (tr/en)\n  - errors: Optional validation errors object\n%>\n\n<section\n  x-data=\"{\n    customerName: '',\n    customerPhone: '',\n    customerNote: localStorage.getItem('orderNotes_<%= locals.menu ? menu.id : 'default' %>') || '',\n    orderType: '<%= locals.tableNumber ? 'dine_in' : 'takeaway' %>',\n    isSubmitting: false,\n    errors: {},\n\n    validateForm() {\n      this.errors = {};\n\n      if (!this.customerName.trim()) {\n        this.errors.name = '<%= typeof t === 'function' ? t('checkout.errors.nameRequired') : 'Please enter your name' %>';\n      }\n\n      if (!this.customerPhone.trim()) {\n        this.errors.phone = '<%= typeof t === 'function' ? t('checkout.errors.phoneRequired') : 'Please enter your phone number' %>';\n      } else if (!/^[0-9\\s\\-\\+\\(\\)]{10,}$/.test(this.customerPhone)) {\n        this.errors.phone = '<%= typeof t === 'function' ? t('checkout.errors.phoneInvalid') : 'Please enter a valid phone number' %>';\n      }\n\n      if (this.cart.length === 0) {\n        this.errors.cart = '<%= typeof t === 'function' ? t('checkout.errors.cartEmpty') : 'Your cart is empty' %>';\n      }\n\n      return Object.keys(this.errors).length === 0;\n    },\n\n    async submitOrder() {\n      if (!this.validateForm()) return;\n\n      this.isSubmitting = true;\n\n      try {\n        const orderData = {\n          items: this.cart.map(item => ({\n            productId: item.productId,\n            name: item.name,\n            price: item.price,\n            quantity: item.quantity,\n            variants: item.variants,\n            modifiers: item.modifiers\n          })),\n          customerName: this.customerName.trim(),\n          customerPhone: this.customerPhone.trim(),\n          customerNote: this.customerNote.trim(),\n          orderType: this.orderType,\n          tableNumber: '<%= locals.tableNumber || '' %>',\n          menuId: '<%= locals.menu ? menu.id : '' %>',\n          total: this.cartTotal\n        };\n\n        const response = await fetch('/api/v1/orders', {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json'\n          },\n          body: JSON.stringify(orderData)\n        });\n\n        const result = await response.json();\n\n        if (result.success) {\n          // Clear cart and notes\n          this.clearCart();\n          localStorage.removeItem('orderNotes_<%= locals.menu ? menu.id : 'default' %>');\n\n          // Redirect to order status page\n          window.location.href = '<%= locals.menu ? '/m/' + menu.slug : '' %>/order/' + result.data.id;\n        } else {\n          this.errors.submit = result.error?.message || '<%= typeof t === 'function' ? t('checkout.errors.submitFailed') : 'Failed to place order. Please try again.' %>';\n        }\n      } catch (error) {\n        this.errors.submit = '<%= typeof t === 'function' ? t('checkout.errors.networkError') : 'Network error. Please check your connection.' %>';\n      } finally {\n        this.isSubmitting = false;\n      }\n    }\n  }\"\n  class=\"min-h-[60vh] px-4 py-6\"\n>\n  <!-- Page Header -->\n  <header class=\"flex items-center gap-4 mb-6\">\n    <a\n      href=\"<%= locals.menu ? '/m/' + menu.slug + '/cart' : '/cart' %>\"\n      class=\"btn btn-ghost btn-icon\"\n      aria-label=\"<%= typeof t === 'function' ? t('common.back') : 'Back to cart' %>\"\n    >\n      <i class=\"ph ph-arrow-left text-xl\" aria-hidden=\"true\"></i>\n    </a>\n    <div>\n      <h1 class=\"text-2xl font-bold text-text-primary\">\n        <%= typeof t === 'function' ? t('checkout.title') : 'Checkout' %>\n      </h1>\n      <p class=\"text-sm text-text-muted\">\n        <%= typeof t === 'function' ? t('checkout.subtitle') : 'Complete your order' %>\n      </p>\n    </div>\n  </header>\n\n  <!-- Empty Cart Warning -->\n  <template x-if=\"cart.length === 0\">\n    <div class=\"text-center py-12\">\n      <div class=\"w-20 h-20 mx-auto mb-4 rounded-full bg-yellow-100 dark:bg-yellow-900/30 flex items-center justify-center\">\n        <i class=\"ph ph-warning text-4xl text-yellow-500\" aria-hidden=\"true\"></i>\n      </div>\n      <h2 class=\"text-xl font-semibold text-text-primary mb-2\">\n        <%= typeof t === 'function' ? t('checkout.cartEmpty') : 'Your cart is empty' %>\n      </h2>\n      <p class=\"text-text-muted mb-6\">\n        <%= typeof t === 'function' ? t('checkout.cartEmptyDesc') : 'Add items to your cart before checking out' %>\n      </p>\n      <a\n        href=\"<%= locals.menu ? '/m/' + menu.slug : '/' %>\"\n        class=\"btn btn-primary\"\n      >\n        <%= typeof t === 'function' ? t('cart.browseMenu') : 'Browse Menu' %>\n      </a>\n    </div>\n  </template>\n\n  <!-- Checkout Form -->\n  <template x-if=\"cart.length > 0\">\n    <form @submit.prevent=\"submitOrder\" class=\"space-y-6\">\n      <!-- Order Type Selection -->\n      <div class=\"card p-4\">\n        <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n          <i class=\"ph ph-fork-knife mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('checkout.orderType') : 'Order Type' %>\n        </h2>\n\n        <div class=\"grid grid-cols-2 gap-3\">\n          <label\n            class=\"flex flex-col items-center gap-2 p-4 border-2 rounded-lg cursor-pointer transition-all\"\n            :class=\"orderType === 'dine_in'\n              ? 'border-brand-primary bg-brand-primary/5'\n              : 'border-border-color hover:border-brand-primary/50'\"\n          >\n            <input\n              type=\"radio\"\n              name=\"orderType\"\n              value=\"dine_in\"\n              x-model=\"orderType\"\n              class=\"sr-only\"\n            >\n            <i class=\"ph ph-armchair text-3xl\" :class=\"orderType === 'dine_in' ? 'text-brand-primary' : 'text-text-muted'\" aria-hidden=\"true\"></i>\n            <span class=\"text-sm font-medium\" :class=\"orderType === 'dine_in' ? 'text-brand-primary' : 'text-text-secondary'\">\n              <%= typeof t === 'function' ? t('checkout.dineIn') : 'Dine In' %>\n            </span>\n            <% if (locals.tableNumber) { %>\n              <span class=\"text-xs text-text-muted\">\n                <%= typeof t === 'function' ? t('common.table') : 'Table' %> <%= tableNumber %>\n              </span>\n            <% } %>\n          </label>\n\n          <label\n            class=\"flex flex-col items-center gap-2 p-4 border-2 rounded-lg cursor-pointer transition-all\"\n            :class=\"orderType === 'takeaway'\n              ? 'border-brand-primary bg-brand-primary/5'\n              : 'border-border-color hover:border-brand-primary/50'\"\n          >\n            <input\n              type=\"radio\"\n              name=\"orderType\"\n              value=\"takeaway\"\n              x-model=\"orderType\"\n              class=\"sr-only\"\n            >\n            <i class=\"ph ph-package text-3xl\" :class=\"orderType === 'takeaway' ? 'text-brand-primary' : 'text-text-muted'\" aria-hidden=\"true\"></i>\n            <span class=\"text-sm font-medium\" :class=\"orderType === 'takeaway' ? 'text-brand-primary' : 'text-text-secondary'\">\n              <%= typeof t === 'function' ? t('checkout.takeaway') : 'Takeaway' %>\n            </span>\n          </label>\n        </div>\n      </div>\n\n      <!-- Customer Information -->\n      <div class=\"card p-4\">\n        <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n          <i class=\"ph ph-user mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('checkout.customerInfo') : 'Your Information' %>\n        </h2>\n\n        <div class=\"space-y-4\">\n          <!-- Name -->\n          <div>\n            <label for=\"customer-name\" class=\"block text-sm font-medium text-text-primary mb-1\">\n              <%= typeof t === 'function' ? t('checkout.name') : 'Name' %> <span class=\"text-red-500\">*</span>\n            </label>\n            <input\n              type=\"text\"\n              id=\"customer-name\"\n              x-model=\"customerName\"\n              class=\"form-input w-full\"\n              :class=\"errors.name ? 'border-red-500 focus:ring-red-500' : ''\"\n              placeholder=\"<%= typeof t === 'function' ? t('checkout.namePlaceholder') : 'Enter your name' %>\"\n              required\n            >\n            <p x-show=\"errors.name\" x-text=\"errors.name\" class=\"mt-1 text-sm text-red-500\"></p>\n          </div>\n\n          <!-- Phone -->\n          <div>\n            <label for=\"customer-phone\" class=\"block text-sm font-medium text-text-primary mb-1\">\n              <%= typeof t === 'function' ? t('checkout.phone') : 'Phone Number' %> <span class=\"text-red-500\">*</span>\n            </label>\n            <input\n              type=\"tel\"\n              id=\"customer-phone\"\n              x-model=\"customerPhone\"\n              class=\"form-input w-full\"\n              :class=\"errors.phone ? 'border-red-500 focus:ring-red-500' : ''\"\n              placeholder=\"<%= typeof t === 'function' ? t('checkout.phonePlaceholder') : '0532 123 45 67' %>\"\n              required\n            >\n            <p x-show=\"errors.phone\" x-text=\"errors.phone\" class=\"mt-1 text-sm text-red-500\"></p>\n          </div>\n\n          <!-- Special Instructions -->\n          <div>\n            <label for=\"customer-note\" class=\"block text-sm font-medium text-text-primary mb-1\">\n              <%= typeof t === 'function' ? t('checkout.notes') : 'Special Requests' %>\n              <span class=\"text-text-muted font-normal\">(<%= typeof t === 'function' ? t('common.optional') : 'optional' %>)</span>\n            </label>\n            <textarea\n              id=\"customer-note\"\n              x-model=\"customerNote\"\n              rows=\"3\"\n              class=\"form-textarea w-full\"\n              placeholder=\"<%= typeof t === 'function' ? t('checkout.notesPlaceholder') : 'Any allergies, dietary restrictions, or special requests?' %>\"\n            ></textarea>\n          </div>\n        </div>\n      </div>\n\n      <!-- Order Summary -->\n      <div class=\"card p-4\">\n        <h2 class=\"text-lg font-semibold text-text-primary mb-4\">\n          <i class=\"ph ph-receipt mr-2\" aria-hidden=\"true\"></i>\n          <%= typeof t === 'function' ? t('checkout.orderSummary') : 'Order Summary' %>\n        </h2>\n\n        <!-- Items -->\n        <ul class=\"divide-y divide-border-color mb-4\">\n          <template x-for=\"(item, index) in cart\" :key=\"index\">\n            <li class=\"py-3 flex items-start justify-between gap-2\">\n              <div class=\"flex-1 min-w-0\">\n                <div class=\"flex items-center gap-2\">\n                  <span class=\"font-medium text-text-primary\" x-text=\"item.name\"></span>\n                  <span class=\"text-sm text-text-muted\" x-text=\"'x' + item.quantity\"></span>\n                </div>\n                <template x-if=\"item.variants.length > 0 || item.modifiers.length > 0\">\n                  <p class=\"text-xs text-text-muted mt-0.5\">\n                    <template x-for=\"(v, i) in item.variants\">\n                      <span x-text=\"v.name + (i < item.variants.length - 1 || item.modifiers.length > 0 ? ', ' : '')\"></span>\n                    </template>\n                    <template x-for=\"(m, i) in item.modifiers\">\n                      <span x-text=\"m.name + (i < item.modifiers.length - 1 ? ', ' : '')\"></span>\n                    </template>\n                  </p>\n                </template>\n              </div>\n              <span class=\"font-medium text-text-primary whitespace-nowrap\" x-text=\"formatPrice(item.price * item.quantity)\"></span>\n            </li>\n          </template>\n        </ul>\n\n        <!-- Totals -->\n        <div class=\"space-y-2 pt-4 border-t border-border-color\">\n          <div class=\"flex items-center justify-between text-sm\">\n            <span class=\"text-text-secondary\"><%= typeof t === 'function' ? t('checkout.subtotal') : 'Subtotal' %></span>\n            <span class=\"text-text-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n          </div>\n          <div class=\"flex items-center justify-between text-lg font-bold\">\n            <span class=\"text-text-primary\"><%= typeof t === 'function' ? t('checkout.total') : 'Total' %></span>\n            <span class=\"text-brand-primary\" x-text=\"formatPrice(cartTotal)\"></span>\n          </div>\n        </div>\n      </div>\n\n      <!-- Error Message -->\n      <div\n        x-show=\"errors.submit\"\n        x-transition\n        class=\"p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg\"\n        role=\"alert\"\n      >\n        <div class=\"flex items-center gap-2 text-red-600 dark:text-red-400\">\n          <i class=\"ph ph-warning-circle text-xl\" aria-hidden=\"true\"></i>\n          <span x-text=\"errors.submit\"></span>\n        </div>\n      </div>\n\n      <!-- Submit Button -->\n      <button\n        type=\"submit\"\n        class=\"btn btn-primary w-full py-4 text-lg\"\n        :disabled=\"isSubmitting\"\n        :class=\"{ 'opacity-50 cursor-not-allowed': isSubmitting }\"\n      >\n        <template x-if=\"isSubmitting\">\n          <span class=\"flex items-center justify-center gap-2\">\n            <i class=\"ph ph-spinner animate-spin\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('checkout.placing') : 'Placing Order...' %>\n          </span>\n        </template>\n        <template x-if=\"!isSubmitting\">\n          <span class=\"flex items-center justify-center gap-2\">\n            <i class=\"ph ph-check-circle\" aria-hidden=\"true\"></i>\n            <%= typeof t === 'function' ? t('checkout.placeOrder') : 'Place Order' %>\n            <span x-text=\"formatPrice(cartTotal)\"></span>\n          </span>\n        </template>\n      </button>\n\n      <!-- Terms -->\n      <p class=\"text-xs text-text-muted text-center\">\n        <%= typeof t === 'function' ? t('checkout.termsNotice') : 'By placing your order, you agree to our terms of service.' %>\n      </p>\n    </form>\n  </template>\n</section>\n",
        "last_modified": "2026-02-01T09:10:53.772780"
      },
